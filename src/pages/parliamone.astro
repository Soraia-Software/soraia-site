---
import Layout from "~/layouts/Layout.astro";
import LeadForm from "~/components/LeadForm.tsx";
import AvatarCircle from "~/components/AvatarCircle.astro";

const title = "Parliamone — contattaci | Soraia";
const description =
  "Raccontaci la tua realtà operativa. Ti rispondiamo entro 24 ore con una proposta di AI Readiness Assessment concreta, perimetrata sul tuo contesto.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Parliamone — Soraia",
  url: "https://www.soraia.io/parliamone",
};
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <!-- ============================================================
       HERO + FORM unico
       ============================================================ -->
  <section class="relative overflow-hidden bg-violet-mesh min-h-[calc(100vh-72px)]">
    <div class="orb orb-violet w-[500px] h-[500px] -top-32 -right-20 opacity-40 float-slow" aria-hidden="true"></div>
    <div class="orb orb-lilac w-[400px] h-[400px] -bottom-20 -left-20 opacity-40 float-slower" aria-hidden="true"></div>

    <div class="container-soraia pt-16 md:pt-24 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <!-- LEFT: Hero copy + CEO card -->
        <div class="lg:col-span-5 lg:sticky lg:top-32">
          <p class="eyebrow mb-6 fade-up">Parliamone</p>

          <h1 class="font-display text-[2.75rem] sm:text-[3.5rem] md:text-[4rem] font-semibold tracking-tight text-ink-900 leading-[1.02] text-balance fade-up fade-up-delay-1">
            Parliamo dei tuoi processi?
          </h1>

          <p class="mt-6 text-[18px] md:text-[19px] text-ink-700 leading-relaxed text-pretty fade-up fade-up-delay-2 max-w-lg">
            Raccontaci la tua realtà operativa. Ti rispondiamo entro 24 ore con una proposta di assessment concreta, perimetrata sul tuo contesto.
          </p>

          <ul class="mt-8 space-y-3.5 fade-up fade-up-delay-3">
            {[
              "Assessment 2.000€, rimborsato se procedi",
              "Risposta entro 24 ore",
              "Nessun impegno a procedere",
              "Paghi solo se sei soddisfatto",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 mt-1 inline-flex w-5 h-5 rounded-full bg-violet-600 items-center justify-center">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                </span>
                <span class="text-[15px] text-ink-700">{item}</span>
              </li>
            ))}
          </ul>

          <!-- CEO card -->
          <div class="mt-10 p-5 rounded-2xl bg-white border border-ink-200 shadow-sm fade-up fade-up-delay-4 max-w-md">
            <div class="flex items-center gap-4">
              <AvatarCircle name="Daniel Levis" src="/team/daniel-levis.png" size="lg" />
              <div>
                <p class="font-semibold text-ink-900 text-[15px] leading-tight">Daniel Levis</p>
                <p class="text-sm text-ink-500 mt-0.5">Co-Founder & CEO</p>
                <p class="text-xs text-ink-500 mt-1.5 leading-snug">
                  Rispondo personalmente alle richieste entro 24 ore.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="lg:col-span-7 fade-up fade-up-delay-2">
          <LeadForm client:load lang="it" source="parliamone" />
        </div>
      </div>
    </div>
  </section>
</Layout>
