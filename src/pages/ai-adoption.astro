---
import Layout from "~/layouts/Layout.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import FAQ from "~/components/FAQ.astro";

const title = "AI Adoption, formazione e change management | Soraia";
const description =
  "Workshop pratico sui processi reali del tuo team, tutoraggio mensile, 110h/anno liberate per persona. Payback in 7-11 settimane. Adottato da LIFTT, APraise, Numeraria, Stars Be Original.";

const phases = [
  {
    num: "01",
    name: "Kick-off scoping",
    what: "Sessione con sponsor interno e advanced users per mappare i processi reali da portare in aula. Output: agenda workshop customizzata sui task del tuo team.",
    time: "2-4 ore",
  },
  {
    num: "02",
    name: "Workshop in batch",
    what: "Suddividiamo il team in batch da <strong>max 10 persone</strong>, N batch in base alla dimensione del team. Uso consapevole degli strumenti AI aziendali, connettori standardizzati (drive, email, chat, CRM, ATS, gestionale), skill aziendali condivise, policy \"AI safe use\". Stesso contenuto per ogni batch, formato adattivo per garantire engagement e tenere libera parte del team operativo durante le sessioni.",
    time: "2 giorni × 4h per batch",
  },
  {
    num: "03",
    name: "Wrap-up review",
    what: "Una sessione per batch a 1 mese dal workshop. Formato circle: ogni partecipante porta un caso reale, vediamo cosa è stato applicato, dove ci si è bloccati, cosa serve consolidare.",
    time: "2 ore per batch",
  },
];

const deliverables = [
  "Prompt-pack per ruolo con i task ricorrenti già pronti",
  "Set di skill aziendali standardizzate (delete protection, approval flow, gestione connettori)",
  "Policy 1-pager \"AI safe use\" da circolare internamente",
  "Checklist connettori: cosa attivare, cosa disattivare, quando, con che permessi",
];

const coachingPackages = [
  {
    hours: "10 ore",
    rate: "120 €/ora",
    total: "1.200 €",
    when: "Pochi casi specifici da sbloccare nelle settimane successive al workshop.",
  },
  {
    hours: "20 ore",
    rate: "100 €/ora",
    total: "2.000 €",
    when: "Accompagnamento più sostenuto e distribuito su più persone del team.",
  },
  {
    hours: "50 ore",
    rate: "90 €/ora",
    total: "4.500 €",
    when: "Programma di consolidamento esteso, copre l'intero anno post-workshop.",
  },
];

const dontFeatures = [
  "Corsi teorici sull'impatto dell'AI nella società o nell'economia",
  "Slide riempite di tool generici, scollegate dai tuoi processi reali",
  "Workshop one-shot senza follow-up, il 70% del contenuto si perde in 2 settimane",
];

const faqs = [
  {
    q: "Per chi è pensato il programma?",
    a: "Per <strong>knowledge worker che fanno lavoro analitico, gestionale o creativo</strong>: Business Analyst, M&A, Project Manager, Recruiter, Account Manager, Content Creator, Operations, Customer Success. Lavoriamo con team da 10 a 50 persone, sopra i 50 modulariamo in più batch.",
  },
  {
    q: "Quanto dura il programma completo?",
    a: "<strong>Foundation</strong>: ~6 settimane totali (kick-off + 2 workshop in 2-3 sett + wrap-up a 1 mese). <strong>Foundation + Tutoraggio</strong>: 4 mesi (Foundation + 3 mesi di accompagnamento). <strong>Foundation + Brain Pilot</strong>: 4 mesi con coaching dedicato sul brain.",
  },
  {
    q: "Su quali strumenti AI lavorate?",
    a: "<strong>Siamo AI-agnostic.</strong> Partiamo da quello che la tua azienda ha già scelto, qualunque LLM aziendale (ChatGPT, Claude, Gemini, Copilot, Mistral o altri), qualunque stack di automazione, qualunque CRM/ATS/ERP/gestionale. Non vendiamo licenze nuove né ti facciamo cambiare provider. <strong>Insegniamo a usare bene quello che il team usa già male o non usa.</strong>",
  },
  {
    q: "Cosa significa Company Brain e perché serve?",
    a: "Un framework leggero (cartella locale + repository privato) dove ogni persona accumula conoscenza propria sui processi, clienti, progetti seguiti. Lo strumento AI scelto dall'azienda vi accede e diventa di fatto un \"intern personale\" che conosce il lavoro della persona e a cui delegare task. <strong>Già adottato internamente da Soraia da oltre 6 mesi</strong>, framework pronto da deployare.",
  },
  {
    q: "Workshop in presenza o da remoto?",
    a: "<strong>Default: in presenza presso la tua sede</strong>, perché l'engagement è 3x e i casi pratici emergono spontaneamente. Possibile da remoto per team distribuiti, con setup specifico (sessioni più corte, esercizi async tra le sessioni). Trasferte in Italia incluse nel setup.",
  },
  {
    q: "Come misurate il ROI?",
    a: "<strong>Tracking della produttività self-reported</strong>: punto di partenza in kick-off, milestone a 1 e 3 mesi. <strong>Final review a 5 mesi</strong> con dati di impatto consolidati e roadmap successiva. La stima conservativa è 30 minuti liberati/giorno/persona, che a 220 giorni lavorativi = 110h/anno/persona × €50-80/h fully loaded.",
  },
  {
    q: "Cosa succede se l'adozione non parte?",
    a: "Le Proposte 2 e 3 includono <strong>tutoraggio mensile con accountability</strong> (esercizio assegnato, check-up di gruppo, coaching 1:1): è la differenza tra adozione reale e workshop dimenticato. Se nonostante questo l'adozione non si attiva, lo capiamo a 2 mesi e adattiamo metodo o partecipanti, non aspettiamo il final review.",
  },
  {
    q: "Avete esperienza nel mio settore?",
    a: "Abbiamo erogato programmi simili a clienti in <strong>venture capital e financial services</strong> (LIFTT), <strong>recruitment</strong> (APraise, Stars Be Original), <strong>accounting</strong> (Numeraria), <strong>real estate</strong> (FRH, Rainplan), <strong>tech</strong> (Navily, StoryWonder). Lo scoping iniziale parte sempre dal tuo settore specifico.",
  },
];

const stripTags = (html: string) => html.replace(/<[^>]+>/g, "");

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Adoption, formazione e change management",
    provider: {
      "@type": "Organization",
      name: "Soraia",
      url: "https://www.soraia.io",
    },
    areaServed: ["IT", "EU"],
    serviceType: "AI training and change management for SMEs",
    offers: [
      {
        "@type": "Offer",
        name: "Foundation",
        priceCurrency: "EUR",
        description: "Kick-off + workshop in batch + wrap-up. Team fino a 20 persone. €8-10k.",
      },
      {
        "@type": "Offer",
        name: "Foundation + Tutoraggio",
        priceCurrency: "EUR",
        description: "Foundation + 3 mesi di tutoraggio mensile e coaching 1:1. €20-25k.",
      },
      {
        "@type": "Offer",
        name: "Foundation + Tutoraggio + Brain Pilot",
        priceCurrency: "EUR",
        description: "Foundation + Tutoraggio + Company Brain pilot per 5-6 advanced users. €30-35k.",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: stripTags(f.a),
      },
    })),
  },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="max-w-[900px]" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Persone · AI Adoption
        </p>

        <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
          Programmi di AI Adoption<br/>che generano produttività reale.
        </h1>

        <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
          Workshop pratico sui processi reali del tuo team, tutoraggio mensile per garantire adozione. <strong style="color: #fff; font-weight: 500;">110h/anno liberate per persona</strong>, payback in 7-11 settimane.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
          <a href="/parliamone" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
            20 min con Daniel
            <span class="btn-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
          <a href="#proposte" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">
            Vedi le 3 proposte
          </a>
        </div>

        <!-- Anchor scroll -->
        <a href="#metodo" class="mt-6 inline-flex items-center gap-1.5 text-[13px] fade-up fade-up-delay-3" style="color: rgba(255,255,255,0.55);">
          Oppure scorri per vedere il metodo
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12l-7 7-7-7M12 5v14"/></svg>
        </a>

        <!-- Trust strip -->
        <div class="mt-10 pt-8 border-t fade-up fade-up-delay-3" style="border-color: rgba(255,255,255,0.12);">
          <p class="text-[10px] uppercase tracking-[0.18em] mb-3" style="color: rgba(255,255,255,0.45);">Hanno già adottato il programma</p>
          <p class="text-[13.5px] leading-relaxed" style="color: rgba(255,255,255,0.7);">
            LIFTT · APraise · Numeraria · Stars Be Original · FRH · Rainplan · Navily · StoryWonder
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       IL PROBLEMA
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Il problema"
        title="Il 75% dei dipendenti usa l'AI senza che l'azienda lo sappia."
        subtitle="Fonte: Microsoft Work Trend Index 2024. Il vero gap non è la tecnologia, è l'<strong>adozione strutturata</strong>. In ogni team convivono una minoranza avanzata che costruisce skill personali e una maggioranza che usa l'AI come una chat. Il risultato: divario di produttività dentro lo stesso team, processi non condivisi, rischi di governance fuori controllo."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <article class="card-editorial reveal !p-7 flex flex-col gap-4">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-violet-700 to-violet-500 flex items-center justify-center shadow-violet">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-ink-900 leading-tight">Asimmetrie nel team</h3>
            <p class="mt-2 text-[15px] text-ink-600 leading-relaxed text-pretty">Chi sa usare l'AI fa il triplo. Chi non sa, resta indietro. La produttività media non sale, sale solo quella dei 2-3 power user.</p>
          </div>
        </article>

        <article class="card-editorial reveal reveal-delay-1 !p-7 flex flex-col gap-4">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-violet-700 to-violet-500 flex items-center justify-center shadow-violet">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-ink-900 leading-tight">Governance assente</h3>
            <p class="mt-2 text-[15px] text-ink-600 leading-relaxed text-pretty">"L'AI ha cancellato i file" è successo davvero in più aziende. Servono skill con multi-step confirmation, approval workflow, regole condivise.</p>
          </div>
        </article>

        <article class="card-editorial reveal reveal-delay-2 !p-7 flex flex-col gap-4">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-violet-700 to-violet-500 flex items-center justify-center shadow-violet">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-ink-900 leading-tight">Workshop dimenticati</h3>
            <p class="mt-2 text-[15px] text-ink-600 leading-relaxed text-pretty">Il <strong class="text-ink-900">70% del contenuto</strong> di un corso evapora in 2 settimane senza accountability. Per questo i nostri programmi includono tutoraggio mensile.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       IL METODO
       ============================================================ -->
  <section id="metodo" class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Il metodo"
        title="Tre fasi. Niente slide, solo casi vostri."
        subtitle="Tutte le proposte condividono lo stesso scheletro metodologico. Cambiano profondità e durata dell'accompagnamento post-workshop."
        align="center"
      />

      <ol class="adoption-timeline max-w-6xl mx-auto reveal">
        {phases.map((p, i) => (
          <li class={`adoption-step ${i === phases.length - 1 ? "adoption-step--milestone" : ""}`}>
            <div class="adoption-step-head">
              <span class={`adoption-num ${i === phases.length - 1 ? "adoption-num--milestone" : ""}`}>{p.num}</span>
              <div class="adoption-step-meta">
                <p class="adoption-step-tag">{p.time}</p>
                <p class="adoption-step-title">{p.name}</p>
              </div>
            </div>
            <p class="adoption-step-body"><Fragment set:html={p.what} /></p>
          </li>
        ))}
      </ol>

      <!-- Deliverable -->
      <div class="mt-12 max-w-5xl mx-auto reveal">
        <p class="eyebrow mb-5">Deliverable consegnati</p>
        <h3 class="text-[1.5rem] md:text-[1.75rem] font-semibold text-ink-900 mb-6 leading-tight">Cosa porta a casa il tuo team.</h3>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {deliverables.map((d) => (
            <li class="flex items-start gap-3 p-4 rounded-xl bg-white border border-ink-200">
              <span class="shrink-0 mt-0.5 inline-flex w-6 h-6 rounded-full bg-violet-50 items-center justify-center">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4A1E5C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              <span class="text-[15px] text-ink-700 leading-relaxed">{d}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHI TIENE IL WORKSHOP
       ============================================================ -->
  <section id="docente" class="section bg-white border-t border-line">
    <div class="container-soraia max-w-5xl">
      <SectionHeader
        eyebrow="Chi tiene il workshop"
        title="Due co-founder in aula. Due prospettive complementari."
        subtitle="Daniel guida la parte di <strong>change management e AI adoption</strong>: come trasformare l'uso AI in produttività di team. Davide guida la parte di <strong>agent development e governance tecnica</strong>: connettori, skill aziendali, safe use. I casi che portano in aula sono casi che hanno vissuto sui clienti Soraia."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-5xl mx-auto reveal">
        <!-- Daniel Levis -->
        <article class="card-editorial !p-7 md:!p-8 flex flex-col">
          <div class="flex items-start gap-5 mb-5">
            <div class="w-20 h-20 md:w-24 md:h-24 shrink-0 rounded-2xl overflow-hidden bg-ink-50 ring-1 ring-violet-100">
              <img src="/team/daniel-levis.webp" alt="Daniel Levis, Co-Founder & CEO Soraia" class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </div>
            <div class="min-w-0">
              <h3 class="text-[1.35rem] md:text-[1.5rem] font-semibold tracking-tight text-ink-900 leading-tight mb-1">Daniel Levis</h3>
              <p class="text-[13.5px] text-violet-700 font-semibold mb-1">Co-Founder & CEO</p>
              <p class="text-[12px] text-ink-500 uppercase tracking-[0.14em]">Change management · AI adoption</p>
            </div>
          </div>

          <p class="text-[14.5px] text-ink-700 leading-relaxed text-pretty flex-1">
            Ex consulente di trasformazione digitale in gruppi quali Reply, Accenture e Alten, ha guidato la trasformazione AI di PMI italiane in venture capital, recruitment, marketing, finance. Ha tenuto programmi di AI Adoption all'ESCP Business School.
          </p>
        </article>

        <!-- Davide Silvestri -->
        <article class="card-editorial !p-7 md:!p-8 flex flex-col">
          <div class="flex items-start gap-5 mb-5">
            <div class="w-20 h-20 md:w-24 md:h-24 shrink-0 rounded-2xl overflow-hidden bg-ink-50 ring-1 ring-violet-100">
              <img src="/team/davide-silvestri.webp" alt="Davide Silvestri, Co-Founder & CTO Soraia" class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </div>
            <div class="min-w-0">
              <h3 class="text-[1.35rem] md:text-[1.5rem] font-semibold tracking-tight text-ink-900 leading-tight mb-1">Davide Silvestri</h3>
              <p class="text-[13.5px] text-violet-700 font-semibold mb-1">Co-Founder & CTO</p>
              <p class="text-[12px] text-ink-500 uppercase tracking-[0.14em]">Agent development · Governance</p>
            </div>
          </div>

          <p class="text-[14.5px] text-ink-700 leading-relaxed text-pretty flex-1">
            10+ anni in technical project management, leadership e backend architecture. In aula porta la parte tecnica: connettori standardizzati, skill aziendali, safe use, costruzione di agenti veri sui processi del team. Ex Simon-Kucher, Amazon, Dott, Satispay.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COSA NON FACCIAMO (moved before pricing for positioning)
       ============================================================ -->
  <section class="section bg-ink-900 relative overflow-hidden">
    <div class="orb orb-violet w-[500px] h-[500px] -top-20 -right-20 opacity-40 float-slow" aria-hidden="true"></div>

    <div class="container-soraia relative z-10 max-w-4xl">
      <p class="eyebrow eyebrow-light mb-6 reveal">Cosa NON facciamo</p>
      <h2 class="text-[2.5rem] md:text-[3.5rem] font-semibold tracking-tight text-white leading-[1.05] text-balance reveal mb-10">
        Lo diciamo subito, per evitare malintesi.
      </h2>

      <ul class="space-y-4 reveal reveal-delay-1">
        {dontFeatures.map((item) => (
          <li class="flex items-start gap-4 pb-5 border-b border-white/10 last:border-b-0">
            <span class="shrink-0 mt-1 inline-flex w-7 h-7 rounded-full bg-red-500/15 items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F87171" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </span>
            <span class="text-[16px] md:text-[17px] text-white/85 leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================================================
       3 PROPOSTE. PRICING
       ============================================================ -->
  <section id="proposte" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Tre livelli"
        title="Tre proposte. Stessa base, accompagnamento diverso."
        subtitle="Tutte includono kick-off, workshop e wrap-up. Cambia la profondità del follow-up post-workshop, perché è lì che si gioca l'adozione reale."
        align="center"
      />

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Proposta 1: Foundation -->
        <article class="card-editorial relative reveal !p-8 flex flex-col">
          <div class="mb-5">
            <p class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold mb-2">Proposta 1</p>
            <h3 class="text-[1.5rem] md:text-[1.75rem] font-semibold text-ink-900 leading-tight">Foundation</h3>
          </div>

          <div class="flex items-baseline gap-1.5 mb-2">
            <span class="text-[2.5rem] font-semibold text-ink-900 leading-none">€8-10k</span>
          </div>
          <p class="text-[12px] text-ink-500 mb-5">Per team fino a 20 persone</p>

          <p class="text-[14px] text-ink-700 leading-relaxed mb-6 text-pretty flex-1">
            <strong class="text-ink-900">Quando ha senso:</strong> serve livellare le skill base e mettere in sicurezza l'uso AI senza commitment di lungo periodo.
          </p>

          <div class="hairline mb-5"></div>

          <p class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold mb-3">Cosa include</p>
          <ul class="space-y-2 text-[14px] text-ink-700 mb-6">
            {[
              "Kick-off scoping (2-4h)",
              "Workshop in batch da max 10 persone (2 giorni × 4h ogni batch)",
              "Wrap-up review a 1 mese (2h per batch)",
              "Tutti i deliverable concreti",
            ].map((item) => (
              <li class="flex items-start gap-2.5">
                <span class="shrink-0 mt-1 inline-flex w-4 h-4 rounded-full bg-violet-50 items-center justify-center">
                  <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#4A1E5C" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                </span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <a href="/parliamone" class="mt-auto btn btn-secondary !w-full !justify-center text-[14px]">
            Parla di Foundation
            <span class="btn-arrow">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
        </article>

        <!-- Proposta 2: Foundation + Tutoraggio (RECOMMENDED) -->
        <article class="relative reveal reveal-delay-1 rounded-2xl p-8 flex flex-col overflow-hidden bg-gradient-to-br from-violet-900 via-violet-800 to-violet-700 text-white shadow-violet-lg">
          <div class="orb orb-violet w-[300px] h-[300px] -top-20 -right-20 opacity-40 float-slow" aria-hidden="true"></div>
