  <style is:global>
    /* === Adoption timeline === */
    .adoption-timeline {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      list-style: none;
      padding: 0;
      margin: 2.5rem 0 0;
      position: relative;
    }
    @media (min-width: 1024px) {
      .adoption-timeline {
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      .adoption-timeline::before {
        content: "";
        position: absolute;
        top: 22px;
        left: 8%;
        right: 8%;
        height: 2px;
        background: linear-gradient(to right,
          var(--color-line-strong) 0%,
          var(--color-violet-300) 50%,
          var(--color-brand) 100%);
        opacity: 0.5;
        z-index: 0;
      }
    }
    .adoption-step {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .adoption-step-head {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    @media (min-width: 1024px) {
      .adoption-step-head {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.1rem;
      }
    }
    .adoption-num {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 9999px;
      background: white;
      border: 1.5px solid var(--color-violet-300);
      color: var(--color-brand);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 500;
      font-size: 0.95rem;
      letter-spacing: -0.01em;
      box-shadow: 0 0 0 8px var(--color-ink-50);
    }
    .adoption-num--milestone {
      background: var(--color-brand);
      border-color: var(--color-brand);
      color: white;
      box-shadow: 0 0 0 8px var(--color-ink-50), 0 4px 14px -4px rgba(74, 30, 92, 0.40);
    }
    .adoption-step-meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      min-width: 0;
    }
    .adoption-step-tag {
      font-size: 10.5px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ink-soft);
      line-height: 1.4;
    }
    .adoption-step-title {
      font-size: 15.5px;
      line-height: 1.25;
      letter-spacing: -0.015em;
      font-weight: 500;
      color: var(--color-ink);
    }
    .adoption-step-body {
      font-size: 13.5px;
      line-height: 1.6;
      color: var(--color-ink-muted);
      margin: 0;
      text-wrap: pretty;
    }
    .adoption-step-body strong {
      color: var(--color-ink);
      font-weight: 500;
    }
    .adoption-step--milestone .adoption-step-title {
      color: var(--color-brand);
    }
  </style>
