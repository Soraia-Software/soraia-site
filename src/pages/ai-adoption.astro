  <!-- ============================================================
       CTA FINALE — Call CEO
       ============================================================ -->
  <CTABanner
    title="Inizia con una call gratuita con il nostro CEO."
    description="20 minuti per capire insieme quale delle 3 proposte ha senso per il tuo team. Nessun impegno, nessun pitch commerciale."
    ctaText="Prenota la call"
