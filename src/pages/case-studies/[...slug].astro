---
import Layout from "~/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import CTABanner from "~/components/CTABanner.astro";

export async function getStaticPaths() {
  const cases = await getCollection("caseStudies");
  return cases.map((c) => ({
    params: { slug: c.id },
    props: { study: c },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const allCases = await getCollection("caseStudies");
const related = (study.data.related || [])
  .map((slug) => allCases.find((c) => c.id === slug))
  .filter(Boolean)
  .slice(0, 2);

function formatDate(d: Date) {
  return d.toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" });
}

const title = `${study.data.title} | Case study Soraia`;
const description = study.data.teaser.problem;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: study.data.title,
  description,
  datePublished: study.data.pubDate.toISOString(),
  author: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
  publisher: { "@type": "Organization", name: "Soraia", logo: { "@type": "ImageObject", url: "https://www.soraia.io/logos/soraia-full.svg" } },
  about: study.data.client,
};
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <article>
    <!-- ============================================================
         HERO
         ============================================================ -->
    <section class="relative overflow-hidden border-b border-line" style="background: #FAFAF8;">
      <div class="container-soraia pt-16 md:pt-20 pb-12 md:pb-16">
        <nav class="flex items-center gap-2 text-[13px] mb-8" style="color: var(--color-ink-soft);">
          <a href="/" class="hover:opacity-70 transition-opacity" style="color: var(--color-ink-soft);">Home</a>
          <span>›</span>
          <a href="/case-studies" class="hover:opacity-70 transition-opacity" style="color: var(--color-ink-soft);">Case studies</a>
          <span>›</span>
          <span style="color: var(--color-ink-muted);">{study.data.client}</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-10 lg:gap-16 items-start">
          <div>
            <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-5" style="color: var(--color-ink-soft);">
              <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
              {study.data.service} · {study.data.sector}
            </p>
            <h1 class="text-balance" style="font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;">
              {study.data.title}
            </h1>
            <p class="mt-7 text-[18px] md:text-[19px] leading-relaxed text-pretty max-w-2xl" style="color: var(--color-ink-muted);">
              {study.data.teaser.problem}
            </p>
          </div>

          <!-- Stats bar -->
          {study.data.stats.length > 0 && (
            <aside class="grid grid-cols-1 gap-px rounded-2xl overflow-hidden" style="background: var(--color-line); border: 1px solid var(--color-line);">
              {study.data.stats.map((s) => (
                <div class="bg-white p-6 md:p-7">
                  <p class="text-[1.75rem] md:text-[2.25rem] font-medium leading-none" style="color: var(--color-brand); letter-spacing: -0.025em;">{s.value}</p>
                  <p class="mt-3 text-[14px] font-medium" style="color: var(--color-ink);">{s.label}</p>
                  {s.sub && <p class="mt-1 text-[12.5px]" style="color: var(--color-ink-soft);">{s.sub}</p>}
                </div>
              ))}
            </aside>
          )}
        </div>
      </div>
    </section>

    <!-- ============================================================
         HERO QUOTE
         ============================================================ -->
    <section class="bg-white border-b border-line">
      <div class="container-soraia max-w-4xl py-14 md:py-20">
        <div class="flex flex-col md:flex-row gap-7 md:gap-10 items-start">
          <img
            src={study.data.stakeholder.photo}
            alt={study.data.stakeholder.name}
            loading="eager"
            width="80"
            height="80"
            class="w-16 h-16 md:w-20 md:h-20 rounded-full object-cover flex-shrink-0"
          />
          <div>
            <svg width="32" height="24" viewBox="0 0 32 24" fill="none" class="mb-4" style="color: var(--color-brand); opacity: 0.30;">
              <path d="M0 24V14.4c0-2.88.72-5.52 2.16-7.92C3.6 4.08 5.76 2.16 8.64.72L11.52 4.8c-1.92.96-3.36 2.16-4.32 3.6-.96 1.44-1.44 3-1.44 4.68v.96h6.24V24H0zm18.72 0V14.4c0-2.88.72-5.52 2.16-7.92C22.32 4.08 24.48 2.16 27.36.72L30.24 4.8c-1.92.96-3.36 2.16-4.32 3.6-.96 1.44-1.44 3-1.44 4.68v.96H30.72V24H18.72z" fill="currentColor"/>
            </svg>
            <p class="text-balance" style="font-size: clamp(1.25rem, 2vw + 0.5rem, 1.625rem); line-height: 1.35; letter-spacing: -0.015em; font-weight: 500; color: var(--color-ink);">
              {study.data.heroQuote}
            </p>
            <p class="mt-6 text-[14px] font-medium" style="color: var(--color-ink);">{study.data.stakeholder.name}</p>
            <p class="text-[13px] mt-0.5" style="color: var(--color-ink-soft);">{study.data.stakeholder.role} · {study.data.client}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         BODY (prose)
         ============================================================ -->
    <section class="bg-white">
      <div class="container-soraia max-w-3xl py-12 md:py-16">
        <div class="prose-soraia">
          <Content />
        </div>

        <!-- Screenshot placeholder hint -->
        <div class="mt-10 p-5 rounded-lg border border-dashed" style="border-color: var(--color-line-strong); background: var(--color-ink-50);">
          <p class="text-[12px] font-medium uppercase tracking-[0.14em] mb-2" style="color: var(--color-ink-soft);">Screenshot da inserire</p>
          <p class="text-[13px]" style="color: var(--color-ink-muted);">
            Spazio riservato per 2-3 screenshot del prodotto / interfaccia agente per {study.data.client}. Da fornire dal cliente o dal team Soraia, poi inserire qui o nel body markdown.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         TIMELINE + STACK
         ============================================================ -->
    {(study.data.timeline || study.data.stack.length > 0) && (
      <section class="bg-ink-50 border-y border-line">
        <div class="container-soraia max-w-4xl py-14 md:py-16">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
            {study.data.timeline && (
              <div>
                <p class="text-[11px] font-medium tracking-[0.14em] uppercase mb-4" style="color: var(--color-ink-soft);">Timeline</p>
                <p class="text-[16px] leading-relaxed" style="color: var(--color-ink);">{study.data.timeline}</p>
              </div>
            )}
            {study.data.stack.length > 0 && (
              <div>
                <p class="text-[11px] font-medium tracking-[0.14em] uppercase mb-4" style="color: var(--color-ink-soft);">Stack tecnico</p>
                <div class="flex flex-wrap gap-2">
                  {study.data.stack.map((s) => (
                    <span class="text-[12.5px] px-2.5 py-1 rounded-md" style="background: white; color: var(--color-ink); border: 1px solid var(--color-line);">{s}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- ============================================================
         RELATED CASE STUDIES
         ============================================================ -->
    {related.length > 0 && (
      <section class="bg-white border-b border-line">
        <div class="container-soraia py-14 md:py-20">
          <p class="eyebrow mb-8">Altri case study</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 max-w-5xl">
            {related.map((r) => (
              <a href={`/case-studies/${r.id}`} class="card-editorial !p-7 group no-underline flex flex-col transition-all hover:!-translate-y-0.5 hover:shadow-md">
                <p class="text-[11px] font-medium tracking-[0.14em] uppercase mb-4" style="color: var(--color-ink-soft);">
                  {r.data.service} · {r.data.sector}
                </p>
                <h3 class="mb-3 text-balance" style="font-size: 1.125rem; line-height: 1.25; letter-spacing: -0.015em; font-weight: 500;">{r.data.client}</h3>
                <p class="text-[14px] leading-relaxed text-pretty mb-4 flex-1" style="color: var(--color-ink-muted);">{r.data.teaser.problem}</p>
                <p class="text-[13px] font-medium" style="color: var(--color-brand);">{r.data.teaser.resultMetric}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ============================================================
         CTA FINALE
         ============================================================ -->
    <CTABanner
      title="Hai un caso simile?"
      description="20 minuti col CEO per capire insieme se ha senso. Nessun impegno, nessun preventivo a sorpresa: solo una conversazione operativa sui tuoi processi."
      ctaText="20 min con Daniel"
      ctaHref="/parliamone"
      avatarName="Daniel Levis"
      avatarRole="Co-Founder & CEO"
      avatarSrc="/team/daniel-levis.png"
    />
  </article>
</Layout>

<style is:global>
  .prose-soraia {
    color: var(--color-ink);
    font-size: 17px;
    line-height: 1.75;
  }
  .prose-soraia > * + * { margin-top: 1.25em; }
  .prose-soraia h2 {
    font-size: clamp(1.5rem, 2vw + 0.5rem, 1.875rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 500;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--color-ink);
  }
  .prose-soraia h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-weight: 500;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-ink);
  }
  .prose-soraia p { color: var(--color-ink); }
  .prose-soraia strong { font-weight: 600; color: var(--color-ink); }
  .prose-soraia a {
    color: var(--color-brand);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose-soraia a:hover { opacity: 0.7; }
  .prose-soraia ul, .prose-soraia ol {
    padding-left: 1.4em;
    color: var(--color-ink);
  }
  .prose-soraia ul { list-style: disc; }
  .prose-soraia ol { list-style: decimal; }
  .prose-soraia li { margin: 0.4em 0; }
  .prose-soraia li::marker { color: var(--color-ink-soft); }
  .prose-soraia hr {
    border: none;
    border-top: 1px solid var(--color-line);
    margin-block: 2.5em;
  }
</style>
