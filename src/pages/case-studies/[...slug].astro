---
import Layout from "~/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import CTABanner from "~/components/CTABanner.astro";
import AvatarCircle from "~/components/AvatarCircle.astro";
import CaseStudyCarousel from "~/components/CaseStudyCarousel.astro";

export async function getStaticPaths() {
  const cases = await getCollection("caseStudies");
  return cases.map((c) => ({
    params: { slug: c.id },
    props: { study: c },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const allCases = await getCollection("caseStudies");
const explicitRelated = (study.data.related || [])
  .map((slug) => allCases.find((c) => c.id === slug))
  .filter(Boolean);
// Fill up to 6 cards: prefer explicit related, then recent (excluding current)
const fillers = allCases
  .filter((c) => c.id !== study.id && !explicitRelated.find((e) => e!.id === c.id))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.pubDate.getTime() - a.data.pubDate.getTime();
  });
const related = [...explicitRelated, ...fillers].slice(0, 6);

function formatDate(d: Date) {
  return d.toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" });
}

// Fallback photo mapping: per i case study che hanno stakeholder.photo vuoto,
// pesca dalla cartella /testimonials/ se esiste una foto matchante.
const photoMap: Record<string, string> = {
  "40factory": "/testimonials/margherita-chifari-40factory.webp",
  aegis: "/testimonials/aegis_vittorio_maiani.webp",
  apraise: "/testimonials/jacopo-castano-apraise.webp",
  cxl: "/testimonials/brian-dandelet-cxl.webp",
  frh: "/testimonials/fabricio-carminati-frh.webp",
  liftt: "/testimonials/alberto-burzio-liftt.webp",
  navily: "/testimonials/edouard-fiess-navily.webp",
  numeraria: "/testimonials/elisa-gnan-numeraria.webp",
  "oggi-lavoro": "/testimonials/francesca-sorrentino-oggi-lavoro.webp",
  rainplan: "/testimonials/amanda-potter-rainplan.webp",
  "stars-be-original": "/testimonials/gabriella-bruzzone-stars.webp",
  "startup-govtech": "/testimonials/govtech-startup.webp",
  storywonder: "/testimonials/rolf-storywonder.webp",
  "talent-match": "/testimonials/guillem-llacuna-talent-match.webp",
};
const stakeholderPhoto = study.data.stakeholder.photo || photoMap[study.id] || null;

const video = study.data.videoTestimonial;
const videoSrc = video
  ? video.provider === "youtube"
    ? `https://www.youtube.com/embed/${video.id}?rel=0&modestbranding=1`
    : `https://player.vimeo.com/video/${video.id}?title=0&byline=0&portrait=0`
  : null;

const title = `${study.data.title} | Case study Soraia`;
const description = study.data.teaser.problem;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: study.data.title,
  description,
  datePublished: study.data.pubDate.toISOString(),
  author: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
  publisher: { "@type": "Organization", name: "Soraia", logo: { "@type": "ImageObject", url: "https://www.soraia.io/logos/soraia-full.svg" } },
  about: study.data.client,
};
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <article>
    <!-- ============================================================
         HERO (JetHR style: logo + big quote + meta + video/photo)
         ============================================================ -->
    <section class="relative bg-white border-b border-line">
      <div class="container-soraia pt-14 md:pt-20 pb-16 md:pb-24">
        <nav class="flex items-center gap-2 text-[13px] mb-10" style="color: var(--color-ink-soft);">
          <a href="/" class="hover:opacity-70 transition-opacity" style="color: var(--color-ink-soft);">Home</a>
          <span>›</span>
          <a href="/case-studies" class="hover:opacity-70 transition-opacity" style="color: var(--color-ink-soft);">Case studies</a>
          <span>›</span>
          <span style="color: var(--color-ink-muted);">{study.data.client}</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-10 lg:gap-16 items-start">
          <div class="min-w-0">
            {study.data.clientLogo && (
              <img
                src={study.data.clientLogo}
                alt={study.data.client}
                class="h-10 md:h-12 w-auto mb-8 grayscale opacity-90"
                loading="eager"
                decoding="async"
              />
            )}

            <h1 class="text-balance" style="font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.12; letter-spacing: -0.025em; font-weight: 500; color: var(--color-ink);">
              &ldquo;{study.data.shortQuote || study.data.heroQuote}&rdquo;
            </h1>

            <div class="mt-10 grid grid-cols-2 gap-x-10 md:gap-x-14 gap-y-5 max-w-md">
              {study.data.dimensioni && (
                <div>
                  <p class="text-[11px] uppercase tracking-[0.15em] font-medium mb-1.5" style="color: var(--color-ink-soft);">Dimensioni</p>
                  <p class="text-[15px] font-semibold" style="color: var(--color-ink);">{study.data.dimensioni}</p>
                </div>
              )}
              <div>
                <p class="text-[11px] uppercase tracking-[0.15em] font-medium mb-1.5" style="color: var(--color-ink-soft);">Settore</p>
                <p class="text-[15px] font-semibold" style="color: var(--color-ink);">{study.data.sector}</p>
              </div>
            </div>

            <div class="mt-14">
              <p class="text-[11px] font-medium tracking-[0.14em] uppercase mb-4" style="color: var(--color-ink-soft);">L'azienda</p>
              <h2 class="mb-5 text-balance" style="font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem); line-height: 1.15; letter-spacing: -0.02em; font-weight: 500; color: var(--color-ink);">
                {study.data.title.replace(/^([^,]+),\s*/, "")}
              </h2>
              <p class="text-[16px] leading-relaxed text-pretty max-w-xl" style="color: var(--color-ink-muted);">
                {study.data.teaser.problem}
              </p>
            </div>

            <!-- INLINE BODY PROSE (lo scroll qui, video sticky a destra) -->
            <div class="prose-soraia mt-16 md:mt-20">
              <Content />
            </div>

            {study.data.screenshots.length > 0 && (
              <div class="mt-12">
                <p class="text-[11px] font-medium tracking-[0.14em] uppercase mb-5" style="color: var(--color-ink-soft);">Screenshot del prodotto</p>
                <div class="screenshots-row" data-lightbox-root>
                  {study.data.screenshots.map((shot, i) => (
                    <figure class="screenshot-item m-0">
                      <button
                        type="button"
                        class="screenshot-frame group overflow-hidden rounded-xl border border-line bg-ink-50 flex items-center justify-center cursor-zoom-in p-0"
                        data-lightbox-trigger
                        data-lightbox-index={i}
                        aria-label={`Apri ${shot.caption || `screenshot ${i + 1}`} in lightbox`}
                      >
                        <img
                          src={shot.src}
                          alt={shot.alt || shot.caption || `Screenshot ${study.data.client}`}
                          loading="lazy"
                          decoding="async"
                          class="max-w-full max-h-full object-contain transition-transform duration-300 group-hover:scale-[1.02]"
                        />
                        <span class="screenshot-zoom-hint" aria-hidden="true">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                        </span>
                      </button>
                      {shot.caption && (
                        <figcaption class="mt-2.5 text-[12.5px] leading-snug text-pretty" style="color: var(--color-ink-soft);">
                          {shot.caption}
                        </figcaption>
                      )}
                    </figure>
                  ))}
                </div>

                <!-- Lightbox dialog (popolato via JS) -->
                <dialog class="screenshot-lightbox" data-lightbox-dialog aria-label="Screenshot gallery">
                  <button type="button" class="lightbox-btn lightbox-close" data-lightbox-close aria-label="Chiudi">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                  {study.data.screenshots.length > 1 && (
                    <>
                      <button type="button" class="lightbox-btn lightbox-prev" data-lightbox-prev aria-label="Precedente">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                      </button>
                      <button type="button" class="lightbox-btn lightbox-next" data-lightbox-next aria-label="Successivo">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                      </button>
                    </>
                  )}
                  <img class="lightbox-img" data-lightbox-img alt="" />
                  <p class="lightbox-caption" data-lightbox-caption></p>
                  <p class="lightbox-counter" data-lightbox-counter></p>
                </dialog>

                <script
                  is:inline
                  define:vars={{
                    items: study.data.screenshots.map((s) => ({
                      src: s.src,
                      alt: s.alt || s.caption || study.data.client,
                      caption: s.caption || "",
                    })),
                  }}
                >
                  (() => {
                    const dialog = document.querySelector("[data-lightbox-dialog]");
                    if (!dialog) return;
                    const imgEl = dialog.querySelector("[data-lightbox-img]");
                    const captionEl = dialog.querySelector("[data-lightbox-caption]");
                    const counterEl = dialog.querySelector("[data-lightbox-counter]");
                    const triggers = document.querySelectorAll("[data-lightbox-trigger]");
                    let current = 0;

                    function render(idx) {
                      current = ((idx % items.length) + items.length) % items.length;
                      imgEl.src = items[current].src;
                      imgEl.alt = items[current].alt;
                      captionEl.textContent = items[current].caption;
                      captionEl.style.display = items[current].caption ? "" : "none";
                      counterEl.textContent = items.length > 1 ? `${current + 1} / ${items.length}` : "";
                    }

                    triggers.forEach((t) => {
                      t.addEventListener("click", () => {
                        render(Number(t.dataset.lightboxIndex || 0));
                        dialog.showModal();
                      });
                    });

                    dialog.querySelector("[data-lightbox-close]")?.addEventListener("click", () => dialog.close());
                    dialog.querySelector("[data-lightbox-prev]")?.addEventListener("click", () => render(current - 1));
                    dialog.querySelector("[data-lightbox-next]")?.addEventListener("click", () => render(current + 1));

                    dialog.addEventListener("click", (e) => {
                      if (e.target === dialog) dialog.close();
                    });

                    document.addEventListener("keydown", (e) => {
                      if (!dialog.open) return;
                      if (e.key === "ArrowLeft") render(current - 1);
                      if (e.key === "ArrowRight") render(current + 1);
                    });
                  })();
                </script>
              </div>
            )}
          </div>

          <!-- RIGHT: Video or Photo (sticky, segue lo scroll del body) -->
          <aside class="lg:sticky lg:top-24 self-start w-full max-w-[440px] mx-auto lg:mx-0 lg:ml-auto">
            {videoSrc ? (
              <div class="case-media aspect-[9/16] rounded-2xl overflow-hidden bg-ink-900 shadow-violet-lg ring-1 ring-violet-100">
                <iframe
                  src={videoSrc}
                  title={`Video testimonial ${study.data.client}`}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="w-full h-full"
                ></iframe>
              </div>
            ) : stakeholderPhoto ? (
              <figure class="case-media relative aspect-[4/5] rounded-2xl overflow-hidden bg-ink-100 shadow-violet-lg ring-1 ring-violet-100">
                <img
                  src={stakeholderPhoto}
                  alt={`${study.data.stakeholder.name}, ${study.data.stakeholder.role}, ${study.data.client}`}
                  loading="eager"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
                <figcaption class="absolute bottom-0 left-0 right-0 p-5 text-white bg-gradient-to-t from-black/70 via-black/35 to-transparent">
                  <p class="text-[14px] font-semibold leading-tight">{study.data.stakeholder.name}</p>
                  <p class="text-[12.5px] opacity-90 mt-0.5">{study.data.stakeholder.role}, {study.data.client}</p>
                </figcaption>
              </figure>
            ) : (
              <div class="case-media aspect-[4/5] rounded-2xl overflow-hidden flex items-center justify-center p-10" style="background: linear-gradient(160deg, var(--color-violet-50, #FDF4FF) 0%, var(--color-violet-200, #E9D5F4) 100%); ring: 1px solid var(--color-violet-100);">
                {study.data.clientLogo && (
                  <img
                    src={study.data.clientLogo}
                    alt={study.data.client}
                    class="max-w-[200px] max-h-[120px] w-auto h-auto opacity-90"
                    loading="eager"
                  />
                )}
              </div>
            )}

          </aside>
        </div>
      </div>
    </section>

    <!-- ============================================================
         RELATED CASE STUDIES (horizontal scroll JetHR-style)
         ============================================================ -->
    {related.length > 0 && (
      <section class="bg-white border-b border-line">
        <div class="container-soraia py-14 md:py-20">
          <div class="max-w-3xl mb-10">
            <p class="eyebrow mb-4">Altri case study</p>
            <h2 class="text-balance" style="font-size: clamp(1.75rem, 2.5vw + 0.5rem, 2.25rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500; color: var(--color-ink);">
              Continua a esplorare.
            </h2>
          </div>
          <CaseStudyCarousel
            items={related.map((r) => ({
              slug: r.id,
              client: r.data.client,
              clientLogo: r.data.clientLogo,
              quote: r.data.shortQuote || (r.data.heroQuote.length > 140 ? r.data.heroQuote.slice(0, 137).trimEnd() + "…" : r.data.heroQuote),
              dimensioni: r.data.dimensioni,
              sector: r.data.sector,
              cardImage: r.data.cardImage || ({
                "40factory": "/testimonials/margherita-chifari-40factory.webp",
                aegis: "/testimonials/aegis_vittorio_maiani.webp",
                apraise: "/testimonials/jacopo-castano-apraise.webp",
                cxl: "/testimonials/brian-dandelet-cxl.webp",
                frh: "/testimonials/fabricio-carminati-frh.webp",
                liftt: "/testimonials/alberto-burzio-liftt.webp",
                navily: "/testimonials/edouard-fiess-navily.webp",
                numeraria: "/testimonials/elisa-gnan-numeraria.webp",
                "oggi-lavoro": "/testimonials/francesca-sorrentino-oggi-lavoro.webp",
                rainplan: "/testimonials/amanda-potter-rainplan.webp",
                "stars-be-original": "/testimonials/gabriella-bruzzone-stars.webp",
                "startup-govtech": "/testimonials/govtech-startup.webp",
                storywonder: "/testimonials/rolf-storywonder.webp",
                "talent-match": "/testimonials/guillem-llacuna-talent-match.webp",
              } as Record<string, string>)[r.id],
            }))}
          />
        </div>
      </section>
    )}

    <!-- ============================================================
         CTA FINALE
         ============================================================ -->
    <CTABanner
      title="Hai un caso simile?"
      description="20 minuti col CEO per capire insieme se ha senso. Nessun impegno, nessun preventivo a sorpresa: solo una conversazione operativa sui tuoi processi."
      ctaText="20 min con Daniel"
      ctaHref="/parliamone"
      avatarName="Daniel Levis"
      avatarRole="Co-Founder & CEO"
      avatarSrc="/team/daniel-levis.png"
    />
  </article>
</Layout>

<style is:global>
  .prose-soraia {
    color: var(--color-ink);
    font-size: 17px;
    line-height: 1.75;
  }
  .prose-soraia > * + * { margin-top: 1.25em; }
  .prose-soraia h2 {
    font-size: clamp(1.5rem, 2vw + 0.5rem, 1.875rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 500;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--color-ink);
  }
  .prose-soraia h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-weight: 500;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-ink);
  }
  .prose-soraia p { color: var(--color-ink); }
  .prose-soraia strong { font-weight: 600; color: var(--color-ink); }
  .prose-soraia a {
    color: var(--color-brand);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose-soraia a:hover { opacity: 0.7; }
  .prose-soraia ul, .prose-soraia ol {
    padding-left: 1.4em;
    color: var(--color-ink);
  }
  .prose-soraia ul { list-style: disc; }
  .prose-soraia ol { list-style: decimal; }
  .prose-soraia li { margin: 0.4em 0; }
  .prose-soraia li::marker { color: var(--color-ink-soft); }
  .prose-soraia hr {
    border: none;
    border-top: 1px solid var(--color-line);
    margin-block: 2.5em;
  }

  /* Screenshots: horizontal scrollable row */
  .screenshots-row {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 78%;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    padding-bottom: 0.5rem;
    margin: 0 -1rem;
    padding: 0 1rem 0.5rem;
  }
  @media (min-width: 640px) {
    .screenshots-row { grid-auto-columns: 55%; gap: 1.25rem; }
  }
  @media (min-width: 1024px) {
    .screenshots-row { grid-auto-columns: 45%; gap: 1.5rem; }
  }
  .screenshot-item {
    scroll-snap-align: start;
    min-width: 0;
  }
  .screenshot-frame {
    aspect-ratio: 4 / 3;
    width: 100%;
    position: relative;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .screenshot-frame:hover,
  .screenshot-frame:focus-visible {
    border-color: var(--color-brand, #4A1E5C);
    box-shadow: 0 8px 28px -10px rgba(74, 30, 92, 0.25);
  }
  .screenshot-zoom-hint {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: rgba(10, 10, 10, 0.7);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    backdrop-filter: blur(4px);
  }
  .screenshot-frame:hover .screenshot-zoom-hint,
  .screenshot-frame:focus-visible .screenshot-zoom-hint {
    opacity: 1;
    transform: translateY(0);
  }

  /* === LIGHTBOX === */
  .screenshot-lightbox {
    padding: 0;
    border: 0;
    margin: 0;
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    background: transparent;
    overflow: hidden;
  }
  .screenshot-lightbox::backdrop {
    background: rgba(10, 10, 11, 0.92);
    backdrop-filter: blur(8px);
  }
  .screenshot-lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    inset: 0;
  }
  .lightbox-img {
    max-width: min(92vw, 1400px);
    max-height: 82vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 10px;
    box-shadow: 0 24px 60px -16px rgba(0, 0, 0, 0.5);
  }
  .lightbox-caption {
    position: absolute;
    bottom: 64px;
    left: 50%;
    transform: translateX(-50%);
    color: #fff;
    font-size: 13.5px;
    line-height: 1.4;
    max-width: 80vw;
    text-align: center;
    padding: 8px 16px;
    background: rgba(10, 10, 11, 0.7);
    border-radius: 999px;
    margin: 0;
    pointer-events: none;
  }
  .lightbox-counter {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
    pointer-events: none;
  }
  .lightbox-btn {
    position: absolute;
    width: 48px;
    height: 48px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
    backdrop-filter: blur(10px);
    z-index: 2;
  }
  .lightbox-btn:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.32);
    transform: translateY(-1px);
  }
  .lightbox-close { top: 24px; right: 24px; }
  .lightbox-prev { left: 24px; top: 50%; transform: translateY(-50%); }
  .lightbox-next { right: 24px; top: 50%; transform: translateY(-50%); }
  .lightbox-prev:hover { transform: translateY(-50%) translateX(-2px); }
  .lightbox-next:hover { transform: translateY(-50%) translateX(2px); }
  @media (max-width: 640px) {
    .lightbox-btn { width: 40px; height: 40px; }
    .lightbox-close { top: 14px; right: 14px; }
    .lightbox-prev { left: 10px; }
    .lightbox-next { right: 10px; }
    .lightbox-caption { bottom: 56px; font-size: 12.5px; }
  }
</style>
