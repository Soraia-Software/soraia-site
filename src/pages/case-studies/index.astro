---
import Layout from "~/layouts/Layout.astro";
import { getCollection } from "astro:content";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";

const title = "Case Studies | Soraia";
const description = "Agenti IA in produzione per PMI italiane ed europee. Recruitment, consumer mobile, finance, climate, public sector: cosa abbiamo costruito e quali risultati.";

const cases = (await getCollection("caseStudies")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const photoMap: Record<string, string> = {
  aegis: "/testimonials/aegis_vittorio_maiani.png",
  apraise: "/testimonials/jacopo-castano-apraise.png",
  cxl: "/testimonials/brian-dandelet-cxl.png",
  frh: "/testimonials/fabricio-carminati-frh.png",
  liftt: "/testimonials/alberto-burzio-liftt.png",
  navily: "/testimonials/edouard-fiess-navily.png",
  numeraria: "/testimonials/elisa-gnan-numeraria.png",
  "oggi-lavoro": "/testimonials/francesca-sorrentino-oggi-lavoro.png",
  rainplan: "/testimonials/amanda-potter-rainplan.png",
  "stars-be-original": "/testimonials/gabriella-bruzzone-stars.png",
  storywonder: "/testimonials/rolf-storywonder.png",
  "talent-match": "/testimonials/guillem-llacuna-talent-match.webp",
};

function cardQuote(c: typeof cases[number]): string {
  const q = c.data.shortQuote || c.data.heroQuote;
  return q.length > 140 ? q.slice(0, 137).trimEnd() + "…" : q;
}

// Industry filter taxonomy
const industryFilters = [
  { id: "all",                 label: "Tutti",                    count: cases.length },
  { id: "recruitment-hr",      label: "Recruitment & HR",         count: cases.filter((c) => c.data.industry === "recruitment-hr").length },
  { id: "consumer-education",  label: "Consumer & Education",     count: cases.filter((c) => c.data.industry === "consumer-education").length },
  { id: "finance-vc",          label: "Finance & VC",             count: cases.filter((c) => c.data.industry === "finance-vc").length },
  { id: "sustainability",      label: "Sustainability",           count: cases.filter((c) => c.data.industry === "sustainability").length },
  { id: "public-sector",       label: "Public Sector",            count: cases.filter((c) => c.data.industry === "public-sector").length },
];
---

<Layout title={title} description={description} lang="it">

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-line" style="background: #FAFAF8;">
    <div class="container-soraia pt-20 md:pt-28 pb-16 md:pb-20">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
        Case studies
      </p>
      <h1 class="text-balance max-w-3xl" style="font-size: clamp(2.25rem, 5vw + 1rem, 4rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;">
        Agenti IA in produzione. Numeri reali.
      </h1>
      <p class="mt-6 text-[18px] md:text-[19px] leading-relaxed max-w-2xl text-pretty" style="color: var(--color-ink-muted);">
        Quali processi abbiamo automatizzato per PMI italiane ed europee, cosa abbiamo costruito, quali risultati. Niente vanity metrics, solo agenti in produzione che gestiscono lavoro vero.
      </p>
    </div>
  </section>

  <!-- FILTER BAR + GRID -->
  <section class="bg-white" style="padding-bottom: 5rem;">
    <div class="container-soraia">

      <!-- Filter pills -->
      <div class="flex flex-wrap items-center gap-2 mt-12 mb-10" data-filter-bar>
        {industryFilters.map((f, i) => (
          <button
            type="button"
            class={`cs-filter ${i === 0 ? "is-active" : ""}`}
            data-filter={f.id}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            <span>{f.label}</span>
            <span class="cs-filter-count">{f.count}</span>
          </button>
        ))}
      </div>

      <!-- Case study grid (JetHR-style cards, JS filters via data attr) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6" data-case-grid>
        {cases.map((c) => (
          <div class="cs-grid-item" data-industry={c.data.industry}>
            <CaseStudyCardJet
              href={`/case-studies/${c.id}`}
              client={c.data.client}
              clientLogo={c.data.clientLogo}
              quote={cardQuote(c)}
              dimensioni={c.data.dimensioni}
              sector={c.data.sector}
              cardImage={c.data.cardImage || photoMap[c.id]}
            />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div class="hidden text-center py-12" data-empty-state>
        <p class="text-[15px]" style="color: var(--color-ink-muted);">Nessun case study per questa industry. Prova un altro filtro o <a href="/parliamone" style="color: var(--color-brand); text-decoration: underline;">parla con noi</a> del tuo settore.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
        Hai un caso simile?
      </p>
      <h2 class="text-balance" style="font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Capiamo insieme se ha senso lavorare.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed" style="color: var(--color-ink-muted);">
        20 minuti col CEO. Senza pitch, senza preventivi a sorpresa. Solo una conversazione operativa sui tuoi processi.
      </p>
      <div class="mt-9">
        <a href="/parliamone" class="btn btn-primary">
          20 min con Daniel
          <span class="btn-arrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const bar = document.querySelector("[data-filter-bar]");
      const grid = document.querySelector("[data-case-grid]");
      const emptyState = document.querySelector("[data-empty-state]");
      if (!bar || !grid) return;

      const cards = grid.querySelectorAll(".cs-grid-item");
      const buttons = bar.querySelectorAll(".cs-filter");

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const filter = btn.dataset.filter;

          buttons.forEach((b) => {
            const active = b === btn;
            b.classList.toggle("is-active", active);
            b.setAttribute("aria-pressed", active ? "true" : "false");
          });

          let visibleCount = 0;
          cards.forEach((card) => {
            const match = filter === "all" || card.dataset.industry === filter;
            card.style.display = match ? "" : "none";
            if (match) visibleCount++;
          });

          emptyState.classList.toggle("hidden", visibleCount > 0);
        });
      });
    })();
  </script>

  <style is:global>
    /* === Filter pills === */
    .cs-filter {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.55rem 1rem;
      border-radius: 9999px;
      border: 1px solid var(--color-line-strong);
      background: white;
      font-family: inherit;
      font-size: 13px;
      font-weight: 500;
      color: var(--color-ink);
      cursor: pointer;
      transition: border-color 180ms ease, background 180ms ease, color 180ms ease;
    }
    .cs-filter:hover {
      border-color: var(--color-brand);
      color: var(--color-brand);
    }
    .cs-filter.is-active {
      background: var(--color-brand);
      border-color: var(--color-brand);
      color: white;
    }
    .cs-filter-count {
      font-size: 11px;
      font-weight: 500;
      padding: 1px 6px;
      border-radius: 9999px;
      background: var(--color-ink-50);
      color: var(--color-ink-soft);
      min-width: 18px;
      text-align: center;
    }
    .cs-filter.is-active .cs-filter-count {
      background: rgba(255, 255, 255, 0.18);
      color: rgba(255, 255, 255, 0.95);
    }
    .cs-filter:hover:not(.is-active) .cs-filter-count {
      background: var(--color-brand-soft);
      color: var(--color-brand);
    }

    /* === Case card === */
    .cs-card {
      background: white;
      border: 1px solid var(--color-line-strong);
      border-radius: 1rem;
      overflow: hidden;
      transition: border-color 220ms ease, transform 220ms ease, box-shadow 220ms ease;
    }
    .cs-card:hover {
      border-color: var(--color-brand);
      transform: translateY(-3px);
      box-shadow: 0 12px 28px -12px rgba(74, 30, 92, 0.16);
    }

    /* Logo band */
    .cs-card-logo {
      background: var(--color-ink-50);
      border-bottom: 1px solid var(--color-line);
      height: 110px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 2rem;
    }
    .cs-card-logo img {
      max-width: 70%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
      filter: grayscale(100%) brightness(0.65) contrast(1.05);
      opacity: 0.85;
      transition: filter 0.3s ease, opacity 0.3s ease, transform 0.3s ease;
      mix-blend-mode: multiply;
    }
    .cs-card:hover .cs-card-logo img {
      filter: grayscale(0%) brightness(1);
      opacity: 1;
    }
    .cs-card-logo-fallback {
      font-size: 1.5rem;
      font-weight: 500;
      letter-spacing: -0.02em;
      color: var(--color-ink);
      opacity: 0.7;
    }

    /* Body */
    .cs-card-body {
      padding: 1.5rem 1.75rem 1.75rem;
      display: flex;
      flex-direction: column;
      flex: 1;
    }
    .cs-card-eyebrow {
      font-size: 10.5px;
      font-weight: 500;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--color-ink-soft);
      margin-bottom: 0.85rem;
      line-height: 1.4;
    }
    .cs-card-title {
      font-size: 1.25rem;
      line-height: 1.2;
      letter-spacing: -0.018em;
      font-weight: 500;
      color: var(--color-ink);
      margin-bottom: 0.7rem;
    }
    .cs-card-desc {
      font-size: 13.5px;
      line-height: 1.55;
      color: var(--color-ink-muted);
      margin-bottom: 1.25rem;
      flex: 1;
    }
    .cs-card-result {
      padding-top: 1rem;
      border-top: 1px solid var(--color-line);
      margin-bottom: 1.15rem;
    }
    .cs-card-result-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ink-soft);
      margin-bottom: 0.4rem;
    }
    .cs-card-result-metric {
      font-size: 14px;
      font-weight: 500;
      line-height: 1.4;
      color: var(--color-brand);
      letter-spacing: -0.005em;
    }
    .cs-card-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 13px;
      font-weight: 500;
      color: var(--color-brand);
    }
    .cs-card-arrow {
      transition: transform 0.22s ease;
    }
    .cs-card:hover .cs-card-arrow {
      transform: translateX(3px);
    }
  </style>
</Layout>
