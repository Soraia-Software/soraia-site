---
import Layout from "~/layouts/Layout.astro";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import HeroVisual from "~/components/HeroVisual.astro";

const title = "AI Agents for Customer Support and Operations | Soraia";
const description =
  "Instant triage, on-brand draft replies, context-rich escalation, sentiment monitoring. AI agents that handle the full ticket funnel end-to-end. -70% operational time. Live in 4 weeks.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Agents for Customer Support. Soraia",
    provider: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
    areaServed: "IT",
    serviceType: "AI agents for customer support teams",
    offers: { "@type": "Offer", priceCurrency: "EUR", price: "2000", description: "Initial assessment €2,000, refunded if you proceed with the sprint." },
  },
];

const problems = [
  {
    title: "Manual triage that doesn't scale",
    description: "Tickets coming in from email, chat, social, forms. Someone has to classify priority, assign to the right team, gauge urgency. At high volume, triage becomes the real bottleneck.",
  },
  {
    title: "Inconsistent brand voice",
    description: "Replies written by different team members, at different times, in different styles. Customers perceive a fragmented brand. Guidelines aren't enough, you need an agent that always applies them.",
  },
  {
    title: "Slow escalations with no context",
    description: "When a case reaches senior support, context gets lost in the thread. The senior re-reads everything from scratch, wastes time, the customer waits. SLA burned.",
  },
];

const processes = [
  {
    number: "01",
    title: "Automated multi-channel triage",
    description: "The agent reads every incoming ticket (email, chat, social, form), classifies by priority and type, and automatically assigns it to the right team. No more unsorted queues.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "On-brand draft replies",
    description: "For every ticket the agent prepares a draft reply in your defined brand voice. The agent never tires, never has an off day, and applies the same criteria to the first ticket as to the thousandth.",
    icon: "transcript" as const,
  },
  {
    number: "03",
    title: "Intelligent routing",
    description: "Tickets routed to the right specialist team (tech, billing, retention) with full context. Skill-based routing, no more ping-pong between colleagues.",
    icon: "outreach" as const,
  },
  {
    number: "04",
    title: "Escalation with full context",
    description: "When a case requires senior support, the agent prepares a brief: customer history, current conversation, attempted solutions, recommendations. The senior replies in 5 minutes, not 30.",
    icon: "match" as const,
  },
  {
    number: "05",
    title: "SLA tracking + real-time sentiment",
    description: "Per-ticket customer sentiment monitoring, alerts on negative responses, SLA tracking by team. Management spots problems before they escalate.",
    icon: "calendar" as const,
  },
  {
    number: "06",
    title: "Performance reports + insights",
    description: "First response time, resolution time, predicted CSAT, top issue categories. Executive dashboard updated in real time, no more weekly exports.",
    icon: "compass" as const,
  },
];

const cases = [
  {
    slug: "navily",
    client: "Navily",
    quote: "AI moderates reviews, images and enriches data: -70% operational time, high accuracy. The team gets back to the product, not manual triage.",
    dimensioni: "11-50",
    sector: "Consumer mobile · Travel & nautical",
    cardImage: "/testimonials/edouard-fiess-navily.webp",
    stakeholder: { name: "Edouard Fiess", role: "CEO & Co-Founder" },
  },
];

const comparisonRows = [
  { label: "Cost", values: ["Per seat", "Per ticket", "One-time + maintenance"] as [string, string, string] },
  { label: "Time to value", values: ["Immediate", "Long setup", "4 weeks"] as [string, string, string] },
  { label: "Brand voice", values: ["Limited", "Configurable", "Trained on yours"] as [string, string, string] },
  { label: "Multi-channel", values: ["Limited", "Yes", "Yes, custom integration"] as [string, string, string] },
  { label: "Vendor dependency", values: ["None", "Total", "None (your code)"] as [string, string, string] },
  { label: "Sentiment + analytics", values: ["No", "Basic", "Custom executive dashboard"] as [string, string, string] },
];

const faqs = [
  {
    q: "How do you handle GDPR and customer personal data?",
    a: "European or on-premise infrastructure on your own servers. <strong>No training on your data</strong>. Every agent decision is logged, retention is configurable, audit-ready.",
  },
  {
    q: "Does it integrate with my helpdesk (Zendesk, Intercom, Freshdesk, custom)?",
    a: "Yes. We work via API or webhook with all major helpdesks. If you have a custom solution or legacy system we validate it during the assessment.",
  },
  {
    q: "Can the agent reply autonomously or does a human always need to be involved?",
    a: "Configurable per ticket category. For routine cases (standard info, status checks) it can reply autonomously with a confidence threshold. For sensitive or borderline cases it passes to the team with full context. <strong>You decide where to draw the line</strong>.",
  },
  {
    q: "How do you train the brand voice?",
    a: "We analyse a sample of your best historical replies. The tone of voice emerges from your data, not abstract guidelines. We validate it with you before going to production.",
  },
  {
    q: "What does it actually cost?",
    a: "Assessment <strong>€2,000</strong> (refunded). Sprint <strong>€10–50k</strong>. Guarantee: if the agent doesn\'t cut triage time as promised, we work for free until it does.",
  },
];
---

<Layout title={title} description={description} lang="en" jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div style="color: #fff;">
          <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            Customer Support · AI Agents
          </p>
          <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
            Instant triage.<br/>On-brand replies.
          </h1>
          <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
            AI agents that classify, draft, route, and escalate. -70% operational time on triage, full-context escalation, real-time sentiment monitoring. Live in 4 weeks.
          </p>
          <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-[14px] font-medium" style="color: #F4B842;">If it doesn't work, you don't pay. Guarantee included.</span>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="/en/contact" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
              Request assessment, €2,000
              <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
            </a>
            <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">See the Navily case study</a>
          </div>
          <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">-70%</strong> triage operational time</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Multi-channel</strong> native</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">GDPR + audit log</strong> included</span></div>
          </div>
        </div>
        <div class="hidden lg:flex justify-end fade-up fade-up-delay-3">
          <HeroVisual filter="support" lang="en" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-14 border-y border-ink-200 bg-white">
    <div class="container-soraia text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 mb-4">Already chosen by consumer mobile and B2B SaaS</p>
      <p class="text-[16px]" style="color: var(--color-ink-muted);">
        <a href="/en/case-studies/navily" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">Navily</a>
        · Europe's leading app for tourist marinas · active client with continuous scaling
      </p>
    </div>
  </section>

  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The problem"
        title="Triage costs more than the solution."
        subtitle="Anyone managing serious ticket volumes knows the real cost isn't resolving issues, it's classifying, prioritising, routing them, and keeping the brand voice consistent. Hours of skilled human work burned on repetitive tasks."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The solution"
        title="6 AI agents covering the full ticket funnel end-to-end."
        subtitle="Triage, drafting, routing, escalation, tracking, analytics. Digital workers that apply the same criteria to the first ticket as to the thousandth of the day."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (<ProcessCard {...p} />))}
      </div>
    </div>
  </section>

  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Our guarantee
        </p>
        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          -70% operational time on triage.<br/><span style="color: rgba(255,255,255,0.45);">Measured in 4 weeks. Or you don't pay.</span>
        </h2>
        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          Baseline measured during assessment against your real tickets. If the agent doesn't recover the promised time for your team, we work for free until it does, or we refund the sprint.
        </p>
      </div>
    </div>
  </section>

  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader eyebrow="Case study" title="Multi-task AI agent in action at Navily." align="center" />
      <div class="max-w-md mx-auto">
        <CaseStudyCardJet lang="en" href={`/en/case-studies/${cases[0].slug}`} client={cases[0].client} quote={cases[0].quote} dimensioni={cases[0].dimensioni} sector={cases[0].sector} cardImage={cases[0].cardImage} />
        <p class="mt-6 text-center text-[14px]" style="color: var(--color-ink-soft);">
          <strong style="color: var(--color-ink); font-weight: 500;">{cases[0].stakeholder.name}</strong>, {cases[0].stakeholder.role} · {cases[0].client}
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Comparison"
        title="Why custom AI agents, and not the alternatives."
        subtitle="The three real options for a customer support team today."
        align="center"
      />
      <ComparisonTable columns={["Standard SaaS helpdesk", "Helpdesk AI add-on", "Soraia AI agents"]} rows={comparisonRows} highlightCol={2} />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-soraia max-w-3xl">
      <SectionHeader eyebrow="Questions" title="What people usually ask us." align="center" />
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 reveal" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Next step
      </p>
      <h2 class="text-balance reveal" style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Find out how much time your support team can get back.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed reveal reveal-delay-1" style="color: var(--color-ink-muted);">
        Assessment €2,000, refunded if you proceed. 1–2 weeks from kick-off to report.
      </p>
      <div class="mt-10 reveal reveal-delay-2">
        <a href="/en/contact" class="btn btn-primary">
          Request assessment
          <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
