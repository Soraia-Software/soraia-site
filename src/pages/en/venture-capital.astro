---
import Layout from "~/layouts/Layout.astro";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import HeroVisual from "~/components/HeroVisual.astro";

const title = "AI Agents for VC Funds and Family Offices | Soraia";
const description =
  "Deal flow managed autonomously. The agent monitors emails, archives with metadata, deduplicates deals, and generates the monthly report. The team gets back to doing deals. Live in 4 weeks.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Agents for Venture Capital. Soraia",
    provider: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
    areaServed: "IT",
    serviceType: "AI agents for venture capital and family office",
    offers: { "@type": "Offer", priceCurrency: "EUR", price: "2000", description: "Initial assessment €2,000, refunded if you proceed with the sprint." },
  },
];

const problems = [
  {
    title: "Pipeline fragmented across a dozen systems",
    description: "CRM, Outlook email, OneDrive, shared spreadsheets. The same founder lives in 4 different records. Figuring out 'where are we with X' takes 20 minutes of context-switching.",
  },
  {
    title: "Emails not archived for due diligence",
    description: "When you need to reconstruct the history of a deal, the key conversations are buried in some Outlook thread nobody can find. Compliance issue.",
  },
  {
    title: "Monthly report built by hand",
    description: "Every start of the month, hours of qualified work to produce pipeline numbers, conversion rates, activity summaries. By the time the report is ready, it's already stale.",
  },
];

const processes = [
  {
    number: "01",
    title: "Deal-related email monitoring",
    description: "The agent reads the deal team's mailboxes and automatically recognises what is deal-related versus spam, newsletters, and internal communications.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "Compliant email + attachment archiving",
    description: "Eml + pitch deck + term sheet archived on OneDrive/SharePoint with structured metadata (deal name, founder, date, attachment type). Ready for due diligence.",
    icon: "transcript" as const,
  },
  {
    number: "03",
    title: "Cross-source deal deduplication",
    description: "The agent recognises that \"Mario Rossi - Startup A\" and \"M. Rossi (CEO StartupA)\" are the same record. It proposes the merge; a human approves with one click.",
    icon: "match" as const,
  },
  {
    number: "04",
    title: "Multi-criteria deal scoring",
    description: "For every new deal in the pipeline, the agent cross-references Crunchbase, PitchBook, and founders' LinkedIn profiles, and produces a justified score for the deal team.",
    icon: "compass" as const,
  },
  {
    number: "05",
    title: "Auto-generated monthly report",
    description: "Auto-updated charts at the start of each month: pipeline by stage, conversion rate, activity by deal team member, alerts on stagnant deals. No more manual Excel exports.",
    icon: "outreach" as const,
  },
  {
    number: "06",
    title: "Portfolio monitoring + alerts",
    description: "For portfolio companies, the agent tracks KPIs reported by founders, alerts on deviations, and sets calendar reminders for periodic check-ins. Nothing slips through the cracks.",
    icon: "calendar" as const,
  },
];

const cases = [
  {
    slug: "liftt",
    client: "LIFTT",
    quote: "The AI agent autonomously handles archiving, deduplication, and reporting for our deal flow. We are back to doing deals.",
    dimensioni: "11-50",
    sector: "Venture Capital · Tech transfer",
    cardImage: "/testimonials/alberto-burzio-liftt.webp",
    stakeholder: { name: "Alberto Burzio", role: "IT Manager" },
  },
];

const comparisonRows = [
  { label: "Cost", values: ["Low", "High annual", "Medium one-off"] as [string, string, string] },
  { label: "Time to go live", values: ["Immediate", "3–6 months", "4 weeks"] as [string, string, string] },
  { label: "Executes tasks autonomously", values: ["No", "Limited", "Yes, end-to-end"] as [string, string, string] },
  { label: "Custom to your deal flow", values: ["No", "Configurable", "Built for you"] as [string, string, string] },
  { label: "Vendor dependency", values: ["None", "Total", "None (your code)"] as [string, string, string] },
  { label: "Email archive compliance", values: ["No", "Partial", "Yes, audit-ready"] as [string, string, string] },
];

const faqs = [
  {
    q: "How do you handle GDPR and confidential deal data?",
    a: "European or on-premise infrastructure on your own stack. <strong>No training on your data</strong>. Full logs, configurable retention. Already in use on deal flows of regulated Italian funds.",
  },
  {
    q: "Does it integrate with Affinity, Salesforce, Attio, or a custom CRM?",
    a: "Yes. We work via API or programmatic export. If you have a custom CRM or Airtable, we assess it during the assessment phase.",
  },
  {
    q: "How does email archiving for due diligence work?",
    a: "Eml + attachments on OneDrive/SharePoint with structured metadata (deal, founder, date, type). When you need to reconstruct a deal's history, two clicks find everything. Compliance-ready.",
  },
  {
    q: "What about portfolio monitoring?",
    a: "The agent tracks the KPIs founders send you (monthly, quarterly), structures them, alerts on deviations, and sets calendar reminders for check-ins. <strong>Zero KPIs lost in your inbox</strong>.",
  },
  {
    q: "What does it actually cost?",
    a: "Assessment <strong>€2,000</strong> (refunded if you proceed). Sprint <strong>€10–50k</strong>. Guarantee: if the agent does not recover the hours promised to the deal team, we work for free until it does.",
  },
];
---

<Layout title={title} description={description} lang="en" jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div style="color: #fff;">
          <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            Finance Ops · Venture Capital
          </p>
          <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
            Deal flow run by AI agents.<br/>You focus on deals.
          </h1>
          <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
            The agent monitors emails, archives with metadata, deduplicates deals, multi-criteria scoring, auto-generated monthly report. Compliant, zero operations overhead. Live in 4 weeks.
          </p>
          <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-[14px] font-medium" style="color: #F4B842;">If it doesn't work, you don't pay. Guarantee included.</span>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="/en/contact" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
              Request assessment, €2,000
              <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
            </a>
            <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">See the LIFTT case study</a>
          </div>
          <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">100%</strong> emails archived</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">0 hours</strong> of manual deduplication</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Monthly report</strong> auto-generated</span></div>
          </div>
        </div>
        <div class="hidden lg:flex justify-end fade-up fade-up-delay-3">
          <HeroVisual filter="vc" lang="en" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-14 border-y border-ink-200 bg-white">
    <div class="container-soraia text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 mb-4">Already chosen by Italian funds</p>
      <p class="text-[16px]" style="color: var(--color-ink-muted);">
        <a href="/en/case-studies/liftt" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">LIFTT</a>
        · Deep tech Venture Capital holding · active client
      </p>
      <p class="mt-5 text-[13px]" style="color: var(--color-ink-soft);">
        Are you a non-VC finance team (accountants, CFO, M&A operations)?
        <a href="/en/finance" class="inline-flex items-center gap-1 ml-1 font-semibold text-violet-700 hover:gap-1.5 transition-all">
          Go to the Finance Ops page
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </p>
    </div>
  </section>

  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The problem"
        title="Deal flow has grown faster than the processes that manage it."
        subtitle="A dozen systems, a thousand email threads, countless files on OneDrive. The senior team spends more time hunting for data than doing deals."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The solution"
        title="6 AI agents that form the backbone of your deal flow."
        subtitle="Monitoring, archiving, deduplication, scoring, reporting, portfolio tracking. End-to-end digital workers. The team steps in only for decisions that require judgement."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (<ProcessCard {...p} />))}
      </div>
    </div>
  </section>

  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Our guarantee
        </p>
        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          Autonomous deal flow backbone.<br/><span style="color: rgba(255,255,255,0.45);">Measured in 4 weeks. Or you don't pay.</span>
        </h2>
        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          Baseline measured during the assessment (hours/person/week on monitoring + deduplication + reporting). If the agent does not recover the promised hours, we work for free until it does — or we refund the sprint.
        </p>
      </div>
    </div>
  </section>

  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader eyebrow="Case study" title="AI agents in action at LIFTT." align="center" />
      <div class="max-w-md mx-auto">
        <CaseStudyCardJet lang="en" href={`/en/case-studies/${cases[0].slug}`} client={cases[0].client} quote={cases[0].quote} dimensioni={cases[0].dimensioni} sector={cases[0].sector} cardImage={cases[0].cardImage} />
        <p class="mt-6 text-center text-[14px]" style="color: var(--color-ink-soft);">
          <strong style="color: var(--color-ink); font-weight: 500;">{cases[0].stakeholder.name}</strong>, {cases[0].stakeholder.role} · {cases[0].client}
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Comparison"
        title="Why custom AI agents, and not something else."
        subtitle="The three real options for a VC fund or family office today."
        align="center"
      />
      <ComparisonTable columns={["ChatGPT / Copilot", "Affinity / Attio AI", "Soraia AI agents"]} rows={comparisonRows} highlightCol={2} />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-soraia max-w-3xl">
      <SectionHeader eyebrow="Questions" title="What people usually ask us." align="center" />
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 reveal" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Next step
      </p>
      <h2 class="text-balance reveal" style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Find out how many hours your deal team can get back.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed reveal reveal-delay-1" style="color: var(--color-ink-muted);">
        Assessment €2,000, refunded if you proceed. 1–2 weeks from kick-off to report.
      </p>
      <div class="mt-10 reveal reveal-delay-2">
        <a href="/en/contact" class="btn btn-primary">
          Request assessment
          <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
