---
import Layout from "~/layouts/Layout.astro";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import HeroVisual from "~/components/HeroVisual.astro";

const title = "AI Agents for Sales & Marketing Operations | Soraia";
const description =
  "Leads enriched, qualified, contacted. All automatically. The agent does cross-source enrichment, qualifies intent, sends personalised outreach. Sales only closes warm leads. Live in 4 weeks.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Agents for Sales & Marketing. Soraia",
    provider: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
    areaServed: "IT",
    serviceType: "AI agents for sales and marketing operations",
    offers: { "@type": "Offer", priceCurrency: "EUR", price: "2000", description: "Initial assessment €2,000, refunded if you proceed with the sprint." },
  },
];

const problems = [
  {
    title: "Minimal leads that eat hours",
    description: "Form downloads, eBooks, webinars: you get an email and a name. Profiling each lead takes 20–30 minutes of research on LinkedIn, public searches, and company signals. It doesn't scale.",
  },
  {
    title: "Pipeline fragmented across tools",
    description: "Apollo for outreach, HubSpot for CRM, Excel sheets for shortlists, LinkedIn for direct messages. No system talks to the others. Data living in silos.",
  },
  {
    title: "'Personalised' outreach that isn't",
    description: "Sequences that only swap out {{firstName}}. Reply rates have collapsed. Without real personalisation — role, company, recent signal — you get no replies and no pipeline.",
  },
];

const processes = [
  {
    number: "01",
    title: "Prospect identification (ICP match)",
    description: "The agent scans public sources and databases, identifying companies and profiles that match your ICP (industry, size, hiring/funding/expansion signals). No more buying contact lists.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "Cross-source enrichment",
    description: "For every lead: role, company, industry, tech stack, recent intent signals. From LinkedIn, company registries, public growth data, news mentions. Complete profile in seconds.",
    icon: "match" as const,
  },
  {
    number: "03",
    title: "Dynamic qualification (BANT, MEDDIC, custom)",
    description: "The agent applies your qualification framework to the collected data. Scored with reasoning, hot/warm/cold tiers, match rationale. Sales only receives leads ready for a conversation.",
    icon: "compass" as const,
  },
  {
    number: "04",
    title: "Personalised multi-channel outreach",
    description: "Email + LinkedIn sequences + (optional) call tasks, with genuinely contextual messages: role, company, recent signal, relevant link. Reply rates multiply compared to templated sequences.",
    icon: "outreach" as const,
  },
  {
    number: "05",
    title: "Engagement tracking + auto follow-up",
    description: "Opens, clicks, replies, meetings booked: tracked per lead. The agent auto-adapts follow-up based on signals. Hot lead? Sales gets a notification with full context. Cold lead? Automatic nurturing.",
    icon: "calendar" as const,
  },
  {
    number: "06",
    title: "Pipeline analytics + attribution",
    description: "Real-time dashboard: pipeline by stage, conversion rate, cost per opportunity, attribution to sourcing channels. No more monthly Excel exports for management.",
    icon: "transcript" as const,
  },
];

const cases = [
  {
    slug: "iltec",
    client: "ILTEC",
    clientLogo: "/logos/clients/iltec.webp",
    quote: "Site rebuilt from scratch in 3 weeks, optimised for ChatGPT and Perplexity. QR on every machine that activates an AI agent: technical and commercial support 24/7.",
    dimensioni: "1-10",
    sector: "B2B office technology · Biellese",
    cardImage: "/testimonials/iltec.webp",
    stakeholder: { name: "ILTEC commercial team", role: "Sales and support" },
  },
];

const comparisonRows = [
  { label: "Cost", values: ["High per seat", "High per seat", "One-time + maintenance"] as [string, string, string] },
  { label: "Real personalisation", values: ["Templates", "Advanced templates", "Contextual per lead"] as [string, string, string] },
  { label: "Enrichment included", values: ["Separate add-on", "Limited", "From 25+ sources, included"] as [string, string, string] },
  { label: "Custom qualification framework", values: ["No", "Basic BANT", "BANT/MEDDIC/yours"] as [string, string, string] },
  { label: "Vendor dependency", values: ["Total", "Total", "None (your code)"] as [string, string, string] },
  { label: "Attribution analytics", values: ["Basic", "Yes", "Custom dashboard"] as [string, string, string] },
];

const faqs = [
  {
    q: "How do you handle GDPR and lead personal data?",
    a: "European infrastructure, complete agent decision logs, configurable retention, one-click opt-out and right to erasure. <strong>No training on your data</strong>.",
  },
  {
    q: "Does it integrate with HubSpot, Salesforce, Pipedrive, custom CRMs?",
    a: "Yes, native integration with the most popular CRMs. For custom CRMs we use APIs/webhooks or Zapier/Make middleware. Either way, the enriched and qualified lead lands exactly where it should.",
  },
  {
    q: "Does it work for outbound or only inbound?",
    a: "Both. For <strong>inbound</strong> the agent enriches and qualifies every incoming lead before the first contact. For <strong>outbound</strong> the agent identifies prospects via ICP match, does enrichment, and launches personalised sequences.",
  },
  {
    q: "How do you train the brand messaging?",
    a: "We start from your best-performing emails and sequences. The agent learns your tone, structure, and CTA style. We validate with you before going live on real volume.",
  },
  {
    q: "What does it actually cost?",
    a: "Assessment <strong>€2,000</strong> (refunded). Sprint <strong>€10k–€50k</strong>. Guarantee: if the agent doesn't increase reply rates or reduce profiling time as promised, we work for free until it does.",
  },
];
---

<Layout title={title} description={description} lang="en" jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div style="color: #fff;">
          <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            Sales & Marketing · AI Agents
          </p>
          <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
            Leads enriched, qualified,<br/>contacted. Automatically.
          </h1>
          <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
            Cross-source enrichment from 25+ sources, dynamic qualification, personalised multi-channel outreach. Sales only receives ready leads. Live in 4 weeks.
          </p>
          <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-[14px] font-medium" style="color: #F4B842;">If it doesn't work, you don't pay. Guarantee included.</span>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="/en/contact" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
              Request assessment, €2,000
              <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
            </a>
            <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">See the ILTEC case study</a>
          </div>
          <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">25+ sources</strong> enrichment</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Multi-channel</strong> native</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">GDPR</strong> compliant</span></div>
          </div>
        </div>
        <div class="hidden lg:flex justify-end fade-up fade-up-delay-3">
          <HeroVisual filter="sales" lang="en" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-14 border-y border-ink-200 bg-white">
    <div class="container-soraia text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 mb-4">Already chosen by B2B SMEs with consultative sales</p>
      <p class="text-[16px]" style="color: var(--color-ink-muted);">
        <a href="/en/case-studies/iltec" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">ILTEC</a>
        · B2B office technology · AI-ready site + commercial AI agent via QR
      </p>
    </div>
  </section>

  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The problem"
        title="The sales team spends more time profiling than closing."
        subtitle="Sales tools cost €200/month per seat, but the real bottleneck is elsewhere: manual research for every lead, pipeline fragmented across five tools, 'personalised' outreach that falls flat."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The solution"
        title="6 AI agents covering the funnel from prospect to deal."
        subtitle="Identification, enrichment, qualification, outreach, tracking, analytics. The human sales rep only steps in on ready leads, with full context and a suggested approach."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (<ProcessCard {...p} />))}
      </div>
    </div>
  </section>

  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Our guarantee
        </p>
        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          Qualified pipeline on autopilot.<br/><span style="color: rgba(255,255,255,0.45);">Measured in 4 weeks. Or you don't pay.</span>
        </h2>
        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          Baseline measured during assessment (profiling time + reply rate + qualified leads/week). If the agent doesn't hit the promised numbers, we work for free until it does — or we refund you.
        </p>
      </div>
    </div>
  </section>

  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader eyebrow="Case study" title="AI agents in action at ILTEC." align="center" />
      <div class="max-w-md mx-auto">
        <CaseStudyCardJet lang="en" href={`/en/case-studies/${cases[0].slug}`} client={cases[0].client} clientLogo={cases[0].clientLogo} quote={cases[0].quote} dimensioni={cases[0].dimensioni} sector={cases[0].sector} cardImage={cases[0].cardImage} />
        <p class="mt-6 text-center text-[14px]" style="color: var(--color-ink-soft);">
          <strong style="color: var(--color-ink); font-weight: 500;">{cases[0].stakeholder.name}</strong>, {cases[0].stakeholder.role} · {cases[0].client}
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Comparison"
        title="Why custom AI agents, and not the alternatives."
        subtitle="The three real options for a sales team today."
        align="center"
      />
      <ComparisonTable columns={["Apollo / Outreach SaaS", "HubSpot Sales AI", "Soraia AI agents"]} rows={comparisonRows} highlightCol={2} />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-soraia max-w-3xl">
      <SectionHeader eyebrow="Questions" title="What we get asked most." align="center" />
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 reveal" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Next step
      </p>
      <h2 class="text-balance reveal" style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Find out how many hours your sales team can get back.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed reveal reveal-delay-1" style="color: var(--color-ink-muted);">
        Assessment €2,000, refunded if you proceed. 1–2 weeks from kick-off to report.
      </p>
      <div class="mt-10 reveal reveal-delay-2">
        <a href="/en/contact" class="btn btn-primary">
          Request assessment
          <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
