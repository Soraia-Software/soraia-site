---
import Layout from "~/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { BLOG_SLUG_MAP, reverseMap } from "~/lib/i18n";

const bare = (id: string) => id.replace(/^en\//, "");
const EN_TO_IT_BLOG = reverseMap(BLOG_SLUG_MAP);

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((p) => p.data.lang === "en" && (import.meta.env.DEV || !p.data.draft));
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^en\//, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const slug = bare(post.id);
const { Content } = await render(post);

const allPosts = (await getCollection("blog"))
  .filter((p) => p.data.lang === "en" && (import.meta.env.DEV || !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 2);

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
}

const title = `${post.data.title} | Soraia`;
const description = post.data.description;
const h1 = post.data.h1 || post.data.title;
const itSlug = EN_TO_IT_BLOG[slug];
const altHref = itSlug ? `/blog/${itSlug}` : "/blog";

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate || post.data.pubDate).toISOString(),
  author: {
    "@type": post.data.author === "Soraia" ? "Organization" : "Person",
    name: post.data.author,
    url: "https://www.soraia.io/en/about",
  },
  publisher: { "@type": "Organization", name: "Soraia", logo: { "@type": "ImageObject", url: "https://www.soraia.io/logos/soraia-full.svg" } },
  keywords: post.data.keywords.join(", "),
};
const faqJsonLd = post.data.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: post.data.faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
} : null;
const jsonLd = faqJsonLd ? [articleJsonLd, faqJsonLd] : articleJsonLd;
---

<Layout title={title} description={description} lang="en" altHref={altHref} jsonLd={jsonLd}>
  <article>
    <header class="relative overflow-hidden border-b border-line" style="background: #FAFAF8;">
      <div class="container-soraia max-w-3xl pt-20 md:pt-24 pb-12 md:pb-14">
        <a href="/en/blog" class="inline-flex items-center gap-1.5 text-[12px] font-medium tracking-[0.1em] uppercase mb-8 hover:opacity-70 transition-opacity" style="color: var(--color-ink-soft);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          All articles
        </a>
        <div class="flex items-center gap-3 text-[11px] font-medium tracking-[0.14em] uppercase mb-6" style="color: var(--color-ink-soft);">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <span>·</span>
          <span>{post.data.readMinutes ?? 5} min read</span>
          <span>·</span>
          <span>{post.data.author}</span>
        </div>
        <h1 class="text-balance" style="font-size: clamp(1.875rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
          {h1}
        </h1>
        <p class="mt-6 text-[18px] md:text-[19px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">
          {post.data.description}
        </p>
      </div>
    </header>

    <section class="bg-white">
      <div class="container-soraia max-w-3xl py-12 md:py-16">
        <div class="prose-soraia">
          <Content />
        </div>

        {post.data.faq.length > 0 && (
          <div class="mt-14 pt-10 border-t border-line">
            <p class="eyebrow mb-3">Frequently asked questions</p>
            <h2 class="mb-8 text-balance" style="font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2rem); line-height: 1.15; letter-spacing: -0.025em; font-weight: 500;">
              What people usually ask us.
            </h2>
            <div class="space-y-3">
              {post.data.faq.map((f) => (
                <details class="group border border-line rounded-xl bg-white overflow-hidden">
                  <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between gap-4 select-none">
                    <span class="font-medium text-[15.5px]" style="color: var(--color-ink);">{f.q}</span>
                    <span class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center transition-transform group-open:rotate-45" style="background: var(--color-ink-50);">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-ink-muted);"><path d="M12 5v14M5 12h14"/></svg>
                    </span>
                  </summary>
                  <div class="px-6 pb-5 -mt-1 text-[14.5px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);" set:html={f.a}></div>
                </details>
              ))}
            </div>
          </div>
        )}

        {post.data.tags?.length > 0 && (
          <div class="mt-12 pt-8 border-t border-line flex flex-wrap gap-2">
            {post.data.tags.map((t) => (
              <span class="text-[11px] font-medium tracking-[0.1em] uppercase px-3 py-1.5 rounded-full" style="background: var(--color-ink-50); color: var(--color-ink-soft);">{t}</span>
            ))}
          </div>
        )}
      </div>
    </section>

    {related.length > 0 && (
      <section class="border-t border-line bg-white" style="padding-block: 4rem;">
        <div class="container-soraia">
          <p class="eyebrow mb-8">Keep reading</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {related.map((p) => (
              <a href={`/en/blog/${bare(p.id)}`} class="card-editorial !p-7 group no-underline flex flex-col transition-all hover:!-translate-y-0.5 hover:shadow-md">
                <div class="flex items-center gap-3 text-[11px] font-medium tracking-[0.14em] uppercase mb-4" style="color: var(--color-ink-soft);">
                  <time datetime={p.data.pubDate.toISOString()}>{formatDate(p.data.pubDate)}</time>
                  <span>·</span>
                  <span>{p.data.readMinutes ?? 5} min</span>
                </div>
                <h3 class="mb-3 text-balance" style="font-size: 1.25rem; line-height: 1.2; letter-spacing: -0.015em; font-weight: 500;">{p.data.title}</h3>
                <p class="text-[14px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section bg-violet-mesh">
      <div class="container-soraia text-center max-w-3xl mx-auto">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
          <span class="w-1 h-1 rounded-full bg-violet-600"></span>
          Next step
        </p>
        <h2 class="text-balance" style="font-size: clamp(1.875rem, 3vw + 0.5rem, 2.5rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
          Where are you on the AI journey?
        </h2>
        <p class="mt-5 text-[17px] leading-relaxed" style="color: var(--color-ink-muted);">
          The check-up gives you an AI readiness score (0–100) + 3 concrete next steps. 3 minutes, no email.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/en/check-up" class="btn btn-primary">
            Start the check-up
            <span class="btn-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
          <a href="/en/contact" class="btn btn-secondary">Let's talk directly</a>
        </div>
      </div>
    </section>
  </article>
</Layout>

<style is:global>
  .prose-soraia {
    color: var(--color-ink);
    font-size: 17px;
    line-height: 1.75;
  }
  .prose-soraia > * + * { margin-top: 1.25em; }
  .prose-soraia h2 {
    font-size: clamp(1.5rem, 2vw + 0.5rem, 1.875rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 500;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--color-ink);
  }
  .prose-soraia h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-weight: 500;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-ink);
  }
  .prose-soraia p { color: var(--color-ink); }
  .prose-soraia strong { font-weight: 600; color: var(--color-ink); }
  .prose-soraia a {
    color: var(--color-brand);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose-soraia a:hover { opacity: 0.7; }
  .prose-soraia ul, .prose-soraia ol {
    padding-left: 1.4em;
    color: var(--color-ink);
  }
  .prose-soraia ul { list-style: disc; }
  .prose-soraia ol { list-style: decimal; }
  .prose-soraia li { margin: 0.4em 0; }
  .prose-soraia li::marker { color: var(--color-ink-soft); }
  .prose-soraia hr {
    border: none;
    border-top: 1px solid var(--color-line);
    margin-block: 2.5em;
  }
  .prose-soraia blockquote {
    border-left: 3px solid var(--color-brand);
    padding-left: 1.25em;
    margin-left: 0;
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .prose-soraia code {
    background: var(--color-ink-50);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }
  .prose-soraia pre {
    background: var(--color-ink-50);
    padding: 1em 1.25em;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.9em;
    line-height: 1.6;
  }
  .prose-soraia pre code { background: transparent; padding: 0; }
</style>
