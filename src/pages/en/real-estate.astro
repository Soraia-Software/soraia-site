---
import Layout from "~/layouts/Layout.astro";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import HeroVisual from "~/components/HeroVisual.astro";
import CTABanner from "~/components/CTABanner.astro";

const title = "AI Agents for Real Estate and Property Operations | Soraia";
const description =
  "For real estate agencies, property managers, and real estate tech. Agents that capture listings with 1 click, qualify leads, generate client dossiers, and handle multi-stakeholder approvals. First delivery in 4 weeks.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Agents for Real Estate & Property Ops. Soraia",
    provider: {
      "@type": "Organization",
      name: "Soraia",
      url: "https://www.soraia.io",
    },
    areaServed: ["IT", "EU"],
    serviceType: "AI agents for real estate operations and property management",
    offers: [
      {
        "@type": "Offer",
        name: "AI Readiness Assessment",
        priceCurrency: "EUR",
        price: "2000",
        description: "1-2 week assessment, refunded if you proceed with the sprint.",
      },
      {
        "@type": "Offer",
        name: "Co-Building Sprint",
        priceCurrency: "EUR",
        description: "Sprint €10-50k, first delivery in 4 weeks.",
      },
    ],
  },
];

const problems = [
  {
    title: "Listings captured by hand",
    description: "Listing sites, scraping, Excel: every new property requires hours of copy-paste for data, photos, floor plans, geolocation. The consultant becomes a data-entry clerk.",
  },
  {
    title: "Client-property matching from memory",
    description: "The senior consultant remembers who is looking for what. Without a system, matching is opportunistic: clients forgotten, the right properties proposed too late.",
  },
  {
    title: "Endless approval pipelines",
    description: "Between incentives, authorisations, and counter-signatures from owners and administrators, every transaction runs through email and PDF. Weeks lost, no single source of truth.",
  },
];

const processes = [
  {
    number: "01",
    title: "Capture — listing ingested in one click",
    description:
      "From a public listing URL, the agent extracts structured data, photos, floor plan, and address. A complete property card ready in your CRM within seconds.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "Enrichment — context data gathered autonomously",
    description:
      "The agent enriches with zoning, precise geolocation, average area price, schools and amenities, and market valuation. Informed decisions with no manual research.",
    icon: "match" as const,
  },
  {
    number: "03",
    title: "Client-property match on criteria",
    description:
      "For every new listing, the agent cross-references your active client portfolio and surfaces matches with an affinity score. Dormant clients re-enter the pipeline.",
    icon: "compass" as const,
  },
  {
    number: "04",
    title: "Comparative dossiers for each client",
    description:
      "The agent generates PDF dossiers with 3-5 properties selected against the client's criteria. Ready to send by email, share on the portal, or present in person.",
    icon: "outreach" as const,
  },
  {
    number: "05",
    title: "Multi-stakeholder approval pipeline",
    description:
      "Every transaction step (incentive, authorisation, counter-signature) has a real-time status. No more lost emails, no more 'waiting for X to sign'.",
    icon: "calendar" as const,
  },
  {
    number: "06",
    title: "Portfolio analytics and KPIs",
    description:
      "Portfolio tracker: time-on-market per property, conversion rate per consultant, pipeline value. Alerts when a new listing matches an active client.",
    icon: "transcript" as const,
  },
];

const featuredCases = [
  {
    slug: "frh",
    client: "French Riviera Househunting",
    clientLogo: "/logos/clients/frh.webp",
    quote: "Two AI agents: one enriches and qualifies every lead, the other lets me capture target properties with one click and assign them to the client who sees them on the portal.",
    dimensioni: "1-10",
    sector: "Boutique real estate · French Riviera",
    cardImage: "/testimonials/fabricio-carminati-frh.webp",
  },
  {
    slug: "rainplan",
    client: "Rainplan",
    clientLogo: "/logos/clients/rainplan.webp",
    quote: "Soraia built the backbone of Rainplan in 18 months. Hundreds of parcels, multiple incentive programs, and multi-stakeholder approvals managed autonomously.",
    dimensioni: "51-250",
    sector: "Climate tech · Stormwater management",
    cardImage: "/testimonials/russell-fyfe.webp",
  },
];

const comparisonRows = [
  { label: "Property capture", values: ["Manual copy-paste", "Listing scraper", "1 click from listing + enrichment"] as [string, string, string] },
  { label: "Client-property match", values: ["Consultant's memory", "CRM filters", "Automatic score + alert"] as [string, string, string] },
  { label: "Client dossier", values: ["Manual Word/PDF", "Static templates", "Generated on demand by the agent"] as [string, string, string] },
  { label: "Approval pipeline", values: ["Email + PDF signature", "Shared spreadsheet", "Multi-stakeholder real-time"] as [string, string, string] },
  { label: "Portfolio analytics", values: ["Nothing", "Basic export", "Tracker + real-time alerts"] as [string, string, string] },
];

const faqs = [
  {
    q: "We work on a small number of high-value mandates, not volumes. Is it worth it?",
    a: "Yes — in fact that's where agents deliver the best ROI. With low volume and high value, every hour of the senior consultant counts: <strong>freeing them from data entry and memory-based matching</strong> means more time on selection and relationship-building, where value is actually created. See the <a href='/en/case-studies/frh'>French Riviera Househunting</a> case study.",
  },
  {
    q: "Which systems does it integrate with?",
    a: "Salesforce, HubSpot, Pipedrive, Zoho, custom real estate management systems (Idealista PRO, Casa.it agency tools, proprietary CRMs). For dossiers and documents: Notion, Airtable, Xano, Google Drive. If you have a custom stack we validate it during the assessment.",
  },
  {
    q: "How long until the first agent is in production?",
    a: "<strong>4 weeks from go.</strong> Week 1: discovery + baseline. Weeks 2-3: build (capture + enrichment + CRM integration). Week 4: deploy + team training + first measurement. 30 days of hypercare included.",
  },
  {
    q: "How do you handle GDPR and client data?",
    a: "Agents run in a European cloud environment or on-premise on your infrastructure. <strong>No training on your data.</strong> Full logs of every agent decision. GDPR Art. 28 DPA included in the contract.",
  },
  {
    q: "How much does it cost?",
    a: "Assessment €2,000 (refunded if you proceed). Sprint €10-50k depending on complexity, price defined in the proposal after the assessment. <strong>You only pay if you're satisfied</strong>: if the target isn't reached at go-live + 30 days, we work for free until it is.",
  },
];
---

<Layout title={title} description={description} lang="en" jsonLd={jsonLd}>
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div style="color: #fff;">
          <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            Property Ops · AI Agents
          </p>

          <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
            Listings captured,<br/>clients matched, dossiers ready.
          </h1>

          <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
            AI agents that capture listings with 1 click, propose client matches, generate tailored dossiers, and manage multi-stakeholder approval pipelines. The consultant goes back to being a consultant.
          </p>

          <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-[14px] font-medium" style="color: #F4B842;">You only pay if you're satisfied. Guarantee included.</span>
          </div>

          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="/en/contact" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
              20 min with Daniel
              <span class="btn-arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </a>
            <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">
              See case studies
            </a>
          </div>

          <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
            <div class="inline-flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-amber"></span>
              <span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">1 click</strong> from listing to CRM</span>
            </div>
            <div class="inline-flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-amber"></span>
              <span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Automatic match</strong> client-property</span>
            </div>
            <div class="inline-flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-amber"></span>
              <span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Real-time pipeline</strong> multi-stakeholder</span>
            </div>
          </div>
        </div>

        <div class="hidden lg:flex justify-end fade-up fade-up-delay-3">
          <HeroVisual filter="real-estate" lang="en" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRUST LINE
       ============================================================ -->
  <section class="py-12 md:py-14 border-y border-ink-200 bg-white">
    <div class="container-soraia text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 mb-4">
        Already trusted by real estate agencies and real estate tech companies
      </p>
      <p class="text-[16px]" style="color: var(--color-ink-muted);">
        <a href="/en/case-studies/frh" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">French Riviera Househunting</a>
        ·
        <a href="/en/case-studies/rainplan" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">Rainplan</a>
        · active clients
      </p>
    </div>
  </section>

  <!-- ============================================================
       PROBLEMA
       ============================================================ -->
  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The problem"
        title="Real estate consultants spend half their day doing data entry."
        subtitle="Manual property capture, client matching from memory, approval pipelines dragging on for weeks via email and PDF. The consultant's value lies in selection and relationships — not copy-paste."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
              </svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       6 PROCESSI
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The solution"
        title="6 orchestrated agents across the full Property Ops cycle."
        subtitle="From listing captured to client viewing the dossier, through to final approval. Every step covered by an AI agent that talks to your existing systems."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (
          <ProcessCard {...p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       GARANZIA
       ============================================================ -->
  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          The guarantee
        </p>

        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          First delivery in 4 weeks.<br/><span style="color: rgba(255,255,255,0.45);">If the agent doesn't recover the hours, we work for free.</span>
        </h2>

        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          The sprint has a clear target set during the assessment (e.g. <em>a property capture agent that recovers 5h/consultant/week</em>). If the target isn't reached at go-live + 30 days of hypercare, we work for free until it is — or we refund the sprint.
        </p>

        <p style="color: rgba(255,255,255,0.55);" class="mt-4 text-[15px] leading-relaxed max-w-2xl text-pretty">
          Assessment €2,000, refunded if you proceed. Sprint €10-50k, price defined in the proposal. The code is yours from day one — no perpetual subscriptions.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CASE STUDIES
       ============================================================ -->
  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Case studies"
        title="Already live at agencies and real estate tech companies."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {featuredCases.map((c) => (
          <CaseStudyCardJet
            lang="en"
            href={`/en/case-studies/${c.slug}`}
            client={c.client}
            clientLogo={c.clientLogo}
            quote={c.quote}
            dimensioni={c.dimensioni}
            sector={c.sector}
            cardImage={c.cardImage}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       COMPARISON TABLE
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia max-w-5xl">
      <SectionHeader
        eyebrow="Comparison"
        title="What changes versus how things work today."
        align="center"
      />

      <ComparisonTable
        columns={["Manual status quo", "Generic CRM", "Soraia · Property Ops"]}
        rows={comparisonRows}
      />
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia max-w-4xl">
      <SectionHeader
        eyebrow="Frequently asked questions"
        title="What people usually ask us."
        align="center"
      />
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ============================================================
       CTA FINALE
       ============================================================ -->
  <CTABanner
    title="20 minutes with the CEO. No pitch."
    description="We figure out together whether an AI Readiness Assessment makes sense for your situation. No commitment, no sales."
    ctaText="20 min with Daniel"
    ctaHref="/en/contact"
    avatarName="Daniel Levis"
    avatarRole="Co-Founder & CEO"
    avatarSrc="/team/daniel-levis.webp"
  />
</Layout>
