---
import Layout from "~/layouts/Layout.astro";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import HeroVisual from "~/components/HeroVisual.astro";

const title = "AI Agents for Accounting Firms and Finance Ops | Soraia";
const description =
  "From Excel patchwork to a unified system. AI agents that read invoices, reconcile, generate reports and billing. Management goes back to advising clients. Live in 4 weeks.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Agents for Finance & Accounting. Soraia",
    provider: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
    areaServed: "IT",
    serviceType: "AI agents for accounting firms and finance ops",
    offers: { "@type": "Offer", priceCurrency: "EUR", price: "2000", description: "Initial assessment €2,000, refunded if you proceed with the sprint." },
  },
];

const problems = [
  {
    title: "Parallel spreadsheets no one controls",
    description: "Quotes, engagements, and billable hours recorded in separate sheets with different line items per division. Reconciling them monthly is expensive manual work.",
  },
  {
    title: "Management doing data entry",
    description: "Senior staff spend hours checking hours, reconciling engagements, and reconstructing quotes. Qualified time burned on operations.",
  },
  {
    title: "Zero consolidated analytics",
    description: "How many clients, in which division, at what margin? Producing even a basic figure requires hours of exports and manual cross-referencing. No consolidated view.",
  },
];

const processes = [
  {
    number: "01",
    title: "Automated quote generation",
    description: "The agent reads the client request, proposes the correct line items from the firm catalogue, and calculates a structured quote at the right rate for each division.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "Real-time engagement tracking",
    description: "Who is assigned to which client, on which part of the quote, with management visibility into team utilisation. No more parallel shared spreadsheets.",
    icon: "match" as const,
  },
  {
    number: "03",
    title: "Granular time validation",
    description: "The team logs hours with precise line items (travel, remote, on-site, special items). The agent validates, reconciles, and flags anomalies automatically.",
    icon: "calendar" as const,
  },
  {
    number: "04",
    title: "Invoice OCR and data extraction",
    description: "Incoming invoices (PDF, scan, photo) parsed by the agent: amount, VAT, codes, supplier, due date. Ready for validation and accounting import.",
    icon: "transcript" as const,
  },
  {
    number: "05",
    title: "Billing export",
    description: "At month end, the agent produces a per-client report with line-item detail, ready for billing and for any existing accounting integration.",
    icon: "outreach" as const,
  },
  {
    number: "06",
    title: "Team utilisation analytics",
    description: "Real-time dashboard: hours per client, margin per division, quote conversion rate, alerts on clients at risk of overrun.",
    icon: "compass" as const,
  },
];

const cases = [
  {
    slug: "numeraria",
    client: "Numeraria",
    quote: "The first half of the month used to be quotes, hours, and reconciliations. Today the AI agents handle everything autonomously, the team uses the system without even noticing.",
    dimensioni: "11-50",
    sector: "Payroll & accounting firm",
    cardImage: "/testimonials/elisa-gnan-numeraria.webp",
    stakeholder: { name: "Elisa Gnan", role: "Consultant" },
  },
];

const comparisonRows = [
  { label: "Cost", values: ["Low", "High annual", "Mid one-off"] as [string, string, string] },
  { label: "Time to live", values: ["Immediate", "6–12 months", "4 weeks"] as [string, string, string] },
  { label: "Executes tasks autonomously", values: ["No", "Limited", "Yes, end-to-end"] as [string, string, string] },
  { label: "Custom to your processes", values: ["No", "Configurable", "Built for you"] as [string, string, string] },
  { label: "Vendor lock-in", values: ["None", "Total", "None (your code)"] as [string, string, string] },
  { label: "Accounting integration", values: ["Manual", "Limited", "All major systems"] as [string, string, string] },
];

const faqs = [
  {
    q: "How do you handle GDPR and sensitive accounting data?",
    a: "European or on-premise infrastructure on your own servers. <strong>No training on your data</strong>. Full operation logs, configurable retention, validated with Italian firms serving enterprise clients.",
  },
  {
    q: "Does it integrate with my accounting system (TeamSystem, Zucchetti, Fatture in Cloud, etc.)?",
    a: "Yes. We work with all major Italian accounting systems via API or programmatic export. If you have a legacy system, we assess it in the initial engagement.",
  },
  {
    q: "What if the team changes or grows?",
    a: "The system scales automatically: new users, new divisions, new rate items. <strong>The code is yours</strong>, no per-seat or per-module costs.",
  },
  {
    q: "What does it actually cost?",
    a: "Assessment <strong>€2,000</strong> (refunded if you proceed). Build sprint <strong>€10–50k</strong> depending on processes covered. Guarantee: if the agents don\'t recover the promised hours, we work for free until they do.",
  },
  {
    q: "What happens in 4 weeks?",
    a: "<strong>Week 1:</strong> discovery + baseline with management. <strong>Weeks 2–3:</strong> build + accounting integration. <strong>Week 4:</strong> deploy + training + first measurement. 30 days of post-go-live support included.",
  },
];
---

<Layout title={title} description={description} lang="en" jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div style="color: #fff;">
          <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            Finance & Accounting · AI Agents
          </p>
          <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
            From Excel patchwork<br/>to a unified system.
          </h1>
          <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
            AI agents that read invoices, reconcile hours, generate quotes and billing. Management goes back to advising clients, not doing data entry. Live in 4 weeks.
          </p>
          <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-[14px] font-medium" style="color: #F4B842;">If it doesn't work, you don't pay. Guarantee included.</span>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="/en/contact" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
              Request assessment, €2,000
              <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
            </a>
            <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">See the Numeraria case study</a>
          </div>
          <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">4 weeks</strong> to first live agent</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Half a month</strong> of management time returned</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">GDPR + audit log</strong> included</span></div>
          </div>
        </div>
        <div class="hidden lg:flex justify-end fade-up fade-up-delay-3">
          <HeroVisual filter="finance" lang="en" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-14 border-y border-ink-200 bg-white">
    <div class="container-soraia text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 mb-4">Already chosen by Italian firms</p>
      <p class="text-[16px]" style="color: var(--color-ink-muted);">
        <a href="/en/case-studies/numeraria" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">Numeraria</a>
        · Multi-division payroll & accounting firm · active client
      </p>
      <p class="mt-5 text-[13px]" style="color: var(--color-ink-soft);">
        Working in a VC fund, family office, or M&A team?
        <a href="/en/venture-capital" class="inline-flex items-center gap-1 ml-1 font-semibold text-violet-700 hover:gap-1.5 transition-all">
          Dedicated page · deal flow, due diligence, portfolio
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </p>
    </div>
  </section>

  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The problem"
        title="Firm management is no longer doing management."
        subtitle="Senior staff, the most expensive people, spend a significant share of their time on data entry, reconciliations, and manual report production. That time never makes it onto an invoice."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="The solution"
        title="6 AI agents covering the full quote-to-billing cycle."
        subtitle="Digital workers that execute tasks end-to-end. The team uses the system without noticing, management steps in only where judgement is needed."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (<ProcessCard {...p} />))}
      </div>
    </div>
  </section>

  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Our guarantee
        </p>
        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          Half the month returned to management.<br/><span style="color: rgba(255,255,255,0.45);">Measured in 4 weeks. Or you don't pay.</span>
        </h2>
        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          Baseline measured together during the assessment. If we don't recover the promised time, we work for free until we do, or we refund the sprint.
        </p>
      </div>
    </div>
  </section>

  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader eyebrow="Case study" title="AI agents in action at Numeraria." align="center" />
      <div class="max-w-md mx-auto">
        <CaseStudyCardJet lang="en" href={`/en/case-studies/${cases[0].slug}`} client={cases[0].client} quote={cases[0].quote} dimensioni={cases[0].dimensioni} sector={cases[0].sector} cardImage={cases[0].cardImage} />
        <p class="mt-6 text-center text-[14px]" style="color: var(--color-ink-soft);">
          <strong style="color: var(--color-ink); font-weight: 500;">{cases[0].stakeholder.name}</strong>, {cases[0].stakeholder.role} · {cases[0].client}
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Comparison"
        title="Why custom AI agents, and not something else."
        subtitle="The three real options for an accounting firm or finance team today."
        align="center"
      />
      <ComparisonTable columns={["Excel / legacy system", "Enterprise ERP", "Soraia AI agents"]} rows={comparisonRows} highlightCol={2} />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-soraia max-w-3xl">
      <SectionHeader eyebrow="Questions" title="What people usually ask us." align="center" />
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 reveal" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Next step
      </p>
      <h2 class="text-balance reveal" style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Find out how much time your firm can get back.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed reveal reveal-delay-1" style="color: var(--color-ink-muted);">
        Assessment €2,000, refunded if you proceed. 1–2 weeks from kick-off to report. No commitment to go further.
      </p>
      <div class="mt-10 reveal reveal-delay-2">
        <a href="/en/contact" class="btn btn-primary">
          Request assessment
          <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
