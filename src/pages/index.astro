  { name: "Bilel Abdelmoula", role: "Senior Developer", flag: "🇹🇳", photoSrc: "/team/bilel-abdelmoula.png" },
  { name: "Sebastian Geido", role: "Senior Developer", flag: "🇦🇷", photoSrc: "/team/sebastian-geido.png" },
