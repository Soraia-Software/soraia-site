  {
    x: 51.5, y: 38,
    label: "Europa",
    flag: "🌍",
    total: 20,
    countries: [
      { flag: "🇮🇹", name: "Italia", count: 12 },
      { flag: "🇫🇷", name: "Francia", count: 4 },
      { flag: "🇪🇸", name: "Spagna", count: 1 },
