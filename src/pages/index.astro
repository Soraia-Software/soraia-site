---
import Layout from "~/layouts/Layout.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import ProofBar from "~/components/ProofBar.astro";
import ServiceFeature from "~/components/ServiceFeature.astro";
import TestimonialCard from "~/components/TestimonialCard.astro";
import TeamMemberCard from "~/components/TeamMemberCard.astro";
import WorldMap from "~/components/WorldMap.astro";
import CTABanner from "~/components/CTABanner.astro";
import HeroVisual from "~/components/HeroVisual.astro";
import FAQ from "~/components/FAQ.astro";
import PartnersStrip from "~/components/PartnersStrip.astro";
import AvatarCircle from "~/components/AvatarCircle.astro";
import LeadForm from "~/components/LeadForm.tsx";

const title = "Soraia — Portiamo gli Agenti IA nelle PMI Italiane";
const description =
  "Non software che il tuo team deve imparare a usare. Agenti IA che eseguono i tuoi processi. Misuriamo il tempo recuperato, se non funziona, non paghi.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Soraia",
  url: "https://www.soraia.io",
  logo: "https://www.soraia.io/logos/soraia-full.svg",
  description,
  email: "hello@soraia.io",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Biella",
    addressCountry: "IT",
  },
  sameAs: ["https://www.linkedin.com/company/soraia-io"],
};

const homeLogos = [
  { name: "APraise", src: "/logos/clients/apraise.webp" },
  { name: "OggiLavoro", src: "/logos/clients/oggilavoro.png" },
  { name: "Aegis Group", src: "/logos/clients/aegisgroup.webp" },
  { name: "Talent Match", src: "/logos/clients/talentmatch.webp" },
  { name: "Rainplan", src: "/logos/clients/rainplan.webp" },
  { name: "Numeraria", src: "/logos/clients/numeraria.png" },
  { name: "KB&B", src: "/logos/clients/kbb.webp" },
  { name: "StoryWonder", src: "/logos/clients/storywonder.webp" },
  { name: "CXL", src: "/logos/clients/cxl.webp" },
  { name: "Stars Be Original", src: "/logos/clients/starsbeoriginal.png" },
  { name: "Liftt", src: "/logos/clients/liftt.webp" },
  { name: "Navily", src: "/logos/clients/navily.png" },
  { name: "French Riviera Househunting", src: "/logos/clients/frh.webp" },
];

const partners = [
  { name: "Anthropic", src: "/logos/tools/anthropic.webp" },
  { name: "OpenAI", src: "/logos/tools/openai.svg" },
  { name: "Mistral", src: "/logos/tools/mistral.webp" },
  { name: "Google Cloud", src: "/logos/tools/google.webp" },
  { name: "Make", src: "/logos/tools/make.webp" },
  { name: "n8n", src: "/logos/tools/n8n.webp" },
  { name: "Xano", src: "/logos/tools/xano.webp" },
  { name: "WeWeb", src: "/logos/tools/weweb.svg" },
  { name: "Cloudflare", src: "/logos/tools/cloudflare.svg" },
];

const testimonials = [
  {
    quote:
      "Soraia ha portato i nostri recruiter dal 60% di tempo su attività amministrative al 60% sul valore — closing e candidate experience. L'agente lavora, loro chiudono.",
    name: "Jacopo Berti",
    role: "CEO",
    company: "APraise",
  },
  {
    quote:
      "Ci siamo trovati con €32.000 al mese di costi operativi recuperati. Non era nelle slide di una consulenza, era nei numeri di fine mese.",
    name: "Massimo Cretier",
    role: "Founder",
    company: "Numeraria",
  },
  {
    quote:
      "In 4 settimane gli agenti erano live. Non abbiamo dovuto formare nessuno: il team ha smesso di fare quel lavoro, ha iniziato a fare cose nuove.",
    name: "Stefano Cantamessa",
    role: "Co-Founder",
    company: "Aegis Group",
  },
  {
    quote:
      "Hanno costruito su misura, hanno spiegato cosa stavano facendo, ci hanno passato il codice. Nessuna sensazione di dipendenza dal fornitore.",
    name: "Maximilien Brungs",
    role: "CEO",
    company: "KB&B Family Marketing",
  },
];

const team = [
  { name: "Daniel Levis", role: "Co-Founder & CEO", flag: "🇮🇹" },
  { name: "Davide Silvestri", role: "Co-Founder & CTO", flag: "🇮🇹" },
  { name: "Eleonora Cogo", role: "Project Manager", flag: "🇮🇹" },
  { name: "Narella Petrocco", role: "Project Manager + QA", flag: "🇮🇹" },
  { name: "Veronica Pisana", role: "Linkly Lead", flag: "🇮🇹" },
  { name: "Martina Rochstein", role: "Senior Developer", flag: "🇩🇪" },
  { name: "Mohamed Mejri", role: "Senior Developer", flag: "🇹🇳" },
  { name: "Lorenzo Barbaglia", role: "Senior Developer", flag: "🇮🇹" },
  { name: "Bilel Abdelmoula", role: "Senior Developer", flag: "🇹🇳" },
  { name: "Sebastian Geido", role: "Senior Developer", flag: "🇦🇷" },
  { name: "Guillaume", role: "Mobile Developer", flag: "🇫🇷" },
  { name: "Andrea Aschei", role: "Mobile Developer", flag: "🇮🇹" },
];

const worldDots = [
  { x: 50, y: 32, label: "Italia" },
  { x: 47, y: 36, label: "Francia" },
  { x: 46, y: 31, label: "UK" },
  { x: 45, y: 38, label: "Spagna" },
  { x: 20, y: 36, label: "USA" },
  { x: 28, y: 78, label: "Argentina" },
  { x: 53, y: 62, label: "Tunisia" },
  { x: 47, y: 28, label: "Germania" },
];

const faqs = [
  {
    q: "Cosa significa esattamente \"agente IA\"?",
    a: "Un agente IA è un software che esegue compiti in autonomia: legge dati, prende decisioni e agisce sui tuoi sistemi (ATS, CRM, gestionale). Non è ChatGPT che ti suggerisce risposte. È un lavoratore digitale che fa il lavoro al posto del tuo team, sui processi che voi scegliete.",
  },
  {
    q: "Quanto tempo serve per vedere risultati?",
    a: "4 settimane dal go al primo agente in produzione. La settimana 1 facciamo discovery e misuriamo la baseline. Settimane 2 e 3 costruiamo. Settimana 4 deploy, training del team e prima misurazione. <strong>30 giorni di affiancamento inclusi</strong> dopo il go-live.",
  },
  {
    q: "Quanto costa?",
    a: "<strong>Assessment 2.000€</strong> (rimborsato se procedi con lo sprint). <strong>Sprint di build 10–50k€</strong> a seconda di quanti processi copri. Garanzia: se gli agenti non recuperano le ore promesse, lavoriamo gratis finché non succede — o rimborsiamo.",
  },
  {
    q: "Come gestite GDPR, AI Act e dati sensibili?",
    a: "Agenti in ambiente cloud europeo o on-premise sulla tua infrastruttura. <strong>Nessun training sui tuoi dati</strong>. Log completi di ogni decisione, DPO esterno per le valutazioni d'impatto, allineamento al Regolamento europeo IA.",
  },
  {
    q: "Si integra con i sistemi che già usiamo?",
    a: "Sì. Lavoriamo con Bullhorn, Salesforce, Bee-Staffing, In-Recruiting, Odoo, Fatture in Cloud, HubSpot, Pipedrive, gestionali italiani legacy. Se hai uno strumento custom, lo validiamo in assessment.",
  },
  {
    q: "Cosa succede se voglio internalizzare dopo?",
    a: "<strong>Il codice è tuo dalla prima settimana.</strong> Documentazione completa, training del tuo team se vuoi gestire in autonomia. Niente abbonamenti perpetui, niente lock-in.",
  },
  {
    q: "Lavorate solo in Italia?",
    a: "Siamo basati a Biella, ma serviamo clienti in Italia, Spagna, UK, Francia, USA, Argentina e Canada. Il team parla italiano, inglese, francese e spagnolo nativamente.",
  },
  {
    q: "E se non funziona?",
    a: "<strong>Non paghi.</strong> Misuriamo le ore recuperate sulla baseline definita insieme in assessment. Se gli agenti non raggiungono il target, continuiamo gratis finché ci arrivano — oppure ti rimborsiamo lo sprint. Nessun cavillo contrattuale.",
  },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <!-- ============================================================
       1. HERO DEEP PURPLE
       ============================================================ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-violet-900 via-violet-800 to-violet-700">
    <!-- Background decoration -->
    <div class="orb orb-violet w-[600px] h-[600px] -top-32 -right-20 opacity-50 float-slow" aria-hidden="true"></div>
    <div class="orb orb-lilac w-[500px] h-[500px] -bottom-32 -left-20 opacity-40 float-slower" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(244,184,66,0.10),transparent_55%)]"></div>

    <div class="container-soraia pt-14 md:pt-20 pb-16 md:pb-24 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center min-h-[60vh]">
        <!-- Left: copy -->
        <div class="lg:col-span-6 text-white">
          <p class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-white/10 border border-white/15 text-xs font-semibold uppercase tracking-[0.14em] text-violet-100 mb-7 fade-up">
            <span class="w-1.5 h-1.5 rounded-full bg-amber animate-pulse"></span>
            AI Agency · Italia
          </p>

          <h1 class="font-display text-[2.75rem] sm:text-[3.5rem] md:text-[4.5rem] lg:text-[5.25rem] font-semibold tracking-[-0.035em] leading-[0.98] text-balance fade-up fade-up-delay-1">
            Portiamo gli <em class="not-italic text-amber">Agenti&nbsp;IA</em> nelle PMI Italiane.
          </h1>

          <p class="mt-7 text-[18px] md:text-[20px] text-violet-100/85 leading-[1.5] max-w-xl fade-up fade-up-delay-2 text-pretty">
            Non software che il tuo team deve imparare a usare. <strong class="text-white">Agenti IA che eseguono i tuoi processi.</strong> Misuriamo il tempo recuperato — se non funziona, non paghi.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="#contact" class="btn !bg-white !text-violet-900 hover:!bg-amber hover:!text-ink-900">
              Call gratuita con il CEO
              <span class="btn-arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </a>
            <a href="#servizi" class="btn !bg-transparent !text-white !border-white/25 hover:!bg-white/10">
              Cosa facciamo
            </a>
          </div>

          <div class="mt-12 flex items-center gap-4 fade-up fade-up-delay-4">
            <div class="flex -space-x-2">
              <AvatarCircle name="DL" size="sm" variant="lilac" />
              <AvatarCircle name="DS" size="sm" variant="violet" />
              <AvatarCircle name="EC" size="sm" variant="lilac" />
              <AvatarCircle name="MR" size="sm" variant="ink" />
            </div>
            <p class="text-sm text-violet-100/70 leading-snug">
              <strong class="text-white">30+ clienti</strong> tra Italia, Spagna, UK, USA<br/>
              <span class="text-violet-200/60">Live media 4 settimane · GDPR + AI Act</span>
            </p>
          </div>
        </div>

        <!-- Right: visual -->
        <div class="lg:col-span-6 fade-up fade-up-delay-2">
          <HeroVisual />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. TRUSTED BY — proof bar
       ============================================================ -->
  <ProofBar label="Si fidano di noi" logos={homeLogos} />

  <!-- ============================================================
       3. CEO INTRO
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <div class="max-w-5xl mx-auto text-center">
        <p class="eyebrow mb-6 mx-auto reveal">Il nostro approccio</p>
        <h2 class="font-display text-[2.5rem] md:text-[4rem] font-semibold tracking-tight leading-[1.02] text-ink-900 text-balance reveal">
          Velocità senza compromessi sulla qualità.
        </h2>
        <p class="mt-7 text-[17px] md:text-[19px] text-ink-600 leading-relaxed max-w-3xl mx-auto text-pretty reveal reveal-delay-1">
          Lavoriamo a sprint settimanali, costruiamo agenti che producono ROI dalla settimana 4, ti consegniamo codice tuo e documentato. Niente trasformazioni a 12 mesi, niente shelfware, niente dipendenza dal fornitore.
        </p>

        <!-- CEO card -->
        <div class="mt-12 inline-flex flex-col items-center gap-5 reveal reveal-delay-2">
          <div class="relative">
            <AvatarCircle name="Daniel Levis" size="xl" variant="violet" />
            <span class="absolute -bottom-1.5 -right-1.5 w-8 h-8 rounded-full bg-white border-2 border-ink-50 flex items-center justify-center text-base">🇮🇹</span>
          </div>
          <div>
            <p class="font-display text-xl font-semibold text-ink-900">Daniel Levis</p>
            <p class="text-sm text-ink-500 mt-0.5">Co-Founder & CEO · Biella, Italia</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. CTA BANNER — start with a free call
       ============================================================ -->
  <CTABanner
    title="Inizia con una call gratuita con il nostro CEO."
    description="20 minuti per capire se gli agenti IA hanno senso per il tuo business. Nessun impegno, nessun pitch commerciale: solo una conversazione operativa."
    ctaText="Prenota la call"
    ctaHref="#contact"
    avatarName="Daniel Levis"
    avatarRole="Co-Founder & CEO"
  />

  <!-- ============================================================
       5. SERVIZI — feature tabs
       ============================================================ -->
  <section id="servizi" class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Cosa facciamo"
        title="Agenti IA, custom software, automazioni."
        subtitle="Tre modi per portare l'intelligenza artificiale dentro la tua operatività. Iniziamo sempre dall'assessment, poi scegliamo l'approccio giusto per il tuo caso."
        align="center"
      />

      <div class="space-y-24 md:space-y-32">
        <ServiceFeature
          eyebrow="01 · Agenti IA"
          title="Agenti che eseguono i tuoi processi end-to-end."
          description="Screening, qualifica, outreach, scheduling, riconciliazioni, moderazione. L'agente legge, decide, agisce sui tuoi sistemi. I tuoi recruiter / commerciali / contabili tornano a fare il lavoro a valore."
          variant="dashboard"
          bullets={[
            { badge: "Live in 4 settimane.", text: "Assessment + sprint di build con prezzo definito." },
            { badge: "Lavora sui tuoi sistemi.", text: "Si integra con ATS, CRM, ERP e gestionali italiani." },
            { badge: "Garanzia ore recuperate.", text: "Se non funziona, non paghi. Rimborso o lavoriamo gratis." },
          ]}
          ctaText="Approfondisci"
          ctaHref="/recruitment"
        />

        <ServiceFeature
          eyebrow="02 · Custom Software con IA"
          title="App, dashboard e workflow su misura — alimentati da agenti."
          description="Costruiamo prodotti software completi quando l'agente da solo non basta: ATS interi, CRM custom, sistemi di intake clienti, dashboard intelligenti per il management. Architettura nostra, codice tuo."
          variant="code"
          reverse
          bullets={[
            { badge: "Web app + mobile native.", text: "Stack moderno (Next, Astro, Flutter), zero lock-in." },
            { badge: "AI integrata nel flusso.", text: "Non un chatbot bolt-on: AI come motore dei processi." },
            { badge: "Owned codebase.", text: "Repository tuo, documentazione tua, scelta di internalizzare quando vuoi." },
          ]}
        />

        <ServiceFeature
          eyebrow="03 · Mobile + Web App"
          title="Esperienze native che i tuoi clienti vogliono usare."
          description="Per i prodotti consumer e B2B abbiamo costruito app native iOS/Android e progressive web app. KB&B con StoryWonder, Linkly per gli eventi B2B, Diplotools per i ministeri."
          variant="phone"
          bullets={[
            { badge: "iOS e Android nativi.", text: "Flutter e React Native, performance e UX premium." },
            { badge: "Progressive Web App.", text: "Quando non serve un app store, un'esperienza web va meglio." },
            { badge: "Backend scalabile.", text: "Xano, Supabase, Cloudflare Workers — pagamento solo per quello che usi." },
          ]}
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. TESTIMONIALS GRID
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Cosa dicono di noi"
        title="Non prendere solo la nostra parola."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {testimonials.map((t) => (
          <TestimonialCard {...t} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. CTA "Give us a shot"
       ============================================================ -->
  <CTABanner
    title="Dacci una possibilità."
    description="Un'ora di call con il CEO, zero pitch commerciale. Se non ti convince, ti abbiamo solo rubato 60 minuti."
    ctaText="Prenota la call"
    ctaHref="#contact"
    avatarName="Daniel Levis"
    avatarRole="Co-Founder & CEO"
  />

  <!-- ============================================================
       8. GLOBAL REACH + STATS
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Reach globale"
        title="Reach globale, impatto locale."
        subtitle="Siamo basati a Biella, in Piemonte. Ma lavoriamo con clienti in mezza Europa, Nord e Sud America."
        align="center"
      />

      <WorldMap dots={worldDots} />

      <!-- Stats bar -->
      <div class="mt-20 grid grid-cols-3 gap-px bg-ink-200 rounded-3xl overflow-hidden max-w-4xl mx-auto reveal">
        <div class="bg-white p-8 md:p-10 text-center">
          <p class="font-display text-[3rem] md:text-[4rem] font-semibold tracking-tight leading-none text-gradient-violet">30+</p>
          <p class="mt-3 text-sm font-medium text-ink-900">Clienti felici</p>
        </div>
        <div class="bg-white p-8 md:p-10 text-center">
          <p class="font-display text-[3rem] md:text-[4rem] font-semibold tracking-tight leading-none text-gradient-violet">50+</p>
          <p class="mt-3 text-sm font-medium text-ink-900">Progetti completati</p>
        </div>
        <div class="bg-white p-8 md:p-10 text-center">
          <p class="font-display text-[3rem] md:text-[4rem] font-semibold tracking-tight leading-none text-gradient-violet">8</p>
          <p class="mt-3 text-sm font-medium text-ink-900">Paesi serviti</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       9. FEATURED TESTIMONIAL
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center reveal">
          <div class="md:col-span-4 flex justify-center md:justify-start">
            <div class="relative">
              <AvatarCircle name="Annamaria Russo" size="xl" variant="violet" />
              <div class="absolute -inset-3 rounded-full border border-violet-200 -z-10"></div>
              <div class="absolute -inset-6 rounded-full border border-violet-100 -z-10"></div>
            </div>
          </div>
          <div class="md:col-span-8">
            <div class="flex gap-1 mb-5 text-amber">
              {[1,2,3,4,5].map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p class="font-display text-[1.5rem] md:text-[2rem] font-semibold text-ink-900 leading-[1.2] text-balance">
              "Avevamo un sistema in cui i nostri operatori passavano metà del tempo a smistare richieste. Oggi un agente IA le qualifica al primo contatto, riassume, decide a chi assegnarle. Il team fa il salto di qualità che cercavamo."
            </p>
            <p class="mt-6 font-semibold text-ink-900">Annamaria Russo</p>
            <p class="text-sm text-ink-500 mt-0.5">Operations Lead · Pro Tier</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       10. TECH STACK
       ============================================================ -->
  <section class="section bg-ink-50 border-y border-ink-200">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Tech stack"
        title="Potente, scalabile, sicuro, conforme."
        subtitle="Lavoriamo con i modelli e le piattaforme migliori del mondo IA. Stack europeo dove serve, vendor-neutral per default."
        align="center"
      />
      <PartnersStrip partners={partners} />
    </div>
  </section>

  <!-- ============================================================
       11. SECOND FEATURED TESTIMONIAL
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center reveal">
          <div class="md:col-span-8 md:order-2">
            <p class="font-display text-[1.5rem] md:text-[2rem] font-semibold text-ink-900 leading-[1.2] text-balance">
              "Il mio sogno per quest'anno è diventato realtà: siamo felici di avere voi dalla nostra parte e questo è il tipo di prodotto che vogliamo costruire nelle nostre mani."
            </p>
            <p class="mt-6 font-semibold text-ink-900">Rolf Kowalewski</p>
            <p class="text-sm text-ink-500 mt-0.5">CEO & Founder · KB&B Family Marketing</p>
          </div>
          <div class="md:col-span-4 md:order-1 flex justify-center md:justify-start">
            <div class="relative">
              <AvatarCircle name="Rolf Kowalewski" size="xl" variant="lilac" />
              <div class="absolute -inset-3 rounded-full border border-violet-200 -z-10"></div>
              <div class="absolute -inset-6 rounded-full border border-violet-100 -z-10"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       12. TEAM GRID
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Il team"
        title="Le persone con cui lavorerai."
        subtitle="Un team distribuito tra Italia, Tunisia, Germania, Francia e Argentina. Italiano, inglese, francese e spagnolo nativi."
        align="center"
      />

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {team.map((m) => (
          <TeamMemberCard {...m} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       13. CONTACT FORM
       ============================================================ -->
  <section id="contact" class="section bg-violet-mesh">
    <div class="container-soraia">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-32">
          <p class="eyebrow mb-6">Parliamone</p>
          <h2 class="font-display text-[2.5rem] md:text-[3.5rem] font-semibold tracking-tight text-ink-900 leading-[1.05] text-balance">
