---
import Layout from "~/layouts/Layout.astro";
import AnnouncementBar from "~/components/AnnouncementBar.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import MetricsBar from "~/components/MetricsBar.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ProofBar from "~/components/ProofBar.astro";
import CaseStudyCard from "~/components/CaseStudyCard.astro";
import SectorsGrid from "~/components/SectorsGrid.astro";
import TrustGrid from "~/components/TrustGrid.astro";
import PartnersStrip from "~/components/PartnersStrip.astro";
import AskAISection from "~/components/AskAISection.astro";
import CheckIcon from "~/components/CheckIcon.astro";
import LeadForm from "~/components/LeadForm.tsx";

const title = "Soraia — Portiamo gli Agenti IA nelle PMI Italiane";
const description =
  "Non software che il tuo team deve imparare a usare. Agenti IA che eseguono i tuoi processi. Misuriamo il tempo recuperato, se non funziona, non paghi.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Soraia",
  url: "https://www.soraia.io",
  logo: "https://www.soraia.io/logos/soraia-full.svg",
  description,
  email: "hello@soraia.io",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Biella",
    addressCountry: "IT",
  },
  sameAs: [
    "https://www.linkedin.com/company/soraia-io",
  ],
};

const metrics = [
  { value: "30+", label: "Clienti tra Italia, Spagna, UK, USA", detail: "Recruitment, accounting, marketing, real estate, govtech" },
  { value: "4", label: "Settimane dall'assessment al primo agente live", detail: "Non 12 mesi di roadmap" },
  { value: "€360k", label: "Risparmio annuo per APraise", detail: "Recruitment internazionale, agenti su screening + outreach" },
  { value: "750h", label: "Ore liberate ogni anno per KB&B", detail: "Marketing agency, agenti su content e publishing" },
];

const homeLogos = [
  { name: "APraise", src: "/logos/clients/apraise.png" },
  { name: "OggiLavoro", src: "/logos/clients/oggilavoro.png" },
  { name: "Numeraria", src: "/logos/clients/numeraria.png" },
  { name: "Rainplan", src: "/logos/clients/rainplan.png" },
  { name: "Aegis Group", src: "/logos/clients/aegisgroup.svg" },
  { name: "CXL", src: "/logos/clients/cxl.jpg" },
  { name: "Stars Be Original", src: "/logos/clients/starsbeoriginal.png" },
  { name: "Talent Match" },
  { name: "KB&B" },
  { name: "Winter Immobilier" },
  { name: "French Riviera Househunting" },
];

const processSteps = [
  {
    number: "01",
    title: "Assessment — 2.000€",
    description:
      "1–2 settimane. Mappiamo i processi reali, definiamo la baseline misurabile, identifichiamo dove gli agenti producono ore liberate entro 4 settimane. Esce un report concreto con perimetro e numeri.",
    icon: "compass" as const,
  },
  {
    number: "02",
    title: "Build sprint — 4 settimane",
    description:
      "Costruiamo gli agenti, li integriamo nei tuoi sistemi (ATS, ERP, CRM, gestionali), li portiamo in produzione. Settimana 4: stanno già lavorando. 10–50k€ a seconda di quanti processi copri.",
    icon: "match" as const,
  },
  {
    number: "03",
    title: "Adozione e scala — 30 giorni di affiancamento",
    description:
      "Training del tuo team, misurazione delle ore recuperate sulla baseline, refinement degli agenti. Se vuoi, estendiamo a nuovi processi. Codice tuo dalla prima settimana.",
    icon: "outreach" as const,
  },
];

const cases = [
  {
    client: "APraise",
    industry: "Recruitment internazionale",
    metric: "€360k",
    metricLabel: "Risparmio annuo",
    description:
      "19 giorni-uomo recuperati ogni settimana. Agenti IA su screening CV, contatto candidati e qualifica. Zero nuove assunzioni.",
  },
  {
    client: "Numeraria",
    industry: "Studio commercialisti · Piemonte",
    metric: "€32k",
    metricLabel: "Risparmio mensile",
    description:
      "Agenti IA su onboarding clienti, riconciliazioni e preparazione documenti standard. +25% di produttività sul team commercialisti.",
  },
  {
    client: "KB&B",
    industry: "Marketing agency · Kids brands",
    metric: "750h",
    metricLabel: "Liberate ogni anno",
    description:
      "Workflow IA per content creation e publishing social. Il team creativo torna a fare creatività, non operativa ripetitiva.",
  },
  {
    client: "Startup GovTech",
    industry: "Piattaforma per ministeri · Svizzera",
    metric: "2h+",
    metricLabel: "Recuperate ogni giorno",
    description:
      "Agenti IA su tracking elezioni, gestione reciprocità diplomatiche, automazione workflow. Compliance gov-grade end-to-end.",
  },
];

const sectors = [
  {
    name: "Recruitment & Staffing",
    description: "Agenzie e APL — screening, outreach, matching, scheduling, BD.",
    href: "/recruitment",
    available: true,
    icon: "users" as const,
  },
  {
    name: "Studi professionali",
    description: "Commercialisti, avvocati, consulenti — onboarding, riconciliazioni, doc prep.",
    available: false,
    icon: "briefcase" as const,
  },
  {
    name: "Marketing & Content",
    description: "Agenzie e team interni — creazione, qualifica, publishing, reporting.",
    available: false,
    icon: "chart" as const,
  },
  {
    name: "Real Estate & Immobiliare",
    description: "Agenzie luxury e tradizionali — qualifica lead, CRM intelligence, follow-up.",
    available: false,
    icon: "home" as const,
  },
  {
    name: "Green Tech & Energy",
    description: "MVP, validazione modelli, automazione back-office su piattaforme green.",
    available: false,
    icon: "leaf" as const,
  },
  {
    name: "Eventi & Tradeshow",
    description: "Cattura, qualifica, attivazione e analisi ROI dei lead da fiere.",
    available: false,
    icon: "calendar" as const,
  },
  {
    name: "Healthcare & Pharma",
    description: "Cliniche, distributori — CRM, automazione amministrativa, intake paziente.",
    available: false,
    icon: "heart" as const,
  },
  {
    name: "GovTech & Compliance",
    description: "Sistemi gov-grade — audit log, retention, conformità AI Act + GDPR.",
    available: false,
    icon: "shield" as const,
  },
];

const trustItems = [
  {
    title: "Conformità GDPR",
    description:
      "Processi, integrazioni e agenti progettati in conformità con il GDPR. Niente training su dati tuoi, niente trasferimenti extra-UE non autorizzati.",
    icon: "shield" as const,
  },
  {
    title: "Conformità AI Act",
    description:
      "Allineamento al Regolamento europeo sull'IA. Classificazione del rischio per ogni agente, documentazione tecnica, supervisione umana sui processi critici.",
    icon: "scale" as const,
  },
  {
    title: "Dati in Europa",
    description:
      "Infrastruttura cloud europea per default (Cloudflare, AWS Frankfurt). Hosting dedicato e on-premise disponibili per settori regolamentati.",
    icon: "globe" as const,
  },
  {
    title: "Log e audit trail",
    description:
      "Ogni decisione e azione degli agenti è tracciata. Log completi, replay del ragionamento, audit pronto per ispezioni interne e regolatori.",
    icon: "eye" as const,
  },
  {
    title: "DPO esterno",
    description:
      "Lavoriamo con Data Protection Officer esterni per governance sui dati. Valutazioni d'impatto (DPIA) quando il caso d'uso lo richiede.",
    icon: "user-shield" as const,
  },
  {
    title: "Codice tuo, no lock-in",
    description:
      "Il codice degli agenti è tuo dalla prima settimana. Documentazione completa, training per internalizzare. Niente licenze mensili perpetue.",
    icon: "lock" as const,
  },
];

const partners = [
  { name: "Anthropic", src: "/logos/tools/anthropic.svg", category: "Modelli IA" },
  { name: "OpenAI", src: "/logos/tools/openai.svg", category: "Modelli IA" },
  { name: "Google", src: "/logos/tools/google.svg", category: "Workspace · IA" },
  { name: "Make", src: "/logos/tools/make.svg", category: "Workflow" },
  { name: "n8n", src: "/logos/tools/n8n.svg", category: "Workflow" },
  { name: "Xano", src: "/logos/tools/xano.svg", category: "Backend" },
  { name: "WeWeb", src: "/logos/tools/weweb.svg", category: "Frontend" },
  { name: "Cloudflare", src: "/logos/tools/cloudflare.svg", category: "Infra" },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <AnnouncementBar
    text="Se non funziona, non paghi. Garanzia inclusa in ogni sprint Soraia."
    ctaText="Come funziona"
    ctaHref="#garanzia"
  />

  <!-- ============================================================
       HERO — Editorial premium
       ============================================================ -->
  <section class="bg-violet-radial relative overflow-hidden">
    <!-- Floating orbs -->
    <div class="orb orb-violet w-[600px] h-[600px] -right-48 -top-24 float-slow opacity-60" aria-hidden="true"></div>
    <div class="orb orb-lilac w-[500px] h-[500px] -left-40 top-1/2 float-slower opacity-70" aria-hidden="true"></div>
    <div class="orb orb-amber w-[300px] h-[300px] right-1/3 bottom-0 float-slow opacity-40" aria-hidden="true" style="animation-delay: -7s"></div>

    <div class="container-soraia pt-20 pb-24 md:pt-28 md:pb-36 lg:pt-36 lg:pb-44 relative z-10">
      <div class="max-w-[1100px]">
        <p class="eyebrow mb-8 fade-up">
          AI Agency · PMI italiane
        </p>

        <h1 class="font-display text-[3.25rem] sm:text-[4.75rem] md:text-[6rem] lg:text-[7.75rem] font-semibold tracking-[-0.045em] leading-[0.94] text-ink-900 fade-up fade-up-delay-1 text-balance">
          Portiamo gli <em class="not-italic text-gradient-violet">Agenti IA</em> nelle PMI Italiane.
        </h1>

        <div class="mt-12 grid grid-cols-1 lg:grid-cols-12 gap-x-12 gap-y-10 items-end">
          <p class="lg:col-span-7 text-[18px] md:text-[20px] text-ink-700 leading-[1.55] max-w-2xl fade-up fade-up-delay-2 text-pretty">
            Non software che il tuo team deve imparare a usare. <strong class="text-ink-900">Agenti IA che eseguono i tuoi processi.</strong> Misuriamo il tempo recuperato &mdash; se non funziona, non paghi.
          </p>

          <div class="lg:col-span-5 flex flex-col sm:flex-row lg:flex-col xl:flex-row gap-3 fade-up fade-up-delay-3 lg:justify-end">
            <a href="#contact" class="btn btn-primary">
              Prenota un assessment
              <span class="btn-arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 5l7 7-7 7"/>
                </svg>
              </span>
            </a>
            <a href="#servizi" class="btn btn-secondary">
              Come funziona
            </a>
          </div>
        </div>

        <div class="mt-16 md:mt-20 hairline fade-up fade-up-delay-4"></div>

        <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-y-4 gap-x-10 text-[13px] fade-up fade-up-delay-4">
          <div class="flex items-baseline gap-3">
            <span class="font-display text-[28px] font-semibold text-gradient-violet leading-none">30+</span>
            <span class="text-ink-600">clienti in IT, ES, UK, USA</span>
          </div>
          <div class="flex items-baseline gap-3">
            <span class="font-display text-[28px] font-semibold text-gradient-violet leading-none">4</span>
            <span class="text-ink-600">settimane al primo agente live</span>
          </div>
          <div class="flex items-baseline gap-3">
            <span class="font-display text-[28px] font-semibold text-gradient-violet leading-none">100%</span>
            <span class="text-ink-600">conformità GDPR + AI Act</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <a href="#servizi" class="hidden md:flex absolute bottom-8 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-ink-500 hover:text-ink-900 transition-colors group z-10" aria-label="Scroll">
      <span class="text-[10px] uppercase tracking-[0.18em] font-semibold">Scorri</span>
      <span class="w-[1px] h-10 bg-gradient-to-b from-ink-400 to-transparent group-hover:from-violet-600 transition-colors"></span>
    </a>
  </section>

  <!-- ============================================================
       METRICS
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Risultati"
        title="L'impatto reale sui nostri clienti"
        subtitle="Numeri veri, non statistiche di marketing. Ogni metrica viene da un caso cliente che possiamo raccontarti in dettaglio."
      />
      <MetricsBar metrics={metrics} />
    </div>
  </section>

  <!-- ============================================================
       PROOF BAR
       ============================================================ -->
  <ProofBar
    label="Ci hanno già scelto"
    logos={homeLogos}
  />

  <!-- ============================================================
       SERVIZI / COME FUNZIONA
       ============================================================ -->
  <section id="servizi" class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Come funziona"
        title="Dall'assessment all'agente in produzione in 6 settimane"
        subtitle="Un percorso lineare con prezzi definiti, garanzia inclusa e nessun lock-in. Non vendiamo trasformazione. Vendiamo ore liberate."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {processSteps.map((s) => (
          <ProcessCard {...s} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       CASE STUDY
       ============================================================ -->
  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Casi studio"
        title="Storie di agenti che lavorano davvero"
        subtitle="Cosa abbiamo costruito per agenzie di recruitment, studi professionali, marketing e tech in produzione."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {cases.map((c) => (
          <CaseStudyCard {...c} />
        ))}
      </div>

      <p class="mt-10 text-center text-ink-600">
        Altri clienti: <strong class="text-ink-900">Aegis Group</strong>, <strong class="text-ink-900">Talent Match</strong>, <strong class="text-ink-900">OggiLavoro</strong>, <strong class="text-ink-900">Winter Immobilier</strong>, <strong class="text-ink-900">French Riviera Househunting</strong>, <strong class="text-ink-900">Rainplan</strong>, <strong class="text-ink-900">CXL</strong>, <strong class="text-ink-900">Stars Be Original</strong>.
      </p>
    </div>
  </section>

  <!-- ============================================================
       SETTORI
       ============================================================ -->
  <section id="settori" class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Settori"
        title="Lavoriamo in tutti i settori, con focus sui processi ripetitivi a basso valore"
        subtitle="Iniziamo dal Recruitment perché abbiamo cinque casi solidi. Per gli altri settori abbiamo già lavorato — le pagine dedicate arrivano nelle prossime settimane."
      />
      <SectorsGrid sectors={sectors} />
    </div>
  </section>

  <!-- ============================================================
       GARANZIA — editorial dark
       ============================================================ -->
  <section id="garanzia" class="section bg-ink-900 relative overflow-hidden">
    <div class="orb orb-violet w-[700px] h-[700px] -top-32 -right-32 opacity-50 float-slow" aria-hidden="true"></div>
    <div class="orb orb-amber w-[400px] h-[400px] -bottom-20 left-1/4 opacity-30 float-slower" aria-hidden="true"></div>

    <div class="container-soraia relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-end">
        <div class="lg:col-span-8 reveal">
          <p class="eyebrow eyebrow-light mb-8">La nostra garanzia</p>

          <h2 class="font-display text-[3rem] sm:text-[4rem] md:text-[5.5rem] font-semibold tracking-[-0.04em] leading-[0.95] text-white text-balance">
            <span class="text-gradient-violet">5–8 ore</span> a settimana per persona.
            <span class="block text-white/40 font-light">Recuperate in 4 settimane. O rimborso.</span>
          </h2>

          <p class="mt-10 text-[18px] md:text-[20px] text-white/70 leading-relaxed max-w-2xl text-pretty">
            Le misuriamo sulla baseline definita insieme in assessment. Se non ci arriviamo, lavoriamo gratis finché non succede &mdash; oppure ti rimborsiamo lo sprint.
          </p>
        </div>

        <ul class="lg:col-span-4 space-y-5 reveal reveal-delay-2">
          <li class="flex items-start gap-4 text-white/90 pb-5 border-b border-white/10">
            <span class="font-display text-2xl font-semibold text-violet-300 leading-none">01</span>
            <span class="text-[15px] leading-relaxed">Baseline misurata <strong class="text-white">insieme</strong>, perimetro chiaro</span>
          </li>
          <li class="flex items-start gap-4 text-white/90 pb-5 border-b border-white/10">
            <span class="font-display text-2xl font-semibold text-violet-300 leading-none">02</span>
            <span class="text-[15px] leading-relaxed">30 giorni di affiancamento <strong class="text-white">inclusi</strong> dopo il deploy</span>
          </li>
          <li class="flex items-start gap-4 text-white/90 pb-5 border-b border-white/10">
            <span class="font-display text-2xl font-semibold text-violet-300 leading-none">03</span>
            <span class="text-[15px] leading-relaxed">Se le ore non si vedono, <strong class="text-white">rimborsiamo</strong></span>
          </li>
          <li class="flex items-start gap-4 text-white/90">
            <span class="font-display text-2xl font-semibold text-violet-300 leading-none">04</span>
            <span class="text-[15px] leading-relaxed">Niente lock-in, niente abbonamenti perpetui</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRUST & SECURITY
       ============================================================ -->
  <section class="section bg-violet-50/30">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Sicurezza e conformità"
        title="La protezione dei dati è un vincolo di progetto, non un'opzione"
        subtitle="Operiamo in settori regolamentati &mdash; recruitment, govtech, finance, healthcare. Ogni agente è progettato per stare dentro le regole, oggi e quando le regole cambieranno."
      />
      <TrustGrid items={trustItems} />
    </div>
  </section>

  <!-- ============================================================
       PARTNERS
       ============================================================ -->
  <section class="section bg-white border-y border-ink-200">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Stack tecnologico"
        title="Costruiamo sui modelli e sulle piattaforme migliori del mondo IA"
        align="center"
      />
      <PartnersStrip partners={partners} />
    </div>
  </section>

  <!-- ============================================================
       FORM / PARLIAMONE
       ============================================================ -->
  <section id="contact" class="section bg-violet-mesh">
    <div class="container-soraia">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-32">
          <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-violet-200 text-violet-700 text-xs font-semibold uppercase tracking-[0.14em] mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-600"></span>
            Parliamone
          </p>
          <h2 class="text-h1 md:text-display-3 font-bold tracking-tight text-ink-900 leading-[1.1]">
            Pronto a vedere<br />quanto puoi recuperare?
          </h2>
          <p class="mt-5 text-body-lg text-ink-700 leading-relaxed">
            Raccontaci la tua realtà operativa. Ti rispondiamo entro 24 ore con una proposta di assessment concreta, perimetrata sul tuo settore.
          </p>
          <ul class="mt-8 space-y-4">
            <li class="flex items-start gap-3">
              <CheckIcon variant="violet" />
              <span class="text-ink-700"><strong class="text-ink-900">Assessment 2.000€</strong>, rimborsato se procedi</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckIcon variant="violet" />
              <span class="text-ink-700">Risposta entro <strong class="text-ink-900">24 ore</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <CheckIcon variant="violet" />
              <span class="text-ink-700">Nessun impegno a procedere</span>
            </li>
          </ul>
        </div>

        <div class="lg:col-span-7">
          <LeadForm client:load lang="it" source="home" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       ASK AI (GEO)
       ============================================================ -->
  <AskAISection lang="it" />
</Layout>
