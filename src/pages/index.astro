  { name: "Daniel Levis", role: "Co-Founder & CEO", flag: "🇮🇹", photoSrc: "/team/daniel-levis.png" },
  { name: "Davide Silvestri", role: "Co-Founder & CTO", flag: "🇮🇹", photoSrc: "/team/davide-silvestri.png" },
  { name: "Eleonora Cogo", role: "Project Manager", flag: "🇮🇹", photoSrc: "/team/eleonora-cogo.png" },
