      { flag: "🇺🇸", name: "USA", count: 3 },
      { flag: "🇨🇦", name: "Canada", count: 2 },
    ],
    align: "left" as const,
  },
  {
    x: 64, y: 50,
    label: "Medio Oriente",
    flag: "🇦🇪",
