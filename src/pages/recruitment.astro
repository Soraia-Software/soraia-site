---
import Layout from "~/layouts/Layout.astro";
import ProofBar from "~/components/ProofBar.astro";
import CaseStudyCard from "~/components/CaseStudyCard.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";

const title = "Agenti IA per agenzie di recruitment | Soraia";
const description =
  "I tuoi recruiter dal 60% di lavoro amministrativo al 60% di tempo dedicato al closing. Agenti IA su misura, attivi in 4 settimane. Se non funziona, non paghi.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Agenti IA per Recruitment. Soraia",
    provider: {
      "@type": "Organization",
      name: "Soraia",
      url: "https://www.soraia.io",
    },
    areaServed: "IT",
    serviceType: "AI agents for recruitment agencies",
    offers: {
      "@type": "Offer",
      priceCurrency: "EUR",
      price: "2000",
      description: "Assessment iniziale 2.000€, rimborsato se procedi con lo sprint.",
    },
  },
];

const recruitmentLogos = [
  { name: "APraise", src: "/logos/clients/apraise.webp" },
  { name: "OggiLavoro", src: "/logos/clients/oggilavoro.webp" },
  { name: "Aegis Group", src: "/logos/clients/aegisgroup.webp" },
  { name: "Talent Match", src: "/logos/clients/talentmatch.webp" },
  { name: "Stars Be Original", src: "/logos/clients/starsbeoriginal.webp" },
];

const problems = [
  {
    title: "Screening manuale infinito",
    description: "Il 70% dei CV viene scartato. Ma qualcuno deve leggerli tutti. I tuoi recruiter più cari spendono lì le mattine.",
  },
  {
    title: "Contatti che non rispondono",
    description: "Outreach a candidati con tasso di risposta del 5%. Personalizzazione manuale insostenibile, automatismi base che bruciano il brand.",
  },
  {
    title: "ATS che non risolvono",
    description: "Stesse funzioni dei competitor, abbonamenti mensili che crescono, dati ostaggio del fornitore. Differenziazione zero.",
  },
];

const processes = [
  {
    number: "01",
    title: "Screening CV intelligente",
    description:
      "L'agente valuta ogni CV contro la job description, non solo per parole chiave. Classifica per fit, scarta motivando, alimenta il tuo ATS.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "Contatto candidati a scala",
    description:
      "Primo contatto personalizzato per ogni ruolo, follow-up multi-touch, qualifica chi risponde. I recruiter ricevono solo i candidati caldi.",
    icon: "outreach" as const,
  },
  {
    number: "03",
    title: "Lettura JD e shortlist",
    description:
      "L'agente legge la richiesta del cliente, estrae requisiti, scansiona DB e LinkedIn, propone una shortlist ordinata. Il recruiter sceglie, non cerca.",
    icon: "match" as const,
  },
  {
    number: "04",
    title: "Calendario colloqui automatico",
    description:
      "Coordina disponibilità tra candidato, cliente e team. Conferme, promemoria, riprogrammazioni. Zero email avanti e indietro.",
    icon: "calendar" as const,
  },
  {
    number: "05",
    title: "Sviluppo nuovi clienti",
    description:
      "L'agente identifica aziende in hiring, qualifica il fit, prepara dossier pronti per il tuo team commerciale. Pipeline alimentata in continuo.",
    icon: "compass" as const,
  },
];

const cases = [
  {
    client: "APraise",
    industry: "Executive search · 100k+ candidati",
    metric: "+19",
    metricLabel: "Giorni-uomo a settimana recuperati",
    description:
      "Flussi IA su screening, contatto candidati e qualifica. €360.000 di costo operativo recuperati ogni anno, zero nuove assunzioni.",
    href: "/case-studies/apraise",
  },
  {
    client: "Stars Be Original",
    industry: "Recruiting turistico · 20k+ candidati",
    metric: "<1min",
    metricLabel: "Tempo di risposta candidato",
    description:
      "Agente IA che risponde ai candidati al posto del team: tempo di risposta sotto il minuto, tono coerente, zero candidati persi nel funnel.",
    href: "/case-studies/stars-be-original",
  },
  {
    client: "OggiLavoro",
    industry: "APL italiana · 1000+ persone",
    metric: "250k+",
    metricLabel: "Candidati liberati dallo stack legacy",
    description:
      "Replatforming completo con agente IA di candidate search e matching. Mobile, OCR, integrazione comm tool email/SMS/WhatsApp. Sistema scalabile sull'intera agenzia.",
    href: "/case-studies/oggi-lavoro",
  },
];

const comparisonRows = [
  { label: "Costo", values: ["Basso", "Alto annuo", "Medio una tantum"] as [string, string, string] },
  { label: "Tempo a regime", values: ["Subito", "3–6 mesi", "4 settimane"] as [string, string, string] },
  { label: "Esegue task in autonomia", values: ["No", "Limitato", "Sì, end-to-end"] as [string, string, string] },
  { label: "Su misura sui tuoi processi", values: ["No", "Configurabile", "Costruito per te"] as [string, string, string] },
  { label: "Dipendenza dal fornitore", values: ["Nessuna", "Totale", "Nessuna (codice tuo)"] as [string, string, string] },
  { label: "Ore recuperate garantite", values: ["No", "No", "Sì, o rimborso"] as [string, string, string] },
];

const faqs = [
  {
    q: "Come gestite GDPR e dati candidati?",
    a: "Gli agenti girano in ambiente cloud europeo o direttamente sulla tua infrastruttura. Log di tutte le operazioni, retention configurabile, <strong>nessun addestramento sui tuoi dati</strong>.",
  },
  {
    q: "Si integra con l'ATS che già usiamo?",
    a: "Sì. Lavoriamo con Bullhorn, Bee-Staffing, Salesforce, In-Recruiting e ATS proprietari. Se hai uno strumento particolare, lo validiamo in assessment.",
  },
  {
    q: "Lingua italiana e mercato locale?",
    a: "Sì. Gli agenti sono multilingua nativi. Lavoriamo già con agenzie italiane (OggiLavoro), spagnole (Talent Match) e internazionali (APraise, Aegis Group).",
  },
  {
    q: "E se dopo voglio gestire tutto in autonomia?",
    a: "Il codice è tuo dalla prima settimana. Documentazione completa, training del tuo team se vuoi internalizzare. <strong>Nessuna dipendenza, nessuna licenza mensile.</strong>",
  },
  {
    q: "Quanto costa davvero?",
    a: "Assessment <strong>€2.000</strong> (rimborsato se procedi con lo sprint). Sprint di costruzione <strong>€10–50k</strong> a seconda di quanti processi copri. Garanzia: se gli agenti non recuperano le ore promesse, rimborsiamo.",
  },
  {
    q: "Cosa succede in 4 settimane esattamente?",
    a: "<strong>Settimana 1:</strong> discovery con il tuo team, baseline misurata. <strong>Settimane 2–3:</strong> costruzione e integrazione degli agenti. <strong>Settimana 4:</strong> deploy in produzione, formazione del team, prima misurazione. 30 giorni di affiancamento inclusi dopo il deploy.",
  },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <!-- ============================================================
       HERO. Editorial premium, dark
       ============================================================ -->
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="max-w-[900px]" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Recruitment & HR · AI Agents
        </p>

        <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
          I tuoi recruiter dal 60% admin<br/>al 60% selling.
        </h1>

        <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
          Costruiamo agenti IA che fanno il lavoro ripetitivo, screening CV, contatto candidati, lettura JD, calendario colloqui. I recruiter chiudono. Live in 4 settimane.
        </p>

        <!-- GARANZIA BADGE -->
        <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium" style="color: #F4B842;">Se non funziona, non paghi. Garanzia inclusa.</span>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
          <a href="/parliamone" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
            Richiedi assessment, €2.000
            <span class="btn-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
          <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">
            Vedi i risultati
          </a>
        </div>

        <!-- TRUST ROW -->
        <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
          <div class="inline-flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            <span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">4 settimane</strong> al primo agente live</span>
          </div>
          <div class="inline-flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            <span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">5–8h</strong> a settimana per recruiter</span>
          </div>
          <div class="inline-flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            <span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">GDPR + AI Act</strong> compliant</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROOF BAR
       ============================================================ -->
  <ProofBar
    label="Già scelti da agenzie di recruitment in Italia, Spagna e UK"
    logos={recruitmentLogos}
  />

  <!-- ============================================================
       PROBLEMA
       ============================================================ -->
  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Il problema"
        title="Più della metà del tempo dei tuoi recruiter non porta fatturato."
        subtitle="Lo sai già. L'hanno notato i tuoi competitor che hanno comprato licenze ChatGPT Enterprise. Ma tu vuoi ore liberate al mese 1, non una roadmap a 12 mesi."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
              </svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       5 PROCESSI
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="La soluzione"
        title="5 processi dove gli agenti producono ore liberate dalla settimana 4."
        subtitle="Non un software che il team deve imparare. Lavoratori digitali che eseguono task end-to-end, decidendo sul contesto come farebbe un recruiter senior."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (
          <ProcessCard {...p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       GARANZIA, editorial dark, sobrio
       ============================================================ -->
  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          La nostra garanzia
        </p>

        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          5–8 ore a settimana per recruiter.<br/><span style="color: rgba(255,255,255,0.45);">Recuperate in 4 settimane. O non paghi.</span>
        </h2>

        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          Le misuriamo sulla baseline definita insieme in assessment. Se non ci arriviamo, lavoriamo gratis finché non succede, oppure ti rimborsiamo lo sprint.
        </p>

        <p style="color: rgba(255,255,255,0.55);" class="mt-4 text-[15px] leading-relaxed max-w-2xl text-pretty">
          Funziona perché definiamo insieme baseline, perimetro e metodo di misurazione. Niente sorprese, niente sotterfugi contrattuali.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CASE STUDY
       ============================================================ -->
  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Casi studio"
        title="Cosa abbiamo già costruito per agenzie come la tua."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {cases.map((c) => (
          <CaseStudyCard {...c} />
        ))}
      </div>

      <p class="mt-10 text-center text-[14px]" style="color: var(--color-ink-muted);">
        Tra gli altri clienti recruitment: <a href="/case-studies/aegis" style="color: var(--color-brand); text-decoration: underline; text-underline-offset: 3px; font-weight: 500;">Aegis Group</a> (350k+ candidati, 7 lines holding) e <a href="/case-studies/talent-match" style="color: var(--color-brand); text-decoration: underline; text-underline-offset: 3px; font-weight: 500;">Talent Match</a> (gruppo spagnolo, 150k+ candidati).
      </p>
    </div>
  </section>

  <!-- ============================================================
       COMPARISON
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Confronto"
        title="Perché agenti IA su misura, e non altro."
        subtitle="Le tre opzioni sul tavolo per un'agenzia di recruitment oggi. Solo una è progettata sulla tua realtà."
        align="center"
      />

      <ComparisonTable
        columns={["ChatGPT / Copilot", "ATS con IA integrata", "Soraia agenti IA"]}
        rows={comparisonRows}
        highlightCol={2}
      />
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia max-w-3xl">
      <SectionHeader
        eyebrow="Domande"
        title="Quello che ci chiedono di solito."
        align="center"
      />
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ============================================================
       CTA finale → /parliamone (sobrio)
       ============================================================ -->
  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 reveal" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Prossimo passo
      </p>

      <h2 class="text-balance reveal" style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Scopri quante ore può recuperare il tuo team.
      </h2>

      <p class="mt-5 text-[17px] leading-relaxed reveal reveal-delay-1" style="color: var(--color-ink-muted);">
        Assessment €2.000, rimborsato se procedi. 1-2 settimane dall'inizio al report. Nessun impegno a procedere.
      </p>

      <div class="mt-10 reveal reveal-delay-2">
        <a href="/parliamone" class="btn btn-primary">
          Richiedi assessment
          <span class="btn-arrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>
