---
import Layout from "~/layouts/Layout.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import FAQ from "~/components/FAQ.astro";
import CTABanner from "~/components/CTABanner.astro";

const title = "AI Search Optimization | Soraia";
const description =
  "Renditi trovabile su ChatGPT, Claude, Perplexity, Google AI Overviews. Audit, re-architettura contenuti, rifacimento sito high converting e monitoring per e-commerce, retail, distribuzione B2B.";

const pillars = [
  {
    icon: "search",
    title: "Audit di visibility",
    description:
      "Mappiamo come ti citano oggi ChatGPT, Claude, Perplexity e Google AI Overviews per le query rilevanti del tuo settore. Gap analysis competitor, ranking per prompt, allucinazioni da correggere.",
  },
  {
    icon: "layers",
    title: "Re-architettura contenuti",
    description:
      "Schema.org, semantic HTML, FAQ tematiche. Riscriviamo i contenuti per renderli consumabili dagli LLM, mantenendo SEO classica e UX umana intatte.",
  },
  {
    icon: "rocket",
    title: "Rifacimento sito high converting",
    description:
      "Sito da zero ottimizzato sia per il lead (multistep form, structured data, micro-conversioni) sia per l'AI search. Sviluppato in 6-10 settimane, su stack Astro/Next.js + Cloudflare.",
  },
  {
    icon: "pulse",
    title: "Monitoring continuo",
    description:
      "Tracking mensile del posizionamento sui motori AI. Dashboard di ranking per prompt, alert su allucinazioni, iterazioni mensili sui contenuti che funzionano meno.",
  },
];

const icons = {
  search: `<circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  layers: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  rocket: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>`,
  pulse: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
};

const faqs = [
  {
    q: "Quanto costa un audit AI Search?",
    a: "Audit standalone parte da <strong>2.500€ + IVA</strong>, consegna in 2 settimane. Include mappa visibility attuale su ChatGPT, Claude, Perplexity e Google AI Overviews, gap analysis sui primi 3-5 competitor, lista prioritaria di interventi.",
  },
  {
    q: "Quanto tempo per vedere risultati sui motori AI?",
    a: "Dipende dall'autorità del dominio. <strong>Le prime citazioni su Perplexity arrivano in 2-6 settimane</strong> dalla pubblicazione dei contenuti riarchitettati. ChatGPT e Google AI Overviews richiedono 2-4 mesi per indicizzare a regime. Il monitoring mensile traccia ogni miglioramento.",
  },
  {
    q: "Devo rifare tutto il sito?",
    a: "No. Per la maggior parte dei progetti basta una <strong>re-architettura dei contenuti chiave</strong> (homepage, pagine prodotto/servizio, FAQ, blog post strategici) senza toccare l'infrastruttura. Il rifacimento sito completo lo consigliamo se hai già pianificato un redesign o se la base tecnica è obsoleta (CMS lento, no SSR, nessun structured data).",
  },
  {
    q: "Funziona anche per B2B?",
    a: "Sì, anzi è dove funziona meglio. I decision maker B2B usano <strong>sempre più spesso ChatGPT/Claude per shortlist fornitori</strong>: \"chi sono i 3 migliori X in Italia\". Se non sei nella risposta, non esisti. Vedi il case <a href='https://www.iltecbiella.it/' target='_blank' rel='noopener'>ILTEC</a>.",
  },
  {
    q: "E la SEO classica? Devo abbandonarla?",
    a: "No. La SEO classica resta importante e <strong>i nostri interventi la migliorano, non la danneggiano</strong>. Semantic HTML, schema.org, FAQ strutturate sono best practice SEO da sempre: ora servono anche agli LLM. Lavoriamo in continuità con il tuo team SEO esistente, se ne hai uno.",
  },
  {
    q: "Cosa intendete con \"high converting\"?",
    a: "Sito ottimizzato per <strong>portare lead qualificati al form</strong>, non solo per essere bello. Multistep form, structured data, social proof in posizioni chiave, micro-conversioni tracciate. Standard di settore: <strong>conversion rate da 0.5-1% a 2-4%</strong> con questa metodologia.",
  },
];

const stripTags = (html: string) => html.replace(/<[^>]+>/g, "");

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Search Optimization. Soraia",
    provider: {
      "@type": "Organization",
      name: "Soraia",
      url: "https://www.soraia.io",
    },
    areaServed: ["IT", "EU"],
    serviceType:
      "Generative engine optimization (GEO). Visibility su ChatGPT, Claude, Perplexity, Google AI Overviews.",
    description:
      "Audit, re-architettura contenuti, rifacimento sito high converting e monitoring per essere trovabili sui motori di ricerca AI.",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: stripTags(f.a),
      },
    })),
  },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="max-w-[900px]" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Visibility · Generative Engine Optimization
        </p>

        <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
          Renditi trovabile dove<br/>cercano i tuoi clienti.
        </h1>

        <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
          ChatGPT, Claude, Perplexity, Google AI Overviews. <strong style="color: #fff; font-weight: 500;">Le ricerche del 2026 non passano più solo da Google.</strong> Per chi vende online, la visibilità sui motori AI vale come la SEO classica di dieci anni fa.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
          <a href="/parliamone" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
            20 min con Daniel
            <span class="btn-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
          <a href="#audit" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">
            Vedi cosa includiamo
          </a>
        </div>

        <p class="mt-6 text-[13px] fade-up fade-up-delay-3" style="color: rgba(255,255,255,0.55);">
          Per: <strong style="color: rgba(255,255,255,0.85); font-weight: 500;">e-commerce, retail, distribuzione B2B, marketplace, professional services</strong> con traffico organico significativo.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROBLEMA
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia max-w-5xl">
      <div class="max-w-3xl mb-12 reveal">
        <p class="eyebrow mb-5">Il problema</p>
        <h2 class="text-[2rem] md:text-[2.75rem] font-semibold tracking-tight text-ink-900 leading-[1.1] text-balance">
          Il primo touchpoint del tuo cliente B2B non è più Google.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 reveal reveal-delay-1">
        <div class="bg-white rounded-xl p-7 border border-line">
          <p class="text-[2.5rem] md:text-[3rem] font-semibold tracking-tight text-violet-700 leading-none mb-4">60%</p>
          <p class="text-[14.5px] text-ink-700 leading-relaxed text-pretty">
            delle ricerche su Google nel 2025 sono <strong class="text-ink-900">zero-click</strong>: l'utente trova la risposta senza visitare nessun sito. Gli AI Overviews stanno accelerando questo trend.
          </p>
        </div>
        <div class="bg-white rounded-xl p-7 border border-line">
          <p class="text-[2.5rem] md:text-[3rem] font-semibold tracking-tight text-violet-700 leading-none mb-4">+1.300%</p>
          <p class="text-[14.5px] text-ink-700 leading-relaxed text-pretty">
            di crescita traffico da ChatGPT verso siti web nel 2025. <strong class="text-ink-900">Perplexity, Claude, Gemini</strong> stanno seguendo la stessa curva.
          </p>
        </div>
        <div class="bg-white rounded-xl p-7 border border-line">
          <p class="text-[2.5rem] md:text-[3rem] font-semibold tracking-tight text-violet-700 leading-none mb-4">3</p>
          <p class="text-[14.5px] text-ink-700 leading-relaxed text-pretty">
            citazioni medie per risposta degli LLM. Se non sei in quelle 3, <strong class="text-ink-900">non esisti</strong> per chi ha appena chiesto consiglio all'AI.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COSA INCLUDIAMO
       ============================================================ -->
  <section id="audit" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Cosa includiamo"
        title="Quattro interventi, modulari."
        subtitle="Puoi partire dal solo audit, o andare fino al rifacimento sito completo. Modulare, niente bundle obbligatori."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {pillars.map((p) => (
          <div class="card-editorial !p-8 md:!p-10 reveal">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-violet-700 to-violet-500 flex items-center justify-center shadow-violet mb-5">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[p.icon]} />
            </div>
            <h3 class="text-[1.35rem] md:text-[1.5rem] font-semibold tracking-tight text-ink-900 leading-tight mb-3">{p.title}</h3>
            <p class="text-[15px] text-ink-700 leading-relaxed text-pretty">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       USE CASE ILTEC
       ============================================================ -->
  <section class="section bg-violet-50/40 relative overflow-hidden border-t border-violet-100">
    <div class="container-soraia">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center max-w-6xl mx-auto">
        <div class="lg:col-span-7 reveal">
          <p class="eyebrow mb-5">Use case · ILTEC</p>
          <h2 class="text-[2rem] md:text-[2.75rem] font-semibold tracking-tight text-ink-900 leading-[1.1] text-balance mb-5">
            B2B office technology.<br class="hidden md:block"/>40+ anni, 800+ clienti.
          </h2>
          <p class="text-[16px] md:text-[17px] text-ink-700 leading-relaxed text-pretty mb-6">
            Sito rifatto da zero in 3 settimane. <strong class="text-ink-900">High converting</strong> sul lead form (multistep + structured data) e <strong class="text-ink-900">ottimizzato per AI search</strong>: schema.org, semantic HTML, FAQ tematiche, contenuti consumabili da LLM.
          </p>
          <p class="text-[15px] text-ink-700 leading-relaxed text-pretty mb-8">
            Risultato: visibilità su ChatGPT e Perplexity nelle ricerche di settore in pochi mesi, lead form con conversion rate triplicato rispetto al sito precedente.
          </p>

          <a href="https://www.iltecbiella.it/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[14.5px] font-semibold text-violet-700 hover:gap-3 transition-all">
            Visita iltecbiella.it
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </div>

        <div class="lg:col-span-5 reveal reveal-delay-1">
          <a href="https://www.iltecbiella.it/" target="_blank" rel="noopener" class="block group no-underline">
            <div class="rounded-2xl overflow-hidden bg-white shadow-violet-lg ring-1 ring-violet-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-xl">
              <div class="flex items-center gap-2 px-4 py-3 bg-ink-50 border-b border-ink-200">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-amber"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
                <span class="ml-3 text-[12px] text-ink-500 font-mono truncate">iltecbiella.it</span>
              </div>
              <div class="p-7 md:p-8">
                <div class="grid grid-cols-3 gap-4 mb-6">
                  <div>
                    <p class="text-[1.75rem] font-semibold text-violet-700 leading-none mb-1">3x</p>
                    <p class="text-[11px] text-ink-500 uppercase tracking-wider">CR form</p>
                  </div>
                  <div>
                    <p class="text-[1.75rem] font-semibold text-violet-700 leading-none mb-1">3w</p>
                    <p class="text-[11px] text-ink-500 uppercase tracking-wider">Go-live</p>
                  </div>
                  <div>
                    <p class="text-[1.75rem] font-semibold text-violet-700 leading-none mb-1">AI</p>
                    <p class="text-[11px] text-ink-500 uppercase tracking-wider">Ready</p>
                  </div>
                </div>
                <div class="flex gap-4 text-[11px] uppercase tracking-wider text-ink-500 font-semibold pt-4 border-t border-ink-100">
                  <span>B2B</span>
                  <span class="text-ink-300">·</span>
                  <span>Office Tech</span>
                  <span class="text-ink-300">·</span>
                  <span>Biella</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia max-w-4xl">
      <SectionHeader
        eyebrow="Domande frequenti"
        title="Quello che ci chiedono di solito."
        align="center"
      />
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ============================================================
       CTA FINALE
       ============================================================ -->
  <CTABanner
    title="20 minuti col CEO. Senza pitch."
    description="Capiamo insieme se ha senso fare un audit AI Search sul tuo sito. Nessun impegno, nessuna vendita."
    ctaText="20 min con Daniel"
    ctaHref="/parliamone"
    avatarName="Daniel Levis"
    avatarRole="Co-Founder & CEO"
    avatarSrc="/team/daniel-levis.png"
  />
</Layout>
