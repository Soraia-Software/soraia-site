---
import Layout from "~/layouts/Layout.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import PricingTwoSteps from "~/components/PricingTwoSteps.astro";
import FAQ from "~/components/FAQ.astro";

const title = "AI Agents per i tuoi processi | Soraia";
const description =
  "Agenti IA su misura per sei aree ad alto impatto delle PMI italiane. AI Readiness Assessment a 2.000€, Co-Building Sprint a 10-50k. Prima delivery in 4 settimane, paghi solo se sei soddisfatto.";

const areas = [
  {
    eyebrow: "Talent Ops",
    title: "Recruitment & HR",
    description:
      "Per agenzie di selezione, APL, recruiter interni. Agenti che gestiscono il flusso candidato-cliente end-to-end e restituiscono ore al lavoro di valore.",
    tasks: [
      "Screening CV intelligente (fit JD, non keyword match)",
      "Contatto candidati personalizzato a scala",
      "Parsing JD + shortlist automatica dal tuo database",
      "Calendario colloqui autonomo (candidato + cliente + team)",
      "BD prospecting su aziende in hiring spike",
    ],
    proof: "APraise: 100k+ candidati gestiti dall'agente IA. Come avere 4 recruiter in più, senza il costo.",
    href: "/recruitment",
    available: true,
    icon: "users",
    priceHint: "Sprint €10-50k · 4 settimane al go-live",
  },
  {
    eyebrow: "Finance Ops",
    title: "Finance & Document Automation",
    description:
      "Per studi commercialisti, CFO di PMI, team finance. Agenti su riconciliazioni, intake documenti, preparazione report e fatturazione.",
    tasks: [
      "Riconciliazioni bancarie automatiche",
      "Estrazione dati da PDF/fatture/contratti",
      "Onboarding clienti standardizzato",
      "Generazione report ricorrenti senza copia-incolla",
      "Calcolo competenze e provvigioni automatiche",
    ],
    proof: "Numeraria: metà mese restituito al management, multi-divisione unificata.",
    href: "/finance",
    available: true,
    icon: "briefcase",
    priceHint: "Sprint €10-50k · 4 settimane al go-live",
  },
  {
    eyebrow: "Revenue Ops",
    title: "Sales & Marketing Automation",
    description:
      "Per team commerciali, agenzie di marketing, content team. Agenti che qualificano lead, generano e pubblicano contenuti, alimentano la pipeline.",
    tasks: [
      "Lead qualifica e arricchimento dati",
      "Generazione articoli e contenuti social",
      "Publishing multi-canale (LinkedIn, IG, blog)",
      "Outreach personalizzato a scala",
      "Reporting performance senza dashboards manuali",
    ],
    proof: "ILTEC: sito rifatto in 3 settimane, AI search optimized + AI agent per assistenza tecnica/commerciale dal QR code.",
    href: "/sales-marketing",
    available: true,
    icon: "chart",
    priceHint: "Sprint €10-50k · 4 settimane al go-live",
  },
  {
    eyebrow: "Customer Ops",
    title: "Customer & Compliance Automation",
    description:
      "Per customer ops, moderation, compliance. Agenti che smistano richieste, moderano contenuti utente, mantengono audit trail completi.",
    tasks: [
      "Triage automatico ticket / richieste / email",
      "Moderazione contenuti UGC con accuracy >90%",
      "Verifica conformità (GDPR, AI Act, settoriali)",
      "Log e audit trail di ogni decisione",
      "Routing intelligente al team giusto",
    ],
    proof: "Navily: -70% tempo operativo su moderazione ed enrichment. Il team torna sul prodotto.",
    href: "/customer-support",
    available: true,
    icon: "shield",
    priceHint: "Sprint €10-50k · 4 settimane al go-live",
  },
  {
    eyebrow: "Event Ops",
    title: "Event Management",
    description:
      "Per chi va in fiera, espositori, eventi B2B. 6 agenti IA che catturano i biglietti, qualificano i lead, fanno follow-up dal tuo dominio.",
    tasks: [
      "OCR su biglietti da visita, badge, QR",
      "Enrichment da 30+ fonti dati",
      "Qualifica dinamica per fiera",
      "Attivazione CRM in pochi secondi",
      "Analytics + demografia presenti allo stand",
    ],
    proof: "6 agenti orchestrati, follow-up dal dominio aziendale in pochi secondi.",
    href: "/event-management",
    available: true,
    icon: "ticket",
    priceHint: "Linkly SaaS · €1.900/anno early adopter",
  },
  {
    eyebrow: "Property Ops",
    title: "Real Estate Operations",
    description:
      "Per agenzie immobiliari, property manager, real estate tech. Agenti che catturano immobili, qualificano lead, generano dossier e gestiscono approvazioni multi-stakeholder.",
    tasks: [
      "Capture immobili da listing con 1 click",
      "Enrichment immobile (zoning, geo, foto, planimetria)",
      "Match automatico immobile-cliente sul portale",
      "Dossier comparativi pronti per il cliente",
      "Pipeline approvazioni multi-stakeholder",
    ],
    proof: "FRH: 2 agenti per lead qualificati + immobili catturati con 1 click. Rainplan: centinaia di parcel e approvazioni multi-stakeholder in autonomia.",
    href: "/real-estate",
    available: true,
    icon: "building",
    priceHint: "Sprint €10-50k · 4 settimane al go-live",
  },
];

const icons = {
  users: `<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>`,
  briefcase: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>`,
  chart: `<path d="M3 3v18h18"/><path d="M7 12l4-4 4 4 5-5"/>`,
  shield: `<path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>`,
  ticket: `<path d="M3 7v2a2 2 0 0 1 0 4v2a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2a2 2 0 0 1 0-4V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"/><line x1="13" y1="5" x2="13" y2="19"/>`,
  building: `<rect x="4" y="2" width="16" height="20" rx="2"/><line x1="9" y1="22" x2="9" y2="18"/><line x1="15" y1="22" x2="15" y2="18"/><line x1="8" y1="6" x2="10" y2="6"/><line x1="14" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="14" y1="14" x2="16" y2="14"/>`,
};

const faqs = [
  {
    q: "Cosa significa esattamente \"agente IA\"?",
    a: "Un agente IA è un software che esegue compiti in autonomia: legge dati, prende decisioni e agisce sui tuoi sistemi (ATS, CRM, gestionale). Non è ChatGPT che ti suggerisce risposte, è un lavoratore digitale che <strong>fa il lavoro</strong> al posto del tuo team sui processi che voi scegliete.",
  },
  {
    q: "Su quali sistemi si integra?",
    a: "Bullhorn, Salesforce, Bee-Staffing, In-Recruiting, Odoo, Fatture in Cloud, HubSpot, Pipedrive, gestionali italiani legacy, ATS proprietari. Se hai uno strumento custom, lo validiamo in assessment.",
  },
  {
    q: "Quanto tempo per vedere risultati?",
    a: "<strong>4 settimane dal go al primo agente in produzione.</strong> Settimana 1 discovery e baseline. Settimane 2-3 build. Settimana 4 deploy + training del team + prima misurazione. <strong>30 giorni di hypercare inclusi</strong> dopo il go-live.",
  },
  {
    q: "Cosa intendete con \"paghi solo se sei soddisfatto\"?",
    a: "Lo sprint ha un target chiaro definito in assessment (es: <em>agente di screening CV che recupera 5h/recruiter/settimana</em>). Se al go-live + 30gg di hypercare il target non è raggiunto, lavoriamo gratis finché non succede, oppure ti rimborsiamo lo sprint. <strong>Nessun cavillo contrattuale.</strong>",
  },
  {
    q: "Come gestite GDPR, AI Act e dati sensibili?",
    a: "Agenti in ambiente cloud europeo o on-premise sulla tua infrastruttura. <strong>Nessun training sui tuoi dati</strong>. Log completi di ogni decisione, DPO esterno per le valutazioni d'impatto, allineamento al Regolamento europeo IA.",
  },
  {
    q: "Cosa succede se voglio internalizzare dopo?",
    a: "<strong>Il codice è tuo dalla prima settimana.</strong> Documentazione completa, training del tuo team se vuoi gestire in autonomia. Niente abbonamenti perpetui, niente lock-in.",
  },
];

const stripTags = (html: string) => html.replace(/<[^>]+>/g, "");

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "AI Agents per PMI. Soraia",
    provider: {
      "@type": "Organization",
      name: "Soraia",
      url: "https://www.soraia.io",
    },
    areaServed: ["IT", "EU"],
    serviceType: "Custom AI agents for SME processes",
    offers: [
      {
        "@type": "Offer",
        name: "AI Readiness Assessment",
        priceCurrency: "EUR",
        price: "2000",
        description: "Assessment 1-2 settimane, rimborsato se procedi con lo sprint.",
      },
      {
        "@type": "Offer",
        name: "Co-Building & Adoption Sprint",
        priceCurrency: "EUR",
        description: "Sprint 10-50k, prima delivery in 4 settimane. Paghi solo se sei soddisfatto.",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: stripTags(f.a),
      },
    })),
  },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <!-- ============================================================
       HERO. Editorial premium AI Agents
       ============================================================ -->
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="max-w-[900px]" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          Processi · AI Agents
        </p>

        <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
          Agenti IA che eseguono<br/>i tuoi processi.
        </h1>

        <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
          Prima delivery in 4 settimane. <strong style="color: #fff; font-weight: 500;">40+ PMI italiane</strong> usano già i nostri agenti per recuperare <strong style="color: #fff; font-weight: 500;">5-19 ore a settimana per persona</strong>, senza assumere.
        </p>

        <!-- GARANZIA BADGE -->
        <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium" style="color: #F4B842;">Paghi solo se sei soddisfatto. Garanzia inclusa.</span>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
          <a href="/parliamone" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
            20 min con Daniel
            <span class="btn-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
          <a href="/downloads/ai-assessment-sample" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40 inline-flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Scarica report di esempio
          </a>
        </div>

        <!-- Anchor scroll to offerta -->
        <a href="#come-iniziamo" class="mt-6 inline-flex items-center gap-1.5 text-[13px] fade-up fade-up-delay-3" style="color: rgba(255,255,255,0.55);">
          Oppure scorri per vedere l'offerta completa
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12l-7 7-7-7M12 5v14"/></svg>
        </a>

        <!-- Trust strip -->
        <div class="mt-10 pt-8 border-t fade-up fade-up-delay-3" style="border-color: rgba(255,255,255,0.12);">
          <p class="text-[10px] uppercase tracking-[0.18em] mb-3" style="color: rgba(255,255,255,0.45);">Lavorano con noi</p>
          <p class="text-[13.5px] leading-relaxed" style="color: rgba(255,255,255,0.7);">
            40+ progetti · 11 paesi · APraise · Numeraria · LIFTT · Navily · OggiLavoro · Stars Be Original
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       OFFERTA, 2 STEP PRICING
       ============================================================ -->
  <PricingTwoSteps bg="ink-50" />

  <!-- ============================================================
       COME COSTRUIAMO I TUOI AGENTI (sprint methodology)
       ============================================================ -->
  <section class="section bg-white border-t border-line">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Metodologia"
        title="Come costruiamo i tuoi agenti IA."
        subtitle="<strong>Sprint iterativi corti</strong>: ad ogni iterazione l'agente fa già qualcosa di utile in produzione. Niente progetti di 6 mesi che finiscono in un demo: vedi valore già dalla prima settimana."
        align="center"
      />

      <!-- Sprint diagram (hero visual, centered) -->
      <figure class="m-0 mt-8 max-w-[1180px] mx-auto">
        <div class="rounded-2xl bg-ink-50 border border-line px-4 py-6 md:px-8 md:py-8">
          <img
            src="/agile/sprint.webp"
            alt="Sprint iterativi: ogni ciclo consegna valore in produzione"
            loading="lazy"
            decoding="async"
            class="w-full h-auto block"
          />
        </div>
        <figcaption class="mt-3.5 text-[12.5px] text-center" style="color: var(--color-ink-soft);">
          Sprint iterativi: ad ogni ciclo l'agente è già in produzione.
        </figcaption>
      </figure>

      <!-- Sprint steps timeline 4-col -->
      <div class="mt-14 md:mt-16 max-w-6xl mx-auto">
        <ol class="sprint-timeline">
          <li class="sprint-step">
            <div class="sprint-step-head">
              <span class="sprint-num">1</span>
              <div class="sprint-step-meta">
                <p class="sprint-step-tag">Settimana 1</p>
                <p class="sprint-step-title">Discovery + baseline</p>
              </div>
            </div>
            <p class="sprint-step-body">Cronometriamo il processo target con il tuo team. Lock del <strong>metric primario unico</strong> (es. ore/persona/settimana recuperate). Senza baseline, niente garanzia.</p>
          </li>
          <li class="sprint-step">
            <div class="sprint-step-head">
              <span class="sprint-num">2</span>
              <div class="sprint-step-meta">
                <p class="sprint-step-tag">Settimane 2-3</p>
                <p class="sprint-step-title">Build dell'agente</p>
              </div>
            </div>
            <p class="sprint-step-body">Prompt engineering, integrazione con i tuoi sistemi (CRM, ATS, gestionali), regole di escalation, audit log. Review settimanali con il tuo team operativo.</p>
          </li>
          <li class="sprint-step">
            <div class="sprint-step-head">
              <span class="sprint-num">3</span>
              <div class="sprint-step-meta">
                <p class="sprint-step-tag">Settimana 4</p>
                <p class="sprint-step-title">Shadow mode + training</p>
              </div>
            </div>
            <p class="sprint-step-body">L'agente lavora in parallelo al team umano, senza ancora prendere decisioni autonome. Confronto output, fine-tuning sui criteri, formazione del team.</p>
          </li>
          <li class="sprint-step sprint-step--milestone">
            <div class="sprint-step-head">
              <span class="sprint-num sprint-num--milestone">4</span>
              <div class="sprint-step-meta">
                <p class="sprint-step-tag">Go-live + 30 gg</p>
                <p class="sprint-step-title">Hypercare e misurazione</p>
              </div>
            </div>
            <p class="sprint-step-body">L'agente passa in produzione. Monitoring attivo Soraia per 30 giorni, fix immediati sui casi limite. Al giorno 30: <strong>misurazione finale vs baseline</strong>. Se non hai recuperato le ore promesse, non paghi lo sprint.</p>
          </li>
        </ol>

        <div class="mt-12 flex justify-center">
          <div class="inline-flex items-center gap-2.5 px-5 py-3 rounded-full text-[13px] font-medium" style="background: var(--color-brand-soft); color: var(--color-brand); border: 1px solid var(--color-violet-200);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span><strong>4 settimane</strong> al primo agente live · iterazioni mensili dopo il go-live</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    /* === Sprint timeline === */
    .sprint-timeline {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      list-style: none;
      padding: 0;
      margin: 0;
      position: relative;
    }
    @media (min-width: 768px) {
      .sprint-timeline {
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem 2rem;
      }
    }
    @media (min-width: 1024px) {
      .sprint-timeline {
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
      }
      /* Connector line behind the badges, horizontal on desktop */
      .sprint-timeline::before {
        content: "";
        position: absolute;
        top: 22px;
        left: 7%;
        right: 7%;
        height: 2px;
        background: linear-gradient(to right,
          var(--color-line-strong) 0%,
          var(--color-violet-300) 50%,
          var(--color-brand) 100%);
        opacity: 0.5;
        z-index: 0;
      }
    }
    .sprint-step {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    /* Mobile: badge + meta inline (horizontal); Desktop: badge above meta (vertical) */
    .sprint-step-head {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    @media (min-width: 1024px) {
      .sprint-step-head {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.1rem;
      }
    }
    .sprint-num {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 9999px;
      background: white;
      border: 1.5px solid var(--color-violet-300);
      color: var(--color-brand);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 500;
      font-size: 1rem;
      letter-spacing: -0.01em;
      /* knock-out: enlarge the white "halo" so the connector line cuts cleanly at the badge edge */
      box-shadow: 0 0 0 8px white;
    }
    .sprint-num--milestone {
      background: var(--color-brand);
      border-color: var(--color-brand);
      color: white;
      box-shadow: 0 0 0 8px white, 0 4px 14px -4px rgba(74, 30, 92, 0.40);
    }
    .sprint-step-meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      min-width: 0;
    }
    .sprint-step-tag {
      font-size: 10.5px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ink-soft);
      line-height: 1.4;
    }
    .sprint-step-title {
      font-size: 15.5px;
      line-height: 1.25;
      letter-spacing: -0.015em;
      font-weight: 500;
      color: var(--color-ink);
    }
    .sprint-step-body {
      font-size: 13.5px;
      line-height: 1.6;
      color: var(--color-ink-muted);
      margin: 0;
      text-wrap: pretty;
    }
    .sprint-step-body strong {
      color: var(--color-ink);
      font-weight: 500;
    }
    .sprint-step--milestone .sprint-step-title {
      color: var(--color-brand);
    }
  </style>

  <!-- ============================================================
       LE 5 AREE (compressed, moved after methodology)
       ============================================================ -->
  <section id="aree" class="section bg-white border-t border-line">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Settori in cui lavoriamo"
        title="Dove gli agenti producono ROI più velocemente."
        subtitle="Cinque settori PMI italiani dove abbiamo già consegnato. Approfondisci la verticale che ti interessa per i dettagli su task e case study."
        align="center"
      />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {areas.map((a) => {
          const Tag = a.available ? "a" : "div";
          return (
            <Tag
              href={a.available ? a.href : undefined}
              class={`card-editorial relative overflow-hidden group reveal !p-7 md:!p-8 flex flex-col no-underline ${a.available ? "hover:!-translate-y-1 hover:shadow-lg transition-all cursor-pointer" : ""}`}
            >
              <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-violet-100/60 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>

              <div class="relative">
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-11 h-11 rounded-2xl bg-gradient-to-br from-violet-700 to-violet-500 flex items-center justify-center shadow-violet">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[a.icon]} />
                  </div>
                  <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-500">{a.eyebrow}</span>
                </div>

                <h3 class="text-[1.5rem] md:text-[1.75rem] font-semibold tracking-tight leading-[1.1] text-ink-900 mb-3">
                  {a.title}
                </h3>
                <p class="text-[14.5px] text-ink-700 leading-relaxed text-pretty mb-5">{a.description}</p>

                <div class="pt-4 border-t border-ink-200 mt-auto">
                  <div class="flex items-center gap-2 mb-3 px-3 py-1.5 rounded-full bg-violet-50 w-fit">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#4A1E5C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span class="text-[11.5px] font-semibold text-violet-700">{a.priceHint}</span>
                  </div>
                  <div class="flex items-center justify-between gap-4">
                    <p class="text-[13px] text-ink-600 leading-snug italic">
                      {a.proof}
                    </p>
                    {a.available ? (
                      <span class="shrink-0 text-sm font-semibold text-violet-700 inline-flex items-center gap-1">
                        Approfondisci
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                      </span>
                    ) : (
                      <span class="shrink-0 text-[11px] font-semibold text-ink-400 uppercase tracking-wider">In arrivo</span>
                    )}
                  </div>
                </div>
              </div>
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section class="section bg-ink-50">
    <div class="container-soraia max-w-4xl">
      <SectionHeader
        eyebrow="Domande frequenti"
        title="Quello che ci chiedono di solito."
        align="center"
      />
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ============================================================
       CTA FINALE DUAL. Call CEO + download report
       ============================================================ -->
  <section class="section bg-ink-50 border-t border-line">
    <div class="container-soraia max-w-5xl">
      <div class="reveal text-center max-w-2xl mx-auto mb-10">
        <p class="eyebrow mb-5">Prossimo passo</p>
        <h2 class="text-[2rem] md:text-[2.75rem] font-semibold tracking-tight text-ink-900 leading-[1.1] text-balance">
          20 minuti col CEO. Senza pitch.
        </h2>
        <p class="mt-5 text-[16px] md:text-[17px] text-ink-600 leading-relaxed text-pretty">
          Capiamo insieme se ha senso fare l'AI Readiness Assessment sul tuo caso. Nessun impegno, nessuna vendita.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-3xl mx-auto reveal reveal-delay-1">
        <a href="/parliamone" class="group rounded-2xl bg-ink-900 hover:bg-ink p-7 md:p-8 transition-all hover:-translate-y-1 hover:shadow-xl no-underline">
          <div class="flex items-start gap-4">
            <img src="/team/daniel-levis.webp" alt="Daniel Levis" class="w-12 h-12 rounded-full object-cover ring-2 ring-violet-400/30" />
            <div class="flex-1 min-w-0">
              <p class="text-[11px] uppercase tracking-[0.16em] font-semibold mb-1" style="color: rgba(216,180,232,0.9);">Opzione 1 · Conversazione</p>
              <h3 class="text-[1.15rem] font-semibold text-white leading-tight mb-1">20 min con Daniel</h3>
              <p class="text-[13.5px] leading-relaxed" style="color: rgba(255,255,255,0.7);">Capiamo insieme se ha senso lavorare insieme. Zero pitch.</p>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-2 text-white group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a href="/downloads/ai-assessment-sample" class="group rounded-2xl bg-white border border-line hover:border-violet-300 p-7 md:p-8 transition-all hover:-translate-y-1 hover:shadow-lg no-underline">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-violet-50 flex items-center justify-center shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4A1E5C" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-[11px] uppercase tracking-[0.16em] font-semibold text-violet-700 mb-1">Opzione 2 · Materiale</p>
              <h3 class="text-[1.15rem] font-semibold text-ink-900 leading-tight mb-1">Scarica report di esempio</h3>
              <p class="text-[13.5px] text-ink-600 leading-relaxed">Vedi com'è fatto un AI Readiness Assessment. PDF, 22 pagine.</p>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-2 text-violet-700 group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
