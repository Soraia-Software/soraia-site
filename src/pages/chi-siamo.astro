---
import Layout from "~/layouts/Layout.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import WorldMap from "~/components/WorldMap.astro";
import FAQ from "~/components/FAQ.astro";
import CTABanner from "~/components/CTABanner.astro";

const title = "Chi siamo, AI Agency italiana per le PMI | Soraia";
const description = "AI consultants 100% remote distribuiti tra Italia, Europa e Sudamerica. 40+ progetti consegnati, focus su PMI italiane, nessun lock-in tecnologico.";

const values = [
  {
    title: "AI-first, ma con criterio.",
    body: "L'AI quando serve. I processi e le persone prima. Niente automazioni a tutti i costi: se un workflow funziona già, lo lasciamo stare.",
  },
  {
    title: "Pensiamo soluzioni, non problemi.",
    body: "Sappiamo cosa si può fare oggi con l'AI. Conosciamo dove sono le limitazioni reali. Diciamo al cliente la verità prima del preventivo, non dopo la firma.",
  },
  {
    title: "Adoption batte technology.",
    body: "Il miglior agente IA è quello che il team usa davvero. Per questo il 40% del nostro lavoro è training, change management, documentazione, non solo build.",
  },
  {
    title: "Misuriamo i risultati.",
    body: "Baseline cronometrata prima dello sprint. Metric primario unico. 30 giorni di hypercare dopo il go-live. Senza numeri verificabili, nessuna garanzia è onesta.",
  },
  {
    title: "Velocità + qualità.",
    body: "Prima delivery in 4 settimane. Codice tuo dalla prima settimana. Niente abbonamenti perpetui, niente lock-in. Se vuoi internalizzare, ti diamo training e documenti.",
  },
  {
    title: "Curiosi, impariamo veloce.",
    body: "Lo stack AI evolve ogni mese. Investiamo tempo a testare modelli, framework, pattern nuovi prima di proporli al cliente. Il vantaggio competitivo è l'aggiornamento.",
  },
];

const founders = [
  {
    name: "Daniel Levis",
    role: "Co-Founder & CEO",
    photo: "/team/daniel-levis.avif",
    bio: "Più di 10 anni tra IT e management consulting. Daniel guida la parte commerciale, change management e adoption sui 40+ progetti consegnati. Convinto che il valore dell'AI per una PMI dipenda al 70% da come la introduci nel team, non da quale modello scegli.",
    education: ["Politecnico di Torino", "ESCP"],
    companies: ["Reply", "Accenture", "Alten", "Satispay"],
  },
  {
    name: "Davide Silvestri",
    role: "Co-Founder & CTO",
    photo: "/team/davide-silvestri.avif",
    bio: "Più di 10 anni in technical project management, technical leadership e backend architecture. Davide guida lo stack tecnico Soraia: garantisce qualità del codice, performance degli agenti, scalabilità delle soluzioni. Owner architetturale dei progetti più complessi del portfolio.",
    education: ["Politecnico di Torino", "ESCP"],
    companies: ["Simon-Kucher", "Amazon", "Dott", "Satispay"],
  },
];

const team = [
  { name: "Eleonora Cogo",      role: "AI Consultant",  photo: "/team/eleonora-cogo.png",      tag: "Sales & AI Workflows" },
  { name: "Lorenzo Barbaglia",  role: "AI Consultant",  photo: "/team/lorenzo-barbaglia.png",  tag: "Backend & AI Integration" },
  { name: "Martina Rochstein",  role: "AI Consultant",  photo: "/team/martina-rochstein.png",  tag: "Adoption & Onboarding" },
  { name: "Mohamed Mejri",      role: "AI Consultant",  photo: "/team/mohamed-mejri.png",      tag: "Backend & AI Integration" },
  { name: "Narella Petrocco",   role: "AI Consultant",  photo: "/team/narella-petrocco.png",   tag: "Product & Discovery" },
  { name: "Bilel Abdelmoula",   role: "AI Consultant",  photo: "/team/bilel-abdelmoula.png",   tag: "Backend & AI Integration" },
  { name: "Sebastian Geido",    role: "AI Consultant",  photo: "/team/sebastian-geido.png",    tag: "Backend & AI Integration" },
  { name: "Veronica Pisana",    role: "AI Consultant",  photo: "/team/veronica-pisana.png",    tag: "Sales & AI Workflows" },
];

const worldRegions = [
  {
    x: 50.5, y: 36,
    label: "Europa",
    flag: "🇪🇺",
    total: 28,
    countries: [
      { flag: "🇮🇹", name: "Italia", count: 12 },
      { flag: "🇨🇭", name: "Svizzera", count: 3 },
      { flag: "🇫🇷", name: "Francia", count: 3 },
      { flag: "🇬🇧", name: "Inghilterra", count: 3 },
      { flag: "🇪🇸", name: "Spagna", count: 2 },
      { flag: "🇳🇱", name: "Paesi Bassi", count: 2 },
      { flag: "🇩🇪", name: "Germania", count: 2 },
      { flag: "🇵🇹", name: "Portogallo", count: 1 },
    ],
    align: "right" as const,
  },
  { x: 23, y: 40,  label: "Stati Uniti",   flag: "🇺🇸", total: 7, countries: [{ flag: "🇺🇸", name: "USA", count: 7 }], align: "left" as const },
  { x: 60, y: 49,  label: "Emirati Arabi", flag: "🇦🇪", total: 4, countries: [{ flag: "🇦🇪", name: "UAE", count: 4 }] },
  { x: 84, y: 71,  label: "Australia",     flag: "🇦🇺", total: 2, countries: [{ flag: "🇦🇺", name: "Australia", count: 2 }], align: "right" as const },
];

const faqs = [
  {
    q: "Chi è dietro Soraia?",
    a: "Soraia nasce nel 2023 da <strong>Daniel Levis</strong> (CEO, change management & AI adoption) e <strong>Davide Silvestri</strong> (CTO, backend architecture & AI engineering). Oggi siamo un team di <strong>11 persone</strong> distribuite tra Italia, Argentina e Algeria. Sede legale a Biella, modalità di lavoro 100% remote.",
  },
  {
    q: "Perché tutti i ruoli si chiamano 'AI Consultant'?",
    a: "Perché in Soraia ogni persona del team lavora a contatto con il cliente, in tutte le fasi: discovery, build, deploy, adoption. Non separiamo developer da consultant da PM. <strong>L'AI è una disciplina trasversale</strong>, non un silo tecnico, e questo modello funziona meglio per le PMI italiane.",
  },
  {
    q: "Quanti progetti avete consegnato?",
    a: "<strong>40+ progetti</strong> consegnati in 11 paesi. Il 30% in Italia, il resto distribuito tra Europa, USA, Emirati e Australia. Settori principali: recruiting & HR, finance & accounting, venture capital, real estate, customer support, sales operations.",
  },
  {
    q: "Avete posizioni aperte?",
    a: "Cresciamo principalmente tramite referral interno. Se hai esperienza in AI engineering, change management o customer-facing consulting, scrivici a <a href='mailto:hello@soraia.io' style='color: var(--color-brand); text-decoration: underline;'>hello@soraia.io</a> con un breve profilo. Rispondiamo sempre, anche solo per dire no.",
  },
  {
    q: "Dove avete sede e come lavorate?",
    a: "<strong>Sede legale a Biella</strong> (Via Losana 13, 13900 Biella). Delivery <strong>100% remote</strong>: niente uffici corporate, niente costi gonfiati nel preventivo. Ma per le fasi che richiedono il contatto umano — <strong>AI Readiness Assessment</strong> (2 giorni onsite per analizzare i processi sul campo) e <strong>AI Adoption workshop</strong> (sempre in sede cliente) — ci muoviamo noi. Il change management non si fa da Zoom.",
  },
];
---

<Layout title={title} description={description} lang="it">

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative overflow-hidden border-b border-line" style="background: #FAFAF8;">
    <div class="container-soraia pt-20 md:pt-28 pb-16 md:pb-20">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
        Chi siamo
      </p>
      <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-16 items-start">
        <div>
          <h1 class="text-balance" style="font-size: clamp(2.25rem, 5vw + 1rem, 4rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;">
            Velocità senza sacrificare la qualità.
          </h1>
          <p class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-xl text-pretty" style="color: var(--color-ink-muted);">
            Siamo un <strong style="color: var(--color-ink); font-weight: 500;">team di AI consultants</strong> 100% remote, distribuiti tra Italia, Europa e Sudamerica. Costruiamo agenti IA che le PMI italiane usano davvero — perché non basta che il software funzioni, deve essere adottato dal team.
          </p>
          <div class="mt-9 flex flex-wrap gap-x-7 gap-y-3 text-[14px]" style="color: var(--color-ink-muted);">
            <div class="inline-flex items-center gap-2">
              <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
              <span><strong style="color: var(--color-ink); font-weight: 500;">40+ progetti</strong> consegnati</span>
            </div>
            <div class="inline-flex items-center gap-2">
              <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
              <span><strong style="color: var(--color-ink); font-weight: 500;">11 paesi</strong> serviti</span>
            </div>
            <div class="inline-flex items-center gap-2">
              <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
              <span><strong style="color: var(--color-ink); font-weight: 500;">100% remote</strong>, sede Biella</span>
            </div>
          </div>
        </div>

        <!-- Founders photo -->
        <div class="relative">
          <div class="grid grid-cols-2 gap-4 lg:gap-5">
            <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-violet-100 relative">
              <img src="/team/daniel-levis.avif" alt="Daniel Levis" loading="eager" width="380" height="475" class="w-full h-full object-cover" />
              <div class="absolute bottom-0 left-0 right-0 p-3 md:p-4" style="background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.7) 100%);">
                <p class="text-white text-[13px] md:text-[14px] font-medium leading-tight">Daniel Levis</p>
                <p class="text-white/70 text-[11px] md:text-[12px] leading-tight mt-0.5">CEO</p>
              </div>
            </div>
            <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-violet-100 relative mt-8 lg:mt-10">
              <img src="/team/davide-silvestri.avif" alt="Davide Silvestri" loading="eager" width="380" height="475" class="w-full h-full object-cover" />
              <div class="absolute bottom-0 left-0 right-0 p-3 md:p-4" style="background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.7) 100%);">
                <p class="text-white text-[13px] md:text-[14px] font-medium leading-tight">Davide Silvestri</p>
                <p class="text-white/70 text-[11px] md:text-[12px] leading-tight mt-0.5">CTO</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VALORI
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Cosa ci muove"
        title="I principi che ci tengono insieme."
        subtitle="Sei valori che usiamo per prendere decisioni difficili: quando dire no a un progetto, quando aggiungere o togliere un agente, come comunicare con il cliente. Non sono slogan, ma criteri operativi."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px max-w-6xl mx-auto" style="background: var(--color-line); border: 1px solid var(--color-line); border-radius: 1.25rem; overflow: hidden;">
        {values.map((v) => (
          <div class="bg-white p-8 md:p-9">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center mb-5" style="background: var(--color-brand-soft); color: var(--color-brand);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/></svg>
            </div>
            <h3 class="text-balance" style="font-size: 1.0625rem; line-height: 1.3; letter-spacing: -0.015em; font-weight: 500; color: var(--color-ink);">{v.title}</h3>
            <p class="mt-3 text-[14.5px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FOUNDERS
       ============================================================ -->
  <section class="section bg-ink-50 border-y border-line">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="I fondatori"
        title="Daniel e Davide."
        subtitle="Co-fondatori dal 2023, profili complementari: commerciale + change management da una parte, tech leadership + AI engineering dall'altra. Background in consulting di alto livello + scaleup tecnologiche."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-6xl mx-auto">
        {founders.map((f) => (
          <article class="card-editorial !p-8 md:!p-10 flex flex-col">
            <div class="flex items-center gap-5 mb-7">
              <img src={f.photo} alt={f.name} loading="lazy" width="80" height="80" class="w-20 h-20 rounded-full object-cover" />
              <div>
                <h3 style="font-size: 1.375rem; line-height: 1.2; letter-spacing: -0.02em; font-weight: 500; color: var(--color-ink);">{f.name}</h3>
                <p class="mt-1 text-[14px]" style="color: var(--color-ink-soft);">{f.role}</p>
              </div>
            </div>
            <p class="text-[15px] leading-relaxed text-pretty flex-1" style="color: var(--color-ink-muted);">{f.bio}</p>
            <div class="mt-7 pt-6 border-t border-line space-y-3">
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                <p class="text-[10px] font-medium tracking-[0.14em] uppercase w-[78px] flex-shrink-0" style="color: var(--color-ink-soft);">Education</p>
                {f.education.map((e, i) => (
                  <>
                    {i > 0 && <span class="text-[11px]" style="color: var(--color-ink-soft);">·</span>}
                    <span class="text-[13px] font-medium" style="color: var(--color-ink);">{e}</span>
                  </>
                ))}
              </div>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                <p class="text-[10px] font-medium tracking-[0.14em] uppercase w-[78px] flex-shrink-0" style="color: var(--color-ink-soft);">Experience</p>
                {f.companies.map((c, i) => (
                  <>
                    {i > 0 && <span class="text-[11px]" style="color: var(--color-ink-soft);">·</span>}
                    <span class="text-[13px] font-medium" style="color: var(--color-ink);">{c}</span>
                  </>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       TEAM GRID
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Il team"
        title="Le persone con cui lavorerai."
        subtitle="Otto AI consultants distribuiti tra Italia, Argentina e Algeria. Tutti partecipano alle call con i clienti, tutti lavorano sui processi reali. Niente intermediari, niente account manager che girano richieste."
        align="center"
      />

      <div class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6 max-w-6xl mx-auto">
        {team.map((m) => (
          <article class="group">
            <div class="aspect-square overflow-hidden rounded-xl mb-4" style="background: var(--color-ink-50);">
              <img src={m.photo} alt={m.name} loading="lazy" width="220" height="220" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]" />
            </div>
            <h3 style="font-size: 0.9375rem; line-height: 1.25; letter-spacing: -0.01em; font-weight: 500; color: var(--color-ink);">{m.name}</h3>
            <p class="mt-1 text-[12.5px]" style="color: var(--color-brand);">{m.role}</p>
            <p class="mt-0.5 text-[12px] leading-snug" style="color: var(--color-ink-soft);">{m.tag}</p>
          </article>
        ))}
      </div>

      <p class="text-center mt-14 text-[14px]" style="color: var(--color-ink-muted);">
        Stiamo crescendo. Posizioni aperte? Scrivici a <a href="mailto:hello@soraia.io" class="underline underline-offset-4" style="color: var(--color-brand);">hello@soraia.io</a>
      </p>
    </div>
  </section>

  <!-- ============================================================
       MODALITÀ DI LAVORO
       ============================================================ -->
  <section class="section bg-white border-t border-line">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Come lavoriamo"
        title="Full-remote operativo. In sede quando il valore lo richiede."
        subtitle="La delivery quotidiana è 100% remote: niente uffici corporate, niente costi gonfiati che finiscono nel preventivo. Quando serve incontrarsi dal vivo, ci muoviamo noi."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-5xl mx-auto">
        <article class="card-editorial !p-8 md:!p-9">
          <div class="w-11 h-11 rounded-lg flex items-center justify-center mb-6" style="background: var(--color-brand-soft); color: var(--color-brand);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="text-balance" style="font-size: 1.25rem; line-height: 1.25; letter-spacing: -0.02em; font-weight: 500; color: var(--color-ink);">
            Delivery 100% remote
          </h3>
          <p class="mt-3 text-[14.5px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">
            Build, deploy, hypercare e supporto post-go-live li gestiamo da remoto. Strumenti pensati per la collaborazione asincrona, niente call inutili. Team distribuito tra Italia, Argentina e Algeria, fuso orario coperto su giornata lavorativa europea.
          </p>
        </article>

        <article class="card-editorial !p-8 md:!p-9">
          <div class="w-11 h-11 rounded-lg flex items-center justify-center mb-6" style="background: var(--color-brand-soft); color: var(--color-brand);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="text-balance" style="font-size: 1.25rem; line-height: 1.25; letter-spacing: -0.02em; font-weight: 500; color: var(--color-ink);">
            In sede quando conta
          </h3>
          <p class="mt-3 text-[14.5px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">
            <strong style="color: var(--color-ink); font-weight: 500;">AI Readiness Assessment</strong>: 2 giorni onsite per analizzare i processi sul campo, non per schermo condiviso. <strong style="color: var(--color-ink); font-weight: 500;">AI Adoption workshop</strong>: sempre in sede cliente, mai da remoto, perché il change management si fa guardando le persone negli occhi.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       GLOBAL REACH
       ============================================================ -->
  <section class="section bg-ink-50 border-y border-line">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Reach globale"
        title="Azienda italiana. Clienti in tutto il mondo."
        subtitle="Team <strong>full-remote basato in Italia</strong>, ma lavoriamo con <strong>40+ clienti</strong> distribuiti tra Europa, Stati Uniti, Emirati Arabi e Australia."
        align="center"
      />

      <WorldMap regions={worldRegions} />

      <div class="mt-20 grid grid-cols-3 gap-px bg-ink-200 rounded-3xl overflow-hidden max-w-4xl mx-auto reveal">
        <div class="bg-white p-7 md:p-9 text-center">
          <p class="text-[2.5rem] md:text-[3.5rem] font-medium tracking-tight leading-none" style="color: var(--color-brand);">40+</p>
          <p class="mt-3 text-[13px] font-medium text-ink-900">Progetti consegnati</p>
        </div>
        <div class="bg-white p-7 md:p-9 text-center">
          <p class="text-[2.5rem] md:text-[3.5rem] font-medium tracking-tight leading-none" style="color: var(--color-brand);">11</p>
          <p class="mt-3 text-[13px] font-medium text-ink-900">Paesi serviti</p>
        </div>
        <div class="bg-white p-7 md:p-9 text-center">
          <p class="text-[2.5rem] md:text-[3.5rem] font-medium tracking-tight leading-none" style="color: var(--color-brand);">4 sett.</p>
          <p class="mt-3 text-[13px] font-medium text-ink-900">Al primo agente live</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section class="section bg-white">
    <div class="container-soraia max-w-4xl">
      <SectionHeader
        eyebrow="Domande frequenti"
        title="Quello che ci chiedono di solito."
        align="center"
      />
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ============================================================
       CTA FINALE
       ============================================================ -->
  <CTABanner
    title="20 minuti col CEO. Senza pitch."
    description="Capiamo insieme se ha senso lavorare. Nessun impegno, nessun preventivo a sorpresa: solo una conversazione operativa sui tuoi processi."
    ctaText="20 min con Daniel"
    ctaHref="/parliamone"
    avatarName="Daniel Levis"
    avatarRole="Co-Founder & CEO"
    avatarSrc="/team/daniel-levis.png"
  />
</Layout>
