---
import Layout from "~/layouts/Layout.astro";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import HeroVisual from "~/components/HeroVisual.astro";

const title = "Agenti IA per Customer Support e Operations | Soraia";
const description =
  "Triage istantaneo, draft in tono brand, escalation con context, sentiment monitoring. Agenti IA che gestiscono il funnel ticket end-to-end. -70% di tempo operativo. Live in 4 settimane.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Agenti IA per Customer Support. Soraia",
    provider: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
    areaServed: "IT",
    serviceType: "AI agents for customer support teams",
    offers: { "@type": "Offer", priceCurrency: "EUR", price: "2000", description: "Assessment iniziale €2.000, rimborsato se procedi con lo sprint." },
  },
];

const problems = [
  {
    title: "Triage manuale che non scala",
    description: "Ticket che arrivano da email, chat, social, form. Qualcuno deve classificare priorità, assegnare al team, capire urgenza. Su volume alto, il triage diventa il vero bottleneck.",
  },
  {
    title: "Tono brand inconsistente",
    description: "Risposte scritte da team diversi, in momenti diversi, con stile diverso. Il cliente percepisce un brand frammentato. Le linee guida non bastano: serve un agente che le applichi sempre.",
  },
  {
    title: "Escalation lente e senza context",
    description: "Quando un caso passa a senior support, il context si perde nei thread. Il senior rilegge tutto da zero, perde tempo, il cliente aspetta. SLA bruciato.",
  },
];

const processes = [
  {
    number: "01",
    title: "Triage automatico multi-canale",
    description: "L'agente legge ogni ticket in arrivo (email, chat, social, form), classifica per priorità e tipologia, assegna automaticamente al team giusto. Niente più code unsorted.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "Draft risposte in tono brand",
    description: "Per ogni ticket l'agente prepara la bozza di risposta nel tono brand definito. L'agente non si stanca, non ha giornate storte, applica i criteri al primo come al millesimo ticket.",
    icon: "transcript" as const,
  },
  {
    number: "03",
    title: "Routing intelligente",
    description: "Tickets smistati al team specializzato (tech, billing, retention) col context completo. Skill-based routing, niente più ping-pong tra colleghi.",
    icon: "outreach" as const,
  },
  {
    number: "04",
    title: "Escalation con context completo",
    description: "Quando un caso richiede senior support, l'agente prepara un brief: storia del cliente, conversazione attuale, tentativi fatti, raccomandazioni. Il senior risponde in 5 minuti, non 30.",
    icon: "match" as const,
  },
  {
    number: "05",
    title: "Tracking SLA + sentiment real-time",
    description: "Monitor sentiment cliente per ticket, alert su risposte negative, tracking SLA per team. Il management vede problemi prima che esplodano.",
    icon: "calendar" as const,
  },
  {
    number: "06",
    title: "Report performance + insights",
    description: "First response time, resolution time, CSAT predicted, top issue categories. Dashboard executive aggiornato in real-time, niente più export settimanali.",
    icon: "compass" as const,
  },
];

const cases = [
  {
    slug: "navily",
    client: "Navily",
    quote: "L'IA modera recensioni, immagini e arricchisce i dati: -70% di tempo operativo, alta precisione. Il team torna sul prodotto, non sul triage manuale.",
    dimensioni: "11-50",
    sector: "Consumer mobile · Travel & nautical",
    cardImage: "/testimonials/edouard-fiess-navily.webp",
    stakeholder: { name: "Edouard Fiess", role: "CEO & Co-Founder" },
  },
];

const comparisonRows = [
  { label: "Costo", values: ["Per seat", "Per ticket", "One-time + maintenance"] as [string, string, string] },
  { label: "Tempo a regime", values: ["Subito", "Setup lungo", "4 settimane"] as [string, string, string] },
  { label: "Tono brand", values: ["Limitato", "Configurabile", "Addestrato sul vostro"] as [string, string, string] },
  { label: "Multi-canale", values: ["Limitato", "Sì", "Sì, custom integration"] as [string, string, string] },
  { label: "Dipendenza dal fornitore", values: ["Nessuna", "Totale", "Nessuna (codice vostro)"] as [string, string, string] },
  { label: "Sentiment + analytics", values: ["No", "Sì base", "Custom executive dashboard"] as [string, string, string] },
];

const faqs = [
  {
    q: "Come gestite GDPR e dati personali dei clienti?",
    a: "Infrastruttura europea o on-premise sulla vostra. <strong>Nessun training sui vostri dati</strong>. Log di ogni decisione dell'agente, retention configurabile, audit-ready.",
  },
  {
    q: "Si integra col mio helpdesk (Zendesk, Intercom, Freshdesk, custom)?",
    a: "Sì. Lavoriamo via API o webhook con i principali helpdesk. Se hai una soluzione custom o un sistema legacy lo validiamo in assessment.",
  },
  {
    q: "L'agente può rispondere autonomamente o serve sempre l'umano?",
    a: "Configurabile per categoria di ticket. Per casi routine (info standard, status check), può rispondere autonomamente con confidence threshold. Per casi delicati o borderline, passa al team con context completo. <strong>Voi decidete dove tracciare la linea</strong>.",
  },
  {
    q: "Come addestrate il tono brand?",
    a: "Analizziamo un campione delle vostre risposte storiche migliori. Il tono di voce emerge dai dati, non da linee guida astratte. Validiamo con voi prima di andare in produzione.",
  },
  {
    q: "Quanto costa davvero?",
    a: "Assessment <strong>€2.000</strong> (rimborsato). Sprint <strong>€10-50k</strong>. Garanzia: se l'agente non riduce il tempo di triage promesso, lavoriamo gratis fino a quando non lo fa.",
  },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div style="color: #fff;">
          <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            Customer Support · AI Agents
          </p>
          <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
            Triage istantaneo.<br/>Risposte in tono brand.
          </h1>
          <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
            Agenti IA che classificano, scrivono bozze, smistano, escalano. -70% di tempo operativo sul triage, escalation con context completo, sentiment monitoring real-time. Live in 4 settimane.
          </p>
          <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-[14px] font-medium" style="color: #F4B842;">Se non funziona, non paghi. Garanzia inclusa.</span>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="/parliamone" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
              Richiedi assessment, €2.000
              <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
            </a>
            <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">Vedi il caso Navily</a>
          </div>
          <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">-70%</strong> tempo operativo triage</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Multi-canale</strong> nativo</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">GDPR + audit log</strong> incluso</span></div>
          </div>
        </div>
        <div class="hidden lg:flex justify-end fade-up fade-up-delay-3">
          <HeroVisual filter="support" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-14 border-y border-ink-200 bg-white">
    <div class="container-soraia text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 mb-4">Già scelto da consumer mobile e SaaS B2B</p>
      <p class="text-[16px]" style="color: var(--color-ink-muted);">
        <a href="/case-studies/navily" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">Navily</a>
        · Principale app europea per porti turistici · cliente attivo con scaling continuo
      </p>
    </div>
  </section>

  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Il problema"
        title="Il triage costa più della soluzione."
        subtitle="Chi gestisce un volume serio di ticket sa che il vero costo non è risolvere i problemi: è classificarli, prioritizzarli, smistarli, mantenere tono brand. Ore di lavoro umano qualificato bruciato su task ripetitivo."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="La soluzione"
        title="6 agenti IA che coprono il funnel ticket end-to-end."
        subtitle="Triage, draft, routing, escalation, tracking, analytics. Lavoratori digitali che applicano gli stessi criteri al primo come al millesimo ticket della giornata."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (<ProcessCard {...p} />))}
      </div>
    </div>
  </section>

  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          La nostra garanzia
        </p>
        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          -70% di tempo operativo sul triage.<br/><span style="color: rgba(255,255,255,0.45);">Misurato in 4 settimane. O non paghi.</span>
        </h2>
        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          Baseline misurata in assessment sui vostri ticket reali. Se l'agente non recupera il tempo promesso al team, lavoriamo gratis finché non succede, oppure rimborsiamo lo sprint.
        </p>
      </div>
    </div>
  </section>

  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader eyebrow="Caso studio" title="Agente IA multi-task in azione su Navily." align="center" />
      <div class="max-w-md mx-auto">
        <CaseStudyCardJet href={`/case-studies/${cases[0].slug}`} client={cases[0].client} quote={cases[0].quote} dimensioni={cases[0].dimensioni} sector={cases[0].sector} cardImage={cases[0].cardImage} />
        <p class="mt-6 text-center text-[14px]" style="color: var(--color-ink-soft);">
          <strong style="color: var(--color-ink); font-weight: 500;">{cases[0].stakeholder.name}</strong>, {cases[0].stakeholder.role} · {cases[0].client}
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Confronto"
        title="Perché agenti IA su misura, e non altro."
        subtitle="Le tre opzioni reali per un team customer support oggi."
        align="center"
      />
      <ComparisonTable columns={["Helpdesk SaaS standard", "Helpdesk AI add-on", "Soraia agenti IA"]} rows={comparisonRows} highlightCol={2} />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-soraia max-w-3xl">
      <SectionHeader eyebrow="Domande" title="Quello che ci chiedono di solito." align="center" />
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 reveal" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Prossimo passo
      </p>
      <h2 class="text-balance reveal" style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Scopri quanto tempo può recuperare il tuo team support.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed reveal reveal-delay-1" style="color: var(--color-ink-muted);">
        Assessment €2.000, rimborsato se procedi. 1-2 settimane dall'inizio al report.
      </p>
      <div class="mt-10 reveal reveal-delay-2">
        <a href="/parliamone" class="btn btn-primary">
          Richiedi assessment
          <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
