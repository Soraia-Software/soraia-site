---
import Layout from "~/layouts/Layout.astro";
import { getCollection } from "astro:content";

const title = "Blog & Insights | Soraia";
const description = "Pratico, contrarian, basato su 40+ progetti agenti IA reali. Niente AI hype, solo decisioni operative.";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.filter((p) => p.data.featured);
const others = posts.filter((p) => !p.data.featured);

function formatDate(d: Date) {
  return d.toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" });
}
---

<Layout title={title} description={description} lang="it">
  <!-- ============================================================
       HERO INDEX
       ============================================================ -->
  <section class="relative overflow-hidden border-b border-line" style="background: #FAFAF8;">
    <div class="container-soraia pt-20 md:pt-28 pb-16 md:pb-20">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Blog & Insights
      </p>
      <h1 class="text-balance max-w-3xl" style="font-size: clamp(2.25rem, 5vw + 1rem, 4rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;">
        Pratico. Contrarian. Basato su 40+ progetti reali.
      </h1>
      <p class="mt-6 text-[18px] md:text-[19px] leading-relaxed max-w-2xl text-pretty" style="color: var(--color-ink-muted);">
        Senza AI hype, senza promesse magiche. Solo decisioni operative su come portare agenti IA nelle PMI italiane, quello che funziona, quello che non funziona, e perché.
      </p>
    </div>
  </section>

  <!-- ============================================================
       FEATURED POSTS
       ============================================================ -->
  {featured.length > 0 && (
    <section class="section bg-white" style="padding-block: 4rem;">
      <div class="container-soraia">
        <p class="eyebrow mb-8">In evidenza</p>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {featured.map((post) => (
            <a href={`/blog/${post.id}`} class="card-editorial !p-8 md:!p-10 group no-underline flex flex-col transition-all hover:!-translate-y-1 hover:shadow-md">
              <div class="flex items-center gap-3 text-[11px] font-medium tracking-[0.14em] uppercase mb-5" style="color: var(--color-ink-soft);">
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                <span>·</span>
                <span>{post.data.readMinutes ?? 5} min lettura</span>
              </div>
              <h2 class="mb-4 text-balance" style="font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2rem); line-height: 1.15; letter-spacing: -0.02em; font-weight: 500;">
                {post.data.title}
              </h2>
              <p class="text-[16px] leading-relaxed text-pretty mb-6 flex-1" style="color: var(--color-ink-muted);">
                {post.data.description}
              </p>
              <span class="inline-flex items-center gap-1.5 text-sm font-medium" style="color: var(--color-brand);">
                Leggi l'articolo
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================================
       ALL POSTS (list)
       ============================================================ -->
  {others.length > 0 && (
    <section class="bg-white" style="padding-bottom: 6rem;">
      <div class="container-soraia">
        <p class="eyebrow mb-8">Tutti gli articoli</p>
        <ul class="divide-y divide-[color:var(--color-line)] border-t border-[color:var(--color-line)]">
          {others.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-4 md:gap-8 py-7 group">
                <div class="text-[11px] font-medium tracking-[0.14em] uppercase pt-1" style="color: var(--color-ink-soft);">
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  <div class="mt-1">{post.data.readMinutes ?? 5} min</div>
                </div>
                <div>
                  <h3 class="mb-2 text-balance" style="font-size: 1.25rem; line-height: 1.25; letter-spacing: -0.015em; font-weight: 500;">{post.data.title}</h3>
                  <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{post.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ============================================================
       CTA finale → check-up
       ============================================================ -->
  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Prima di leggere altro
      </p>
      <h2 class="text-balance" style="font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Capisci dove sei in 3 minuti.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed" style="color: var(--color-ink-muted);">
        Il check-up ti dà un punteggio di prontezza IA (0-100) + 3 next-step concreti per il tuo caso specifico.
      </p>
      <div class="mt-9">
        <a href="/check-up" class="btn btn-primary">
          Inizia il check-up, è gratis
          <span class="btn-arrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>
