---
import Layout from "~/layouts/Layout.astro";
import { getCollection } from "astro:content";

const title = "Guide AI per aziende italiane | Soraia";
const description = "Le guide operative di Soraia per le PMI italiane che valutano l'IA: agenti, consulenza, formazione, AI Act, costi. Senza fluff, basate su 40+ progetti reali.";

const guides = (await getCollection("guides")).sort(
  (a, b) => (b.data.updatedDate || b.data.pubDate).valueOf() - (a.data.updatedDate || a.data.pubDate).valueOf()
);

const featured = guides.filter((g) => g.data.featured);
const others = guides.filter((g) => !g.data.featured);

function formatDate(d: Date) {
  return d.toLocaleDateString("it-IT", { day: "numeric", month: "short", year: "numeric" });
}
---

<Layout title={title} description={description} lang="it">

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-line" style="background: #FAFAF8;">
    <div class="container-soraia pt-20 md:pt-28 pb-16 md:pb-20">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
        Guide AI per aziende
      </p>
      <h1 class="text-balance max-w-3xl" style="font-size: clamp(2.25rem, 5vw + 1rem, 4rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;">
        Guide operative per chi sta valutando l'IA in azienda.
      </h1>
      <p class="mt-6 text-[18px] md:text-[19px] leading-relaxed max-w-2xl text-pretty" style="color: var(--color-ink-muted);">
        Niente AI hype, niente promesse magiche. Quello che funziona davvero quando porti agenti IA in una PMI italiana, basato su 40+ progetti consegnati. Aggiornate periodicamente.
      </p>
    </div>
  </section>

  <!-- FEATURED -->
  {featured.length > 0 && (
    <section class="section bg-white">
      <div class="container-soraia">
        <p class="eyebrow mb-8">Guide in evidenza</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
          {featured.map((g) => (
            <a href={`/guide/${g.id}`} class="card-editorial !p-8 group no-underline flex flex-col transition-all hover:!-translate-y-1 hover:shadow-md">
              <p class="text-[10.5px] font-medium tracking-[0.14em] uppercase mb-4" style="color: var(--color-ink-soft);">
                Guida · {g.data.readMinutes} min
              </p>
              <h2 class="mb-4 text-balance" style="font-size: 1.25rem; line-height: 1.2; letter-spacing: -0.015em; font-weight: 500;">{g.data.title}</h2>
              <p class="text-[14.5px] leading-relaxed text-pretty mb-6 flex-1" style="color: var(--color-ink-muted);">{g.data.description}</p>
              <span class="inline-flex items-center gap-1.5 text-[13.5px] font-medium" style="color: var(--color-brand);">
                Leggi la guida
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ALL OTHERS -->
  {others.length > 0 && (
    <section class="bg-white" style="padding-bottom: 6rem;">
      <div class="container-soraia">
        <p class="eyebrow mb-8">Tutte le guide</p>
        <ul class="divide-y divide-[color:var(--color-line)] border-t border-[color:var(--color-line)]">
          {others.map((g) => (
            <li>
              <a href={`/guide/${g.id}`} class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-4 md:gap-8 py-7 group">
                <div class="text-[11px] font-medium tracking-[0.14em] uppercase pt-1" style="color: var(--color-ink-soft);">
                  <span>Guida · {g.data.readMinutes} min</span>
                  <div class="mt-1.5 text-[11px] normal-case tracking-normal font-normal" style="color: var(--color-ink-soft);">Aggiornata {formatDate(g.data.updatedDate || g.data.pubDate)}</div>
                </div>
                <div>
                  <h3 class="mb-2 text-balance" style="font-size: 1.25rem; line-height: 1.25; letter-spacing: -0.015em; font-weight: 500;">{g.data.title}</h3>
                  <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{g.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full" style="background: var(--color-brand);"></span>
        Vuoi una valutazione sul tuo caso?
      </p>
      <h2 class="text-balance" style="font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Capiamo insieme se ha senso lavorare.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed" style="color: var(--color-ink-muted);">
        20 minuti col CEO. Senza pitch, senza preventivi a sorpresa.
      </p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="/parliamone" class="btn btn-primary">
          20 min con Daniel
          <span class="btn-arrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a href="/check-up" class="btn btn-secondary">Fai il check-up · 3 min</a>
      </div>
    </div>
  </section>
</Layout>
