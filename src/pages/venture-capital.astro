---
import Layout from "~/layouts/Layout.astro";
import CaseStudyCardJet from "~/components/CaseStudyCardJet.astro";
import ProcessCard from "~/components/ProcessCard.astro";
import ComparisonTable from "~/components/ComparisonTable.astro";
import FAQ from "~/components/FAQ.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import HeroVisual from "~/components/HeroVisual.astro";

const title = "Agenti IA per fondi VC e family office | Soraia";
const description =
  "Deal flow gestito in autonomia. L'agente monitora email, archivia con metadata, dedupplica i deal, genera il monthly report. Il team torna a fare deal. Live in 4 settimane.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Agenti IA per Venture Capital. Soraia",
    provider: { "@type": "Organization", name: "Soraia", url: "https://www.soraia.io" },
    areaServed: "IT",
    serviceType: "AI agents for venture capital and family office",
    offers: { "@type": "Offer", priceCurrency: "EUR", price: "2000", description: "Assessment iniziale €2.000, rimborsato se procedi con lo sprint." },
  },
];

const problems = [
  {
    title: "Pipeline frammentata tra mille sistemi",
    description: "CRM, email Outlook, OneDrive, fogli condivisi. Lo stesso founder vive in 4 record diversi. Capire 'a che punto siamo con X' richiede 20 minuti di context-switch.",
  },
  {
    title: "Email non archiviate per la due diligence",
    description: "Quando serve ricostruire la storia di un deal, le conversazioni chiave sono in qualche thread Outlook che nessuno riesce a trovare. Compliance issue.",
  },
  {
    title: "Monthly report costruito a mano",
    description: "Ogni inizio mese, ore di lavoro qualificato per produrre numeri pipeline, conversion, attività. Quando il report è pronto, è già vecchio.",
  },
];

const processes = [
  {
    number: "01",
    title: "Monitoraggio email deal-related",
    description: "L'agente legge i mailbox del deal team, riconosce automaticamente cosa è deal-related vs spam/newsletter/comunicazioni interne.",
    icon: "screen" as const,
  },
  {
    number: "02",
    title: "Archiving email + allegati conforme",
    description: "Eml + pitch deck + term sheet archiviati su OneDrive/SharePoint con metadata strutturati (deal name, founder, data, tipo allegato). Pronto per due diligence.",
    icon: "transcript" as const,
  },
  {
    number: "03",
    title: "Dedupe deal cross-fonti",
    description: "L'agente riconosce che 'Mario Rossi - Startup A' e 'M. Rossi (CEO StartupA)' sono lo stesso record. Propone il merge, l'umano approva in un click.",
    icon: "match" as const,
  },
  {
    number: "04",
    title: "Scoring deal multi-criterio",
    description: "Per ogni nuovo deal in pipeline, l'agente cross-referenzia Crunchbase, PitchBook, LinkedIn dei founder, e produce uno score motivato per il deal team.",
    icon: "compass" as const,
  },
  {
    number: "05",
    title: "Monthly report auto-generato",
    description: "Charts auto-aggiornati a inizio mese: pipeline per stage, conversion rate, attività per deal team, alert su deal stagnanti. Niente più export Excel manuali.",
    icon: "outreach" as const,
  },
  {
    number: "06",
    title: "Portfolio monitoring + alerts",
    description: "Per le partecipate, l'agente traccia KPI segnalati dai founder, alert su deviazioni, calendario reminder per check-in periodici. Niente più sviste.",
    icon: "calendar" as const,
  },
];

const cases = [
  {
    slug: "liftt",
    client: "LIFTT",
    quote: "L'agente IA gestisce in autonomia archiving, dedupe e reportistica del deal flow. Noi siamo tornati a fare deal.",
    dimensioni: "11-50",
    sector: "Venture Capital · Tech transfer",
    cardImage: "/testimonials/alberto-burzio-liftt.webp",
    stakeholder: { name: "Alberto Burzio", role: "IT Manager" },
  },
];

const comparisonRows = [
  { label: "Costo", values: ["Basso", "Alto annuo", "Medio una tantum"] as [string, string, string] },
  { label: "Tempo a regime", values: ["Subito", "3-6 mesi", "4 settimane"] as [string, string, string] },
  { label: "Esegue task in autonomia", values: ["No", "Limitato", "Sì, end-to-end"] as [string, string, string] },
  { label: "Custom sul vostro deal flow", values: ["No", "Configurabile", "Costruito per voi"] as [string, string, string] },
  { label: "Dipendenza dal fornitore", values: ["Nessuna", "Totale", "Nessuna (codice vostro)"] as [string, string, string] },
  { label: "Compliance email archive", values: ["No", "Parziale", "Sì, audit-ready"] as [string, string, string] },
];

const faqs = [
  {
    q: "Come gestite GDPR e dati confidenziali deal?",
    a: "Infrastruttura europea o on-premise sulla vostra. <strong>Nessun training sui vostri dati</strong>. Log completi, retention configurabile. Già usato su deal flow di fondi italiani regolamentati.",
  },
  {
    q: "Si integra con Affinity, Salesforce, Attio, CRM custom?",
    a: "Sì. Lavoriamo via API o via export programmatico. Se avete un CRM custom o un Airtable lo validiamo in assessment.",
  },
  {
    q: "Come funziona l'archiving email per due diligence?",
    a: "Eml + allegati su OneDrive/SharePoint con metadata strutturati (deal, founder, data, tipo). Quando serve ricostruire la storia di un deal, in 2 click trovi tutto. Compliance-ready.",
  },
  {
    q: "E per il monitoring portfolio?",
    a: "L'agente traccia i KPI che il founder ti manda (mensili, trimestrali), li struttura, alert su deviazioni e calendario reminder per check-in. <strong>Zero KPI persi tra le pieghe della mail</strong>.",
  },
  {
    q: "Quanto costa davvero?",
    a: "Assessment <strong>€2.000</strong> (rimborsato se procedi). Sprint <strong>€10-50k</strong>. Garanzia: se l'agente non recupera le ore promesse al deal team, lavoriamo gratis fino a quando non succede.",
  },
];
---

<Layout title={title} description={description} lang="it" jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-hero-dark">
    <div class="container-soraia pt-20 md:pt-28 pb-20 md:pb-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div style="color: #fff;">
          <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 fade-up" style="color: rgba(216,180,232,0.8);">
            <span class="w-1 h-1 rounded-full bg-amber"></span>
            Finance Ops · Venture Capital
          </p>
          <h1 style="color: #fff; font-size: clamp(2.5rem, 5vw + 1rem, 4.25rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500;" class="text-balance fade-up fade-up-delay-1">
            Deal flow gestito dagli agenti IA.<br/>Voi fate deal.
          </h1>
          <p style="color: rgba(255,255,255,0.78);" class="mt-7 text-[18px] md:text-[19px] leading-relaxed max-w-2xl fade-up fade-up-delay-2 text-pretty">
            L'agente monitora email, archivia con metadata, dedupplica i deal, scoring multi-criterio, monthly report auto-generato. Compliance, niente più ore di operations. Live in 4 settimane.
          </p>
          <div class="mt-6 inline-flex items-center gap-2 fade-up fade-up-delay-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F4B842" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-[14px] font-medium" style="color: #F4B842;">Se non funziona, non paghi. Garanzia inclusa.</span>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row gap-3 fade-up fade-up-delay-3">
            <a href="/parliamone" class="btn !bg-white !text-violet-900 hover:!bg-violet-50">
              Richiedi assessment, €2.000
              <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
            </a>
            <a href="#cases" class="btn btn-secondary !bg-transparent !text-white !border-white/25 hover:!bg-white/10 hover:!border-white/40">Vedi il caso LIFTT</a>
          </div>
          <div class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] fade-up fade-up-delay-4">
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">100%</strong> email archiviate</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">0 ore</strong> di dedupe manuale</span></div>
            <div class="inline-flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber"></span><span style="color: rgba(216,180,232,0.8);"><strong style="color: #fff; font-weight: 500;">Monthly report</strong> auto-generato</span></div>
          </div>
        </div>
        <div class="hidden lg:flex justify-end fade-up fade-up-delay-3">
          <HeroVisual filter="vc" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-14 border-y border-ink-200 bg-white">
    <div class="container-soraia text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 mb-4">Già scelto da fondi italiani</p>
      <p class="text-[16px]" style="color: var(--color-ink-muted);">
        <a href="/case-studies/liftt" style="color: var(--color-ink); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--color-violet-200);">LIFTT</a>
        · Holding di Venture Capital deep tech · cliente attivo
      </p>
      <p class="mt-5 text-[13px]" style="color: var(--color-ink-soft);">
        Sei un team finance non-VC (commercialisti, CFO, M&A operations)?
        <a href="/finance" class="inline-flex items-center gap-1 ml-1 font-semibold text-violet-700 hover:gap-1.5 transition-all">
          Vai alla landing Finance Ops
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </p>
    </div>
  </section>

  <section id="problema" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Il problema"
        title="Il deal flow è cresciuto più dei processi che lo gestiscono."
        subtitle="Mille sistemi, mille thread email, mille file su OneDrive. Il senior team passa più tempo a cercare un dato che a fare deal."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {problems.map((p) => (
          <article class="card-editorial reveal flex flex-col gap-3 !p-7">
            <div class="w-9 h-9 rounded-lg bg-violet-50 text-violet-700 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            </div>
            <h3 class="font-medium text-ink leading-tight" style="font-size: 18px;">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty" style="color: var(--color-ink-muted);">{p.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="La soluzione"
        title="6 agenti IA che fanno il backbone del deal flow."
        subtitle="Monitoring, archiving, dedupe, scoring, report, portfolio tracking. Lavoratori digitali end-to-end. Il team interviene solo sui passaggi che richiedono giudizio."
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processes.map((p) => (<ProcessCard {...p} />))}
      </div>
    </div>
  </section>

  <section class="section bg-hero-dark relative overflow-hidden">
    <div class="container-soraia relative z-10">
      <div class="max-w-3xl reveal" style="color: #fff;">
        <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6" style="color: rgba(216,180,232,0.8);">
          <span class="w-1 h-1 rounded-full bg-amber"></span>
          La nostra garanzia
        </p>
        <h2 style="color: #fff; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;" class="text-balance">
          Backbone deal flow in autonomia.<br/><span style="color: rgba(255,255,255,0.45);">Misurato in 4 settimane. O non paghi.</span>
        </h2>
        <p style="color: rgba(255,255,255,0.72);" class="mt-7 text-[17px] leading-relaxed max-w-2xl text-pretty">
          Baseline misurata in assessment (ore/persona/settimana su monitoring + dedupe + report). Se l'agente non recupera le ore promesse, lavoriamo gratis finché non succede, oppure rimborsiamo lo sprint.
        </p>
      </div>
    </div>
  </section>

  <section id="cases" class="section bg-white">
    <div class="container-soraia">
      <SectionHeader eyebrow="Caso studio" title="Agenti IA in azione su LIFTT." align="center" />
      <div class="max-w-md mx-auto">
        <CaseStudyCardJet href={`/case-studies/${cases[0].slug}`} client={cases[0].client} quote={cases[0].quote} dimensioni={cases[0].dimensioni} sector={cases[0].sector} cardImage={cases[0].cardImage} />
        <p class="mt-6 text-center text-[14px]" style="color: var(--color-ink-soft);">
          <strong style="color: var(--color-ink); font-weight: 500;">{cases[0].stakeholder.name}</strong>, {cases[0].stakeholder.role} · {cases[0].client}
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-ink-50">
    <div class="container-soraia">
      <SectionHeader
        eyebrow="Confronto"
        title="Perché agenti IA su misura, e non altro."
        subtitle="Le tre opzioni reali per un fondo VC o family office oggi."
        align="center"
      />
      <ComparisonTable columns={["ChatGPT / Copilot", "Affinity / Attio AI", "Soraia agenti IA"]} rows={comparisonRows} highlightCol={2} />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-soraia max-w-3xl">
      <SectionHeader eyebrow="Domande" title="Quello che ci chiedono di solito." align="center" />
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section bg-violet-mesh">
    <div class="container-soraia text-center max-w-3xl mx-auto">
      <p class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.15em] uppercase mb-6 reveal" style="color: var(--color-ink-soft);">
        <span class="w-1 h-1 rounded-full bg-violet-600"></span>
        Prossimo passo
      </p>
      <h2 class="text-balance reveal" style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 2.75rem); line-height: 1.1; letter-spacing: -0.025em; font-weight: 500;">
        Scopri quante ore può recuperare il tuo deal team.
      </h2>
      <p class="mt-5 text-[17px] leading-relaxed reveal reveal-delay-1" style="color: var(--color-ink-muted);">
        Assessment €2.000, rimborsato se procedi. 1-2 settimane dall'inizio al report.
      </p>
      <div class="mt-10 reveal reveal-delay-2">
        <a href="/parliamone" class="btn btn-primary">
          Richiedi assessment
          <span class="btn-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
