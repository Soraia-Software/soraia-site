---
import "~/styles/globals.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import AskAIWidget from "~/components/AskAIWidget.astro";
import { localizePath, path as i18nPath } from "~/lib/i18n";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  lang?: "it" | "en";
  jsonLd?: Record<string, any> | Record<string, any>[];
  /** Explicit URL of this page in the OTHER language. Pass on content detail
   *  pages whose slug differs across languages (guides, blog). When omitted,
   *  the alternate is derived from the path via localizePath(). */
  altHref?: string;
}

const {
  title,
  description,
  ogImage = "/og/default.png",
  canonical,
  lang = "it",
  jsonLd,
  altHref,
} = Astro.props;

const siteUrl = "https://www.soraia.io";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();

// hreflang alternates (it / en / x-default)
const otherLang = lang === "it" ? "en" : "it";
const otherPath = altHref ?? localizePath(Astro.url.pathname, otherLang);
const itPath = lang === "it" ? Astro.url.pathname : otherPath;
const enPath = lang === "en" ? Astro.url.pathname : otherPath;
const itUrl = new URL(itPath, siteUrl).toString();
const enUrl = new URL(enPath, siteUrl).toString();
const contactHref = i18nPath("/parliamone", lang);
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="it" href={itUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={itUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).toString()} />
    <meta property="og:locale" content={lang === "it" ? "it_IT" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "it" ? "en_US" : "it_IT"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).toString()} />

    <!-- Theme -->
    <meta name="theme-color" content="#4A1E5C" />

    <!-- Fonts self-hosted via @fontsource (importati in globals.css), niente CDN Google -->


    <!-- Favicon (placeholder) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Header lang={lang} altHref={otherPath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Sticky AI ask widget, bottom-right su tutte le pagine -->
    <AskAIWidget lang={lang} />

    <!-- Sticky mobile CTA bottom, visible only on mobile, hidden when /parliamone is the current path -->
    <div id="sticky-cta" class="md:hidden fixed bottom-0 left-0 right-0 z-40 px-4 pb-3 pt-2 transition-transform duration-300" style="background: linear-gradient(180deg, rgba(250,250,248,0) 0%, rgba(250,250,248,0.95) 30%, #FAFAF8 100%);">
      <a href={contactHref} class="btn btn-primary w-full !justify-center shadow-lg">
        {lang === "en" ? "20 min with Daniel" : "20 min con Daniel"}
        <span class="btn-arrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>

    <script is:inline>
      // Hide sticky CTA on /parliamone (already showing form)
      (function() {
        const cta = document.getElementById("sticky-cta");
        if (!cta) return;
        const p = window.location.pathname;
        if (p.startsWith("/parliamone") || p.startsWith("/en/contact")) {
          cta.style.display = "none";
          return;
        }
        // Hide on scroll down past hero, show again on scroll up
        let lastY = window.scrollY;
        let visible = true;
        window.addEventListener("scroll", () => {
          const y = window.scrollY;
          if (y < 200) {
            // Near top: hide (hero CTAs visible)
            if (visible) { cta.style.transform = "translateY(110%)"; visible = false; }
          } else if (y > lastY + 20) {
            // scrolling down fast: hide
            if (visible) { cta.style.transform = "translateY(110%)"; visible = false; }
          } else if (y < lastY - 20) {
            // scrolling up: show
            if (!visible) { cta.style.transform = "translateY(0)"; visible = true; }
          }
          lastY = y;
        }, { passive: true });
      })();
    </script>

    <script>
      // Refined scroll-triggered reveal
      if (typeof window !== "undefined" && "IntersectionObserver" in window) {
        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (!reduced) {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("in-view");
                  io.unobserve(entry.target);
                }
              });
            },
            { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
          );
          document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
        } else {
          document.querySelectorAll(".reveal").forEach((el) => el.classList.add("in-view"));
        }
      }
    </script>
  </body>
</html>
