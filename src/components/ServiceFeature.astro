---
interface Bullet {
  badge: string;
  text: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  bullets: Bullet[];
  ctaText?: string;
  ctaHref?: string;
  reverse?: boolean;
  variant?: "phone" | "dashboard" | "code";
  lang?: "it" | "en";
}

const { eyebrow, title, description, bullets, ctaText, ctaHref, reverse = false, variant = "dashboard", lang = "it" } = Astro.props;
const m = lang === "en"
  ? {
      agent_active: "Agent active", screening: "CV screening in progress",
      agent: "Agent", active: "Active", processed: "Processed", qualified: "Qualified",
      code_c1: "// → 847 processed, 47 shortlisted", code_c2: "// → 4 hours of work recovered",
    }
  : {
      agent_active: "Agente attivo", screening: "Screening CV in corso",
      agent: "Agente", active: "Attivo", processed: "Elaborati", qualified: "Qualificati",
      code_c1: "// → 847 elaborati, 47 in shortlist", code_c2: "// → 4 ore di lavoro recuperate",
    };
---

<div class={`grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center ${reverse ? "lg:[&>*:first-child]:order-2" : ""}`}>
  <!-- Text side -->
  <div class="lg:col-span-6 reveal">
    <p class="eyebrow mb-5">{eyebrow}</p>
    <h3 class="text-[2rem] md:text-[2.5rem] font-semibold tracking-tight leading-[1.05] text-ink-900 text-balance">
      {title}
    </h3>
    <p class="mt-5 text-[17px] text-ink-700 leading-relaxed text-pretty max-w-xl">{description}</p>

    <ul class="mt-8 space-y-4">
      {bullets.map((b) => (
        <li class="flex items-start gap-3.5">
          <span class="shrink-0 mt-0.5 inline-flex w-6 h-6 rounded-full bg-violet-50 items-center justify-center">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4A1E5C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
          </span>
          <div>
            <p class="text-[15px] text-ink-900 leading-snug"><strong class="font-semibold">{b.badge}</strong> {b.text}</p>
          </div>
        </li>
      ))}
    </ul>

    {ctaText && ctaHref && (
      <a href={ctaHref} class="btn btn-primary mt-9">
        {ctaText}
        <span class="btn-arrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
    )}
  </div>

  <!-- Visual side -->
  <div class="lg:col-span-6 reveal reveal-delay-2">
    <div class="relative">
      {variant === "phone" && (
        <div class="mx-auto w-full max-w-[320px] aspect-[9/19] rounded-[2.5rem] bg-gradient-to-br from-violet-900 via-violet-800 to-violet-700 p-3 shadow-violet-lg">
          <div class="w-full h-full rounded-[2rem] bg-white overflow-hidden p-5 flex flex-col gap-3">
            <div class="flex items-center justify-between text-[10px] text-ink-500">
              <span>9:41</span>
              <span class="font-semibold text-violet-700">Soraia</span>
              <span>●●●</span>
            </div>
            <div class="rounded-xl bg-violet-50 p-3 mt-2">
              <p class="text-[11px] text-violet-700 font-semibold uppercase tracking-wider">{m.agent_active}</p>
              <p class="text-sm font-semibold text-ink-900 mt-1">{m.screening}</p>
              <div class="mt-2 h-1.5 rounded-full bg-violet-200 overflow-hidden">
                <div class="h-full w-3/4 bg-gradient-to-r from-violet-700 to-violet-500 rounded-full"></div>
              </div>
            </div>
            <div class="space-y-2 mt-1">
              {[1, 2, 3, 4].map(() => (
                <div class="rounded-lg border border-ink-100 p-2.5 flex items-center gap-2">
                  <div class="w-7 h-7 rounded-full bg-gradient-to-br from-violet-300 to-violet-500"></div>
                  <div class="flex-1 space-y-1">
                    <div class="h-1.5 rounded bg-ink-200 w-3/4"></div>
                    <div class="h-1.5 rounded bg-ink-100 w-1/2"></div>
                  </div>
                  <span class="text-[10px] font-semibold text-violet-700">92%</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {variant === "dashboard" && (
        <div class="rounded-2xl bg-gradient-to-br from-ink-900 to-ink-800 p-3 shadow-violet-lg">
          <div class="rounded-xl bg-white overflow-hidden">
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-ink-200 bg-ink-50">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-success"></span>
              <span class="ml-3 text-[11px] text-ink-500 font-mono">soraia.app/agent/screening</span>
            </div>
            <div class="p-5 space-y-4">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-[10px] uppercase tracking-wider text-ink-500 font-semibold">{m.agent}</p>
                  <p class="text-lg font-semibold text-ink-900">CV Screening Pipeline</p>
                </div>
                <span class="px-2.5 py-1 rounded-full bg-success/10 text-success text-[11px] font-semibold uppercase tracking-wider flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>
                  {m.active}
                </span>
              </div>
              <div class="grid grid-cols-3 gap-2">
                <div class="rounded-lg bg-violet-50 p-3">
                  <p class="text-[10px] uppercase text-violet-700 font-semibold">{m.processed}</p>
                  <p class="text-2xl font-semibold text-violet-700 mt-0.5">847</p>
                </div>
                <div class="rounded-lg bg-ink-50 p-3">
                  <p class="text-[10px] uppercase text-ink-500 font-semibold">{m.qualified}</p>
                  <p class="text-2xl font-semibold text-ink-900 mt-0.5">203</p>
                </div>
                <div class="rounded-lg bg-amber-soft p-3">
                  <p class="text-[10px] uppercase text-ink-600 font-semibold">Shortlist</p>
                  <p class="text-2xl font-semibold text-ink-900 mt-0.5">47</p>
                </div>
              </div>
              <div class="space-y-2">
                {[
                  { name: "Anna R.", role: "Senior Recruiter. Milano", score: 96 },
                  { name: "Marco D.", role: "Sales Rep. Roma", score: 91 },
                  { name: "Sara B.", role: "PM. Bologna", score: 88 },
                ].map((c) => (
                  <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-ink-50 transition-colors">
                    <span class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-700 to-violet-500"></span>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-ink-900">{c.name}</p>
                      <p class="text-xs text-ink-500 truncate">{c.role}</p>
                    </div>
                    <span class="px-2 py-0.5 rounded-full bg-violet-50 text-violet-700 text-xs font-semibold">{c.score}%</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      )}

      {variant === "code" && (
        <div class="rounded-2xl bg-ink-900 p-3 shadow-violet-lg">
          <div class="rounded-xl bg-ink-800 overflow-hidden">
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/10">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-success"></span>
              <span class="ml-3 text-[11px] text-white/40 font-mono">agent.ts</span>
            </div>
            <pre class="p-5 text-[12px] leading-relaxed font-mono text-white/90 overflow-hidden"><code><span class="text-violet-400">const</span> <span class="text-amber">screener</span> = <span class="text-violet-400">await</span> agent.create(&#123;
  task: <span class="text-success">"qualify candidates"</span>,
  source: ats.fetchNew(),
  rules: jd.parse(<span class="text-success">"senior-it.pdf"</span>),
&#125;);

<span class="text-violet-400">const</span> <span class="text-amber">results</span> = <span class="text-violet-400">await</span> screener.run();
<span class="text-white/40">{m.code_c1}</span>
<span class="text-white/40">{m.code_c2}</span>

ats.push(<span class="text-amber">results</span>.shortlist);
slack.notify(team, <span class="text-amber">results</span>.summary);</code></pre>
          </div>
        </div>
      )}
    </div>
  </div>
</div>
