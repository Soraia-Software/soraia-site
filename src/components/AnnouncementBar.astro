---
interface Props {
  text: string;
  ctaText: string;
  ctaHref: string;
}
const { text, ctaText, ctaHref } = Astro.props;
---

<div class="bg-gradient-to-r from-violet-900 via-violet-800 to-violet-700 text-white text-sm">
  <div class="container-soraia py-2.5 flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
    <span class="text-white/85">{text}</span>
    <a href={ctaHref} class="inline-flex items-center gap-1 font-semibold text-white hover:text-amber transition-colors">
      {ctaText}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>
