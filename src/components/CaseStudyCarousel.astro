---
import CaseStudyCardJet from "./CaseStudyCardJet.astro";

interface Item {
  slug: string;
  client: string;
  clientLogo?: string;
  quote: string;
  dimensioni?: string;
  sector: string;
  cardImage?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
const uid = `carousel-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="case-carousel" data-carousel={uid}>
  <div class="case-carousel-track" data-track={uid}>
    {items.map((it) => (
      <div class="case-carousel-item">
        <CaseStudyCardJet
          href={`/case-studies/${it.slug}`}
          client={it.client}
          clientLogo={it.clientLogo}
          quote={it.quote}
          dimensioni={it.dimensioni}
          sector={it.sector}
          cardImage={it.cardImage}
        />
      </div>
    ))}
  </div>

  <div class="case-carousel-controls mt-8 flex gap-3 reveal">
    <button
      type="button"
      class="case-carousel-btn"
      data-dir="prev"
      data-target={uid}
      aria-label="Caso precedente"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
    </button>
    <button
      type="button"
      class="case-carousel-btn"
      data-dir="next"
      data-target={uid}
      aria-label="Caso successivo"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </button>
  </div>
</div>

<style>
  .case-carousel {
    position: relative;
  }
  .case-carousel-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 78%;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 1rem;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }
  .case-carousel-track::-webkit-scrollbar {
    display: none;
  }
  .case-carousel-item {
    scroll-snap-align: start;
    min-width: 0;
  }
  @media (min-width: 640px) {
    .case-carousel-track {
      grid-auto-columns: 48%;
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .case-carousel-track {
      grid-auto-columns: 30%;
      gap: 1.5rem;
    }
  }
  .case-carousel-btn {
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    border: 1px solid var(--color-line, #e4e4e7);
    background: white;
    color: var(--color-ink, #0a0a0a);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .case-carousel-btn:hover {
    background: var(--color-ink-50, #f5f5f5);
    border-color: var(--color-ink, #0a0a0a);
    transform: translateY(-1px);
  }
  .case-carousel-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".case-carousel-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.getAttribute("data-target");
      const dir = btn.getAttribute("data-dir");
      const track = document.querySelector<HTMLElement>(`[data-track="${target}"]`);
      if (!track) return;
      const firstItem = track.querySelector<HTMLElement>(".case-carousel-item");
      const step = firstItem ? firstItem.offsetWidth + 16 : track.clientWidth * 0.8;
      track.scrollBy({ left: dir === "next" ? step : -step, behavior: "smooth" });
    });
  });
</script>
