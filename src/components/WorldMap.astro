---
interface Dot {
  x: number;  // percent left
  y: number;  // percent top
  label: string;
}

interface Props {
  dots: Dot[];
}

const { dots } = Astro.props;
---

<div class="relative w-full max-w-5xl mx-auto">
  <!-- Real Wikimedia world map loaded as <img>, styled with CSS filters -->
  <img
    src="/maps/world.svg"
    alt=""
    aria-hidden="true"
    loading="lazy"
    class="w-full h-auto select-none pointer-events-none world-map-img"
  />

  <!-- Animated dots for active markets -->
  {dots.map((dot, i) => (
    <div
      class="absolute reveal"
      style={`left: ${dot.x}%; top: ${dot.y}%; transform: translate(-50%, -50%); transition-delay: ${i * 60}ms;`}
    >
      <span class="relative flex w-3 h-3">
        <span class="absolute inset-0 rounded-full bg-violet-600 opacity-75 animate-ping" style={`animation-delay: ${i * 0.5}s`}></span>
        <span class="relative inline-flex w-3 h-3 rounded-full bg-violet-700 shadow-[0_0_18px_rgba(159,26,177,0.55)] ring-2 ring-white"></span>
      </span>
      <span class="absolute left-1/2 -translate-x-1/2 -bottom-6 text-[10px] md:text-[11px] font-semibold text-ink-700 whitespace-nowrap bg-white/85 backdrop-blur-sm px-1.5 py-0.5 rounded shadow-sm">
        {dot.label}
      </span>
    </div>
  ))}
</div>

<style is:global>
  .world-map-img {
    filter:
      brightness(0)
      saturate(100%)
      invert(85%)
      sepia(8%)
      saturate(338%)
      hue-rotate(338deg)
      brightness(95%)
      contrast(91%);
    /* Equivalent to soft warm grey (#D5D3CD / ink-300) */
    opacity: 0.45;
    mix-blend-mode: multiply;
  }
</style>
