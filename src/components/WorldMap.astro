---
interface CountryBreakdown {
  flag: string;
  name: string;
  count: number;
}

interface Region {
  x: number;          // percent left
  y: number;          // percent top
  label: string;
  flag: string;
  total: number;
  countries: CountryBreakdown[];
  align?: "left" | "right" | "center";
}

interface Props {
  regions: Region[];
  lang?: "it" | "en";
}

const { regions, lang = "it" } = Astro.props;
const clientsLabel = lang === "en" ? "clients" : "clienti";
---

<div class="world-map-wrapper">
  <img
    src="/maps/world map.webp"
    alt=""
    aria-hidden="true"
    loading="lazy"
    class="world-map-img"
    width="2400"
    height="1100"
  />

  {regions.map((r) => (
    <div
      class="region-marker reveal"
      style={`left: ${r.x}%; top: ${r.y}%;`}
      data-align={r.align ?? "center"}
    >
      <button
        type="button"
        class="region-dot"
        aria-label={`${r.label}, ${r.total} ${clientsLabel}`}
      >
        <span class="region-pulse"></span>
        <span class="region-core"></span>
      </button>

      <div class="region-popup">
        <div class="region-popup-flag">{r.flag}</div>
        <p class="region-popup-name">{r.label}</p>
        <p class="region-popup-total">{r.total} {clientsLabel}</p>
        {r.countries.length > 1 && (
          <ul class="region-popup-list">
            {r.countries.map((c) => (
              <li>
                <span class="popup-flag">{c.flag}</span>
                <span class="popup-text"><strong>{c.count}</strong> {c.name}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  ))}
</div>

<style is:global>
  .world-map-wrapper {
    position: relative;
    width: 100%;
    max-width: 1100px;
    margin-inline: auto;
  }

  .world-map-img {
    display: block;
    width: 100%;
    height: auto;
    user-select: none;
    -webkit-user-select: none;
  }

  /* Region marker container */
  .region-marker {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 10;
  }

  /* Pulsing dot button */
  .region-dot {
    position: relative;
    width: 14px;
    height: 14px;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .region-pulse {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: rgba(74, 30, 92, 0.20);
    animation: ping 2.8s var(--ease-out-quart) infinite;
  }

  .region-core {
    position: relative;
    width: 10px;
    height: 10px;
    border-radius: 9999px;
    background: #4A1E5C;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.95), 0 1px 3px rgba(42, 14, 54, 0.30);
    transition: transform 0.3s var(--ease-out-quart);
  }

  .region-dot:hover .region-core,
  .region-dot:focus-visible .region-core {
    transform: scale(1.3);
  }

  @keyframes ping {
    0%   { transform: scale(0.9); opacity: 0.55; }
    75%, 100% { transform: scale(3.2); opacity: 0; }
  }

  /* Popup card, visible on hover/focus */
  .region-popup {
    position: absolute;
    bottom: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 200px;
    max-width: 240px;
    background: white;
    border-radius: 14px;
    border: 1px solid var(--color-line-strong);
    padding: 14px 16px;
    box-shadow: 0 12px 32px -8px rgba(10, 10, 11, 0.18);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s;
    pointer-events: none;
    z-index: 20;
  }

  .region-marker[data-align="left"] .region-popup {
    left: 0;
    transform: translateX(-12px) translateY(8px);
  }

  .region-marker[data-align="right"] .region-popup {
    left: auto;
    right: 0;
    transform: translateX(12px) translateY(8px);
  }

  .region-marker:hover .region-popup,
  .region-marker:focus-within .region-popup {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .region-marker[data-align="left"]:hover .region-popup,
  .region-marker[data-align="left"]:focus-within .region-popup {
    transform: translateX(-12px) translateY(0);
  }

  .region-marker[data-align="right"]:hover .region-popup,
  .region-marker[data-align="right"]:focus-within .region-popup {
    transform: translateX(12px) translateY(0);
  }

  .region-popup::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: white;
    filter: drop-shadow(0 2px 1px rgba(10, 10, 11, 0.08));
  }

  .region-marker[data-align="left"] .region-popup::after { left: 16px; transform: none; }
  .region-marker[data-align="right"] .region-popup::after { left: auto; right: 16px; transform: none; }

  .region-popup-flag {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: var(--color-ink-50);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 19px;
    line-height: 1;
    margin-bottom: 8px;
    box-shadow: 0 0 0 1px var(--color-line);
  }

  .region-popup-name {
    font-weight: 500;
    color: var(--color-ink);
    font-size: 14.5px;
    line-height: 1.2;
    margin-bottom: 2px;
  }

  .region-popup-total {
    font-size: 12px;
    color: var(--color-ink-soft);
    font-weight: 500;
    margin-bottom: 10px;
  }

  .region-popup-list {
    border-top: 1px solid var(--color-line);
    padding-top: 10px;
    margin: 0;
    list-style: none;
  }

  .region-popup-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 3px 0;
    font-size: 12.5px;
    color: var(--color-ink-muted);
  }

  .popup-flag {
    font-size: 14px;
    line-height: 1;
    flex-shrink: 0;
  }

  .popup-text strong {
    color: var(--color-ink);
    font-weight: 500;
  }
</style>
