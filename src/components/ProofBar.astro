---
interface Logo {
  name: string;
  detail?: string;
}

interface Props {
  label: string;
  logos: Logo[];
}

const { label, logos } = Astro.props;
---

<section class="border-y border-ink-200 bg-white/50 backdrop-blur-sm">
  <div class="container-soraia py-10">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-ink-500 text-center mb-6">
      {label}
    </p>
    <ul class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
      {logos.map((logo) => (
        <li class="flex flex-col items-center">
          <span class="text-lg md:text-xl font-bold tracking-tight text-ink-700 hover:text-violet-700 transition-colors">
            {logo.name}
          </span>
          {logo.detail && (
            <span class="text-xs text-ink-500 mt-0.5">{logo.detail}</span>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>
