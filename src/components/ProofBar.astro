---
interface Logo {
  name: string;
  src?: string;       // path to logo image (svg/png/jpg)
  detail?: string;
}

interface Props {
  label: string;
  logos: Logo[];
}

const { label, logos } = Astro.props;

// Build seamless marquee track: ensure each "half" of the track is wide enough
// to overflow the widest common viewport. With few logos (e.g. 4), we need
// multiple repetitions per half so translateX(-50%) loops without visible gaps.
const MIN_CELLS_PER_HALF = 8;
const repeatsPerHalf = Math.max(1, Math.ceil(MIN_CELLS_PER_HALF / Math.max(1, logos.length)));
const halfTrack = Array.from({ length: repeatsPerHalf }, () => logos).flat();
const doubled = [...halfTrack, ...halfTrack];
---

<section class="py-14 md:py-16 border-y border-ink-200 bg-white">
  <div class="container-soraia">
    <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 text-center mb-9">
      {label}
    </p>
  </div>

  <div class="marquee">
    <div class="marquee-track">
      {doubled.map((logo, idx) => (
        <div
          class="proofbar-cell shrink-0"
          aria-hidden={idx >= halfTrack.length ? "true" : undefined}
          title={logo.name}
        >
          {logo.src ? (
            <img
              src={logo.src}
              alt={logo.name}
              loading="lazy"
              decoding="async"
              class="logo-img"
            />
          ) : (
            <span class="text-xl md:text-2xl font-semibold tracking-tight text-ink-400 hover:text-ink-900 transition-colors duration-300 whitespace-nowrap">
              {logo.name}
            </span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  /* Uniform bounding box per logo: same visual real estate for square / wide / tall logos */
  .proofbar-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 150px;
    height: 60px;
    padding: 0 0.5rem;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .proofbar-cell { width: 170px; height: 64px; }
  }

  /* Logo image: fits within cell, max constraints both dimensions */
  .proofbar-cell .logo-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.55) contrast(1.1);
    opacity: 0.75;
    transition: filter 0.4s var(--ease-out-quart), opacity 0.4s var(--ease-out-quart);
    /* mix-blend-mode helps any residual white halo from logo backgrounds disappear into the strip bg */
    mix-blend-mode: multiply;
  }

  /* Square / padded source images look small vs wide logos in a fixed cell.
     Scale up specific ones to match the perceived size of the others. */
  .proofbar-cell .logo-img[src*="navily"],
  .proofbar-cell .logo-img[src*="storywonder"] {
    transform: scale(1.45);
    transform-origin: center;
  }
  .marquee:hover .proofbar-cell .logo-img,
  .proofbar-cell .logo-img:hover {
    filter: grayscale(0%) brightness(1);
    opacity: 1;
  }
</style>
