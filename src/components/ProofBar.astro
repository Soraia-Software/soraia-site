---
interface Logo {
  name: string;
  detail?: string;
}

interface Props {
  label: string;
  logos: Logo[];
}

const { label, logos } = Astro.props;

// Duplicate for seamless marquee loop
const doubled = [...logos, ...logos];
---

<section class="py-14 md:py-16 border-y border-ink-200 bg-white">
  <div class="container-soraia">
    <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-500 text-center mb-9">
      {label}
    </p>
  </div>

  <div class="marquee">
    <div class="marquee-track">
      {doubled.map((logo, idx) => (
        <div
          class="flex items-center shrink-0 px-2"
          aria-hidden={idx >= logos.length ? "true" : undefined}
        >
          <span class="font-display text-xl md:text-2xl font-semibold tracking-tight text-ink-400 hover:text-ink-900 transition-colors duration-300 whitespace-nowrap">
            {logo.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
