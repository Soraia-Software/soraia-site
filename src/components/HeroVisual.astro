const icons: Record<string, string> = {
  doc: `<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>`,
  mail: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
  calendar: `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  search: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  check: `<polyline points="20 6 9 17 4 12"/>`,
  chart: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  users: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  briefcase: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  trending: `<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>`,
  headphones: `<path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/><path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>`,
  target: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
};
---

<div class="agent-feed-soraia" aria-label="Soraia agents, live workflow per industry">

  <!-- Industry tabs -->
  <div class="afs-tabs" role="tablist" aria-label="Industries">
    {industries.map((ind, i) => (
      <button
        type="button"
        class={`afs-tab ${i === 0 ? "is-active" : ""}`}
        data-tab={ind.id}
        role="tab"
        aria-selected={i === 0 ? "true" : "false"}
      >
        <span class="afs-tab-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[ind.industryIcon]} />
        </span>
        <span class="afs-tab-label">{ind.label}</span>
      </button>
    ))}
  </div>

  <!-- Feed card -->
  <div class="afs-card">
    <!-- Header -->
    <div class="afs-header">
      <span class="afs-dot"></span>
      <span class="afs-header-label">Soraia · agent activity</span>
      <span class="afs-time" data-feed-clock>·</span>
    </div>

    <!-- Industry context -->
    <div class="afs-context">
      <div class="afs-industry-row">
        <span class="afs-industry-icon" data-industry-icon>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></svg>
        </span>
        <span class="afs-industry-name" data-industry-name>·</span>
      </div>
      <p class="afs-industry-role" data-industry-role>·</p>
    </div>

    <!-- Events stream -->
    <ol class="afs-events">
      {[0,1,2,3,4,5].map((i) => (
        <li class="afs-event" data-slot={i}>
          <span class="afs-event-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></svg>
          </span>
          <div class="afs-event-body">
            <span class="afs-agent"></span>
            <span class="afs-text"></span>
          </div>
          <span class="afs-event-check">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
        </li>
      ))}
    </ol>

    <!-- Footer progress -->
    <div class="afs-footer">
      <div class="afs-progress"><span class="afs-progress-fill" data-feed-progress></span></div>
      <span class="afs-time-mono" data-feed-total>00:24</span>
    </div>
  </div>

</div>

<script is:inline define:vars={{ industries, icons }}>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;

    const tabs = root.querySelectorAll(".afs-tab");
    const slots = root.querySelectorAll(".afs-event");
    const clockEl = root.querySelector("[data-feed-clock]");
    const nameEl = root.querySelector("[data-industry-name]");
    const industryIconEl = root.querySelector("[data-industry-icon] svg");
    const roleEl = root.querySelector("[data-industry-role]");
    const progressEl = root.querySelector("[data-feed-progress]");

    let activeId = industries[0].id;
    let cycleTimeout = null;
    let userInteracted = false;
    let stepTimeouts = [];

    function pad(n) { return n < 10 ? "0" + n : "" + n; }
    function fmtTime(d) { return pad(d.getHours()) + ":" + pad(d.getMinutes()) + ":" + pad(d.getSeconds()); }

    function clearSlots() {
      slots.forEach((s) => {
        s.classList.remove("is-visible");
        s.querySelector(".afs-agent").textContent = "";
        s.querySelector(".afs-text").textContent = "";
        const svg = s.querySelector(".afs-event-icon svg");
        if (svg) svg.innerHTML = "";
      });
      progressEl.style.transform = "scaleX(0)";
    }

    function clearTimeouts() {
      stepTimeouts.forEach(clearTimeout);
      stepTimeouts = [];
      if (cycleTimeout) { clearTimeout(cycleTimeout); cycleTimeout = null; }
    }

    function setActive(id) {
      tabs.forEach((t) => {
        const isActive = t.dataset.tab === id;
        t.classList.toggle("is-active", isActive);
        t.setAttribute("aria-selected", isActive ? "true" : "false");
      });
      activeId = id;
    }

    function renderIndustry(id, autoNext = false) {
      const ind = industries.find((i) => i.id === id);
      if (!ind) return;

      clearTimeouts();
      clearSlots();
      setActive(id);

      nameEl.textContent = ind.label;
      if (industryIconEl && icons[ind.industryIcon]) industryIconEl.innerHTML = icons[ind.industryIcon];
      roleEl.textContent = ind.role;
      clockEl.textContent = fmtTime(new Date());

      const STEP_MS = 950;

      ind.events.forEach((ev, i) => {
        const t = setTimeout(() => {
          const slot = slots[i];
          slot.querySelector(".afs-agent").textContent = ev.agent;
          slot.querySelector(".afs-text").textContent = ev.text;
          const svg = slot.querySelector(".afs-event-icon svg");
          if (svg && icons[ev.icon]) svg.innerHTML = icons[ev.icon];
          slot.classList.add("is-visible");
          progressEl.style.transform = "scaleX(" + ((i + 1) / ind.events.length) + ")";
        }, i * STEP_MS);
        stepTimeouts.push(t);
      });

      // Auto-cycle to next industry only if user hasn't clicked
      if (autoNext && !userInteracted) {
        const TOTAL_MS = STEP_MS * ind.events.length;
        cycleTimeout = setTimeout(() => {
          if (!userInteracted) {
            const idx = industries.findIndex((i) => i.id === id);
            const next = industries[(idx + 1) % industries.length];
            renderIndustry(next.id, true);
          }
        }, TOTAL_MS + 3500);
      }
    }

    // Tab click handler
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        userInteracted = true;
        renderIndustry(tab.dataset.tab, false);
      });
    });

    // Init
    const prefersReduced = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) {
      const ind = industries[0];
      nameEl.textContent = ind.label;
      if (industryIconEl && icons[ind.industryIcon]) industryIconEl.innerHTML = icons[ind.industryIcon];
      roleEl.textContent = ind.role;
      progressEl.style.transform = "scaleX(1)";
      ind.events.forEach((ev, i) => {
        const slot = slots[i];
        slot.querySelector(".afs-agent").textContent = ev.agent;
        slot.querySelector(".afs-text").textContent = ev.text;
        const svg = slot.querySelector(".afs-event-icon svg");
        if (svg && icons[ev.icon]) svg.innerHTML = icons[ev.icon];
        slot.classList.add("is-visible");
      });
      return;
    }

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          renderIndustry(industries[0].id, true);
          io.disconnect();
        }
      });
    }, { threshold: 0.1 });
    io.observe(root);
  })();
</script>

<style>
  .agent-feed-soraia {
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Industry tabs */
  .afs-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }

  .afs-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    font-size: 12.5px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    cursor: pointer;
    transition: all 200ms ease;
    font-family: var(--font-sans);
    line-height: 1;
  }
  .afs-tab:hover {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.9);
  }
  .afs-tab.is-active {
    background: white;
    color: var(--color-violet-900);
    border-color: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }
  .afs-tab-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
  }
  .afs-tab.is-active .afs-tab-icon { opacity: 1; }

  /* Card */
  .afs-card {
    background: #FFFFFF;
    border: 1px solid var(--color-line);
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 24px 60px -28px rgba(137, 45, 156, 0.30),
      0 32px 80px -32px rgba(74, 30, 92, 0.20);
    font-size: 13px;
    line-height: 1.5;
  }

  /* Header */
  .afs-header {
    background: linear-gradient(135deg, #1F0828 0%, #2A0E36 100%);
    color: white;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .afs-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #17B26A;
    box-shadow: 0 0 0 0 rgba(23, 178, 106, 0.55);
    animation: afsPulse 1.8s ease-out infinite;
    flex-shrink: 0;
  }
  .afs-header-label { text-transform: uppercase; flex: 1; opacity: 0.92; }
  .afs-header .afs-time { opacity: 0.6; font-variant-numeric: tabular-nums; }

  @keyframes afsPulse {
    0%   { box-shadow: 0 0 0 0 rgba(23, 178, 106, 0.55); }
    100% { box-shadow: 0 0 0 10px rgba(23, 178, 106, 0); }
  }

  /* Industry context */
  .afs-context {
    padding: 1.1rem 1.25rem 1rem;
    border-bottom: 1px solid var(--color-line);
  }
  .afs-industry-row {
    display: flex; align-items: center; gap: 0.6rem;
    font-size: 17px; font-weight: 500; color: var(--color-ink);
  }
  .afs-industry-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px; height: 26px;
    border-radius: 0.5rem;
    background: var(--color-violet-50);
    color: var(--color-violet-700);
    flex-shrink: 0;
  }
  .afs-industry-role {
    margin-top: 0.3rem;
    font-size: 12.5px;
    color: var(--color-ink-soft);
    line-height: 1.4;
  }

  /* Events */
  .afs-events {
    list-style: none;
    padding: 0.6rem 0;
    margin: 0;
    min-height: 290px;
  }
  .afs-event {
    display: grid;
    grid-template-columns: 30px 1fr 18px;
    gap: 0.8rem;
    align-items: center;
    padding: 0.6rem 1.25rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 400ms ease, transform 400ms ease;
  }
  .afs-event.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .afs-event-icon {
    width: 30px; height: 30px;
    border-radius: 0.625rem;
    background: linear-gradient(135deg, #4A1E5C 0%, #4A1E5C 100%);
    color: white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .afs-event-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .afs-agent {
    color: var(--color-violet-700);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    font-weight: 600;
    text-transform: uppercase;
  }
  .afs-text {
    color: var(--color-ink);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.35;
  }
  .afs-event-check {
    color: #17B26A;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Footer */
  .afs-footer {
    border-top: 1px solid var(--color-line);
    background: #FAFAF8;
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .afs-progress {
    flex: 1;
    height: 3px;
    background: var(--color-line);
    border-radius: 2px;
    overflow: hidden;
  }
  .afs-progress-fill {
    display: block;
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, #4A1E5C 0%, #4A1E5C 100%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.9s ease;
  }
  .afs-time-mono {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-soft);
    font-variant-numeric: tabular-nums;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .afs-card { border-radius: 1.25rem; }
    .afs-event { grid-template-columns: 26px 1fr 16px; padding: 0.5rem 1rem; }
    .afs-event-icon { width: 26px; height: 26px; }
    .afs-tab { font-size: 11.5px; padding: 0.35rem 0.7rem; }
  }
</style>
