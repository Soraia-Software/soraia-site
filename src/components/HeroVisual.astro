    ],
  },
  {
    id: "vc",
    label: "Venture Capital",
    industryIcon: "trending",
    role: "Per fondi VC/PE, family office, M&A",
    events: [
      { agent: "INTAKE",     icon: "doc",      text: "14 deck letti · sintesi 1-pager generata" },
      { agent: "ENRICHMENT", icon: "search",   text: "+Crunchbase · +PitchBook · +founder LinkedIn" },
      { agent: "SCORE",      icon: "check",    text: "Scoring multi-criterio · top-quartile flagged" },
      { agent: "DD",         icon: "doc",      text: "Due diligence room organizzata · 32 docs" },
      { agent: "MONITOR",    icon: "calendar", text: "Portfolio KPI tracker · alerts settati" },
      { agent: "ANALYTICS",  icon: "chart",    text: "8 ore senior team risparmiate per deal" },
    ],
  },
  {
    id: "support",
    label: "Customer Support",
    industryIcon: "headphones",
    role: "Per CS teams, customer ops, helpdesk",
    events: [
      { agent: "TRIAGE",     icon: "search",   text: "127 ticket classificati · priorità assegnata" },
      { agent: "DRAFT",      icon: "doc",      text: "Risposte preparate · tone match brand voice" },
      { agent: "ROUTE",      icon: "mail",     text: "Smistato a team specializzato · context passato" },
      { agent: "ESCALATE",   icon: "check",    text: "3 casi critici flaggati a senior · SLA tracker" },
      { agent: "TRACK",      icon: "chart",    text: "Sentiment + SLA monitor real-time" },
      { agent: "ANALYTICS",  icon: "chart",    text: "First response time ridotto del 70%" },
    ],
  },
  {
    id: "sales",
    label: "Sales & Marketing",
    industryIcon: "target",
    role: "Per sales teams, growth, marketing ops",
    events: [
      { agent: "PROSPECT",   icon: "search",   text: "240 lead identificati · ICP match score" },
      { agent: "ENRICHMENT", icon: "doc",      text: "+contatti · +tech stack · +intent signals" },
      { agent: "QUALIFY",    icon: "check",    text: "BANT score · pipeline-ready filter" },
      { agent: "OUTREACH",   icon: "mail",     text: "Sequence multi-canale personalizzata" },
      { agent: "TRACK",      icon: "calendar", text: "Engagement + reply tracking · auto follow-up" },
      { agent: "ANALYTICS",  icon: "chart",    text: "Pipeline qualificato +42% trimestre" },
    ],
