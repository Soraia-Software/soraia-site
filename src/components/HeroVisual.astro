---
// Abstract domain-agnostic agent-at-work visualization for hero
---

<div class="relative w-full h-full min-h-[440px] lg:min-h-[520px] flex items-center justify-center">
  <!-- Floating orbs as background -->
  <div class="absolute inset-0">
    <div class="orb orb-lilac w-[420px] h-[420px] -top-10 -right-20 opacity-50 float-slow" aria-hidden="true"></div>
    <div class="orb orb-amber w-[280px] h-[280px] -bottom-20 -left-10 opacity-30 float-slower" aria-hidden="true"></div>
  </div>

  <!-- Main floating dashboard card — generic agent metrics -->
  <div class="relative z-10 w-full max-w-md float-slower" style="animation-duration: 22s">
    <div class="rounded-3xl bg-white/95 backdrop-blur-xl shadow-2xl border border-white/40 p-6">
      <div class="flex items-center justify-between mb-5">
        <div class="flex items-center gap-2.5">
          <span class="inline-block w-8 h-8 rounded-lg bg-gradient-to-br from-violet-700 to-violet-500"></span>
          <div>
            <p class="text-[10px] uppercase tracking-wider text-ink-500 font-semibold">Agente</p>
            <p class="font-display text-sm font-semibold text-ink-900">Soraia · in produzione</p>
          </div>
        </div>
        <span class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-emerald-50 text-emerald-700 text-[10px] font-semibold uppercase tracking-wider">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
          Live
        </span>
      </div>

      <div class="grid grid-cols-3 gap-2 mb-5">
        <div class="rounded-xl bg-violet-50 p-3">
          <p class="text-[9px] uppercase text-violet-700 font-semibold">Task</p>
          <p class="font-display text-xl font-semibold text-violet-700">1.247</p>
        </div>
        <div class="rounded-xl bg-ink-50 p-3">
          <p class="text-[9px] uppercase text-ink-500 font-semibold">Ore</p>
          <p class="font-display text-xl font-semibold text-ink-900">+24<span class="text-xs">/sett</span></p>
        </div>
        <div class="rounded-xl bg-amber/15 p-3">
          <p class="text-[9px] uppercase text-ink-700 font-semibold">Precis.</p>
          <p class="font-display text-xl font-semibold text-ink-900">97<span class="text-xs">%</span></p>
        </div>
      </div>

      <div class="space-y-2">
        {[
          { icon: "doc", label: "Documento analizzato", time: "12s fa" },
          { icon: "mail", label: "Email inviata", time: "1m fa" },
          { icon: "calendar", label: "Calendar invite", time: "3m fa" },
        ].map((item) => (
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-ink-50 transition-colors">
            <span class="w-7 h-7 rounded-full bg-gradient-to-br from-violet-700 to-violet-500 text-white flex items-center justify-center">
              {item.icon === "doc" && (
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              )}
              {item.icon === "mail" && (
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              )}
              {item.icon === "calendar" && (
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              )}
            </span>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-medium text-ink-900 leading-tight">{item.label}</p>
            </div>
            <span class="text-[10px] text-ink-400">{item.time}</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#17B26A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Floating bubble: AI status -->
  <div class="absolute z-20 hidden md:block top-[6%] left-[-3%] float-slow" style="animation-duration: 17s">
    <div class="rounded-2xl bg-ink-900 shadow-xl p-4 max-w-[220px]">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-6 h-6 rounded-full bg-gradient-to-br from-violet-500 to-violet-300"></span>
        <span class="text-[10px] font-semibold text-white/60 uppercase tracking-wider">Soraia Agent</span>
      </div>
      <p class="text-[12px] text-white leading-relaxed">Pronti per il prossimo task? Ho già preparato il summary.</p>
    </div>
  </div>

  <!-- Floating bubble: savings -->
  <div class="absolute z-20 hidden md:block bottom-[8%] right-[-3%] float-slower" style="animation-duration: 20s">
    <div class="rounded-2xl bg-white shadow-xl p-4 border border-violet-100 max-w-[180px]">
      <p class="text-[10px] uppercase tracking-wider text-violet-700 font-semibold mb-1">Tempo recuperato</p>
      <p class="font-display text-2xl font-semibold text-ink-900 leading-none">+24 h<span class="text-base text-ink-500 font-normal">/sett</span></p>
      <p class="text-[10px] text-ink-500 mt-1">per persona</p>
    </div>
  </div>
</div>
