      { agent: "VALIDATE",   icon: "check",    text: "IVA + codici verificati · anomalie segnalate" },
      { agent: "RECONCILE",  icon: "search",   text: "Riconciliazione bancaria · 218 movimenti" },
      { agent: "REPORT",     icon: "chart",    text: "F24 generato · pronto per revisione" },
      { agent: "NOTIFY",     icon: "mail",     text: "Client portal aggiornato · 8 clienti notificati" },
