      { agent: "ENRICHMENT", icon: "search",   text: "+LinkedIn · +email · +stack tecnico" },
      { agent: "QUALIFY",    icon: "check",    text: "47 candidati shortlisted · score >88%" },
      { agent: "OUTREACH",   icon: "mail",     text: "Primo touch personalizzato · multi-lingua" },
      { agent: "SCHEDULE",   icon: "calendar", text: "12 colloqui prenotati · auto sync ATS" },
      { agent: "ANALYTICS",  icon: "chart",    text: "19 giorni-uomo recuperati questa settimana" },
