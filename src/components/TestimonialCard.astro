---
import AvatarCircle from "./AvatarCircle.astro";

interface Props {
  quote: string;
  name: string;
  role: string;
  company?: string;
  photoSrc?: string;
  rating?: number;
  // optional case-study fields (for GEO/SEO + human scannability)
  project?: string;
  sector?: string;
  problem?: string;
  action?: string;
  resultMetric?: string;
  resultBody?: string;
  caseSlug?: string;  // if present, footer becomes a link to /case-studies/<slug>
}

const {
  quote,
  name,
  role,
  company,
  photoSrc,
  rating = 5,
  project,
  sector,
  problem,
  action,
  resultMetric,
  resultBody,
  caseSlug,
} = Astro.props;

const caseHref = caseSlug ? `/case-studies/${caseSlug}` : null;
const resultPreview = resultMetric || null;
---

<article class="card-editorial group flex flex-col gap-5 h-full reveal !p-7 md:!p-8">
  {(project || sector) && (
    <p class="text-[11px] font-medium tracking-[0.14em] uppercase" style="color: var(--color-ink-soft);">
      {project}{project && sector && <span style="opacity: 0.5;"> · </span>}{sector}
    </p>
  )}

  <div class="flex items-center gap-1 text-amber">
    {Array.from({ length: rating }).map(() => (
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    ))}
  </div>

  <p class="text-[15.5px] leading-relaxed text-pretty flex-1" style="color: var(--color-ink);">"{quote}"</p>

  <footer class="flex items-center gap-3 pt-1">
    <AvatarCircle name={name} src={photoSrc} size="md" variant="violet" />
    <div>
      <p class="font-medium text-[14px] leading-tight" style="color: var(--color-ink);">{name}</p>
      <p class="text-[12px] mt-0.5 leading-tight" style="color: var(--color-ink-soft);">
        {role}{company && <span style="opacity: 0.7;"> · {company}</span>}
      </p>
    </div>
  </footer>

  {(resultPreview || caseHref) && (
    <div class="pt-5 mt-auto border-t border-line flex flex-wrap items-center justify-between gap-3">
      {resultPreview && (
        <p class="text-[13.5px] font-medium leading-snug" style="color: var(--color-brand); letter-spacing: -0.01em;">{resultPreview}</p>
      )}
      {caseHref && (
        <a href={caseHref} class="inline-flex items-center gap-1.5 text-[13px] font-medium group/cta no-underline" style="color: var(--color-brand);">
          Leggi il case study
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/cta:translate-x-1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      )}
    </div>
  )}
</article>
