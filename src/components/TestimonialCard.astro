---
import AvatarCircle from "./AvatarCircle.astro";

interface Props {
  quote: string;
  name: string;
  role: string;
  company?: string;
  photoSrc?: string;
  rating?: number;
}

const { quote, name, role, company, photoSrc, rating = 5 } = Astro.props;
---

<article class="card-editorial group flex flex-col gap-5 h-full reveal !p-7">
  <div class="flex items-center gap-1 text-amber">
    {Array.from({ length: rating }).map(() => (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    ))}
  </div>

  <p class="text-[15px] text-ink-700 leading-relaxed text-pretty flex-1">"{quote}"</p>

  <footer class="flex items-center gap-3 pt-2 mt-auto">
    <AvatarCircle name={name} src={photoSrc} size="md" variant="violet" />
    <div>
      <p class="font-semibold text-ink-900 text-sm leading-tight">{name}</p>
      <p class="text-xs text-ink-500 mt-0.5 leading-tight">
        {role}{company && <span class="text-ink-400"> · {company}</span>}
      </p>
    </div>
  </footer>
</article>
