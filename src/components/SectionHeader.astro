---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  variant?: "default" | "dark";
}

const { eyebrow, title, subtitle, align = "left", variant = "default" } = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "";
const eyebrowClass = variant === "dark" ? "eyebrow eyebrow-light" : "eyebrow";
const titleClass = variant === "dark" ? "text-white" : "text-ink-900";
const subtitleClass = variant === "dark" ? "text-white/70" : "text-ink-600";
---

<header class={`max-w-3xl ${alignClass} mb-14 md:mb-20 reveal`}>
  {eyebrow && (
    <p class={`${eyebrowClass} mb-6`}>
      {eyebrow}
    </p>
  )}
  <h2 class={`font-display text-[2.5rem] md:text-[3.75rem] lg:text-[4.25rem] font-semibold tracking-[-0.035em] ${titleClass} leading-[0.98] text-balance`}>
    <slot name="title">{title}</slot>
  </h2>
  {subtitle && (
    <p class={`mt-6 text-[17px] md:text-[19px] ${subtitleClass} leading-relaxed text-pretty max-w-2xl`}>
      <Fragment set:html={subtitle} />
    </p>
  )}
</header>
