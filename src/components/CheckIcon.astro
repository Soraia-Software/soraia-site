---
interface Props {
  variant?: "violet" | "default";
}
const { variant = "default" } = Astro.props;
const bgClass = variant === "violet" ? "bg-violet-600" : "bg-violet-600/15";
const strokeClass = variant === "violet" ? "white" : "#892D9C";
---

<span class={`inline-flex w-5 h-5 rounded-full ${bgClass} items-center justify-center shrink-0`}>
  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke={strokeClass} stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 6L9 17l-5-5" />
  </svg>
</span>
