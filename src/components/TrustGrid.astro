---
interface TrustItem {
  title: string;
  description: string;
  icon: "shield" | "user-shield" | "scale" | "globe" | "eye" | "lock";
}

interface Props {
  items: TrustItem[];
}

const { items } = Astro.props;

const icons = {
  shield: `<path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/>`,
  "user-shield": `<path d="M20 7l-8-4-8 4v6c0 4 3 7 8 8 5-1 8-4 8-8V7z"/><circle cx="12" cy="11" r="2"/><path d="M8 16c1-1 2.5-2 4-2s3 1 4 2"/>`,
  scale: `<path d="M12 3v18M5 8l-3 6c0 2 1.5 3 3 3s3-1 3-3l-3-6zM19 8l-3 6c0 2 1.5 3 3 3s3-1 3-3l-3-6zM4 21h16"/>`,
  globe: `<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2c2.5 3 4 6.5 4 10s-1.5 7-4 10c-2.5-3-4-6.5-4-10s1.5-7 4-10z"/>`,
  eye: `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`,
  lock: `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>`,
};
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
  {items.map((item) => (
    <article class="card !p-7 flex flex-col gap-4">
      <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-violet-700 to-violet-600 flex items-center justify-center shadow-violet">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]} />
      </div>
      <div>
        <h3 class="font-bold text-ink-900">{item.title}</h3>
        <p class="mt-1.5 text-sm text-ink-600 leading-relaxed">{item.description}</p>
      </div>
    </article>
  ))}
</div>
