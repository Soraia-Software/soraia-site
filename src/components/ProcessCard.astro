---
interface Props {
  number: string;
  title: string;
  description: string;
  icon: "screen" | "outreach" | "match" | "calendar" | "compass" | "transcript";
}

const { number, title, description, icon } = Astro.props;

const icons = {
  screen: `<path d="M3 7h18M3 12h18M3 17h12"/><circle cx="20" cy="17" r="3"/>`,
  outreach: `<path d="M3 21v-2a4 4 0 014-4h6a4 4 0 014 4v2"/><circle cx="10" cy="7" r="4"/><path d="M17 11l3-3-3-3"/>`,
  match: `<path d="M9 11l3 3 8-8"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>`,
  calendar: `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>`,
  compass: `<circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/>`,
  transcript: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="14" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/><line x1="9" y1="9" x2="10" y2="9"/>`,
};
---

<article class="card-editorial group h-full flex flex-col reveal">
  <header class="flex items-baseline justify-between mb-8">
    <span class="text-[3.5rem] font-semibold leading-none tracking-[-0.04em] text-ink-200 group-hover:text-violet-200 transition-colors duration-500">
      {number}
    </span>
    <div class="w-10 h-10 rounded-full bg-ink-50 flex items-center justify-center group-hover:bg-violet-600 transition-colors duration-300">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
        class="text-ink-700 group-hover:text-white transition-colors duration-300" set:html={icons[icon]} />
    </div>
  </header>

  <h3 class="text-[1.625rem] font-semibold mb-3 text-ink-900 leading-[1.1] tracking-tight text-balance">{title}</h3>
  <p class="text-[15px] text-ink-600 leading-relaxed text-pretty">{description}</p>
</article>
