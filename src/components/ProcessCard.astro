---
interface Props {
  number: string;
  title: string;
  description: string;
  icon: "screen" | "outreach" | "match" | "calendar" | "compass";
}

const { number, title, description, icon } = Astro.props;

const icons = {
  screen: `<path d="M3 7h18M3 12h18M3 17h12"/><circle cx="20" cy="17" r="3"/>`,
  outreach: `<path d="M3 21v-2a4 4 0 014-4h6a4 4 0 014 4v2"/><circle cx="10" cy="7" r="4"/><path d="M17 11l3-3-3-3"/>`,
  match: `<path d="M9 11l3 3 8-8"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>`,
  calendar: `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>`,
  compass: `<circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/>`,
};
---

<article class="card card-hover h-full flex flex-col">
  <div class="flex items-center gap-4 mb-5">
    <span class="inline-flex w-11 h-11 rounded-xl bg-violet-50 text-violet-700 items-center justify-center font-bold text-sm">
      {number}
    </span>
    <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-violet-700 to-violet-600 flex items-center justify-center shadow-sm">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[icon]} />
    </div>
  </div>
  <h3 class="text-h3 font-bold mb-2.5 text-ink-900 leading-tight">{title}</h3>
  <p class="text-body text-ink-600 leading-relaxed">{description}</p>
</article>
