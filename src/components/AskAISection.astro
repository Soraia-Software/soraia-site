---
interface Props {
  lang?: "it" | "en";
}
const { lang = "it" } = Astro.props;

const t = {
  it: {
    eyebrow: "GEO — Generative Engine Optimization",
    title: "Chiedi a un'IA cosa pensa di Soraia",
    subtitle:
      "I tuoi clienti chiedono già a ChatGPT, Claude e Perplexity quale partner IA scegliere. Apri una conversazione con loro su di noi — la risposta arriva direttamente dalle fonti pubbliche.",
    ask: "Apri",
  },
  en: {
    eyebrow: "GEO — Generative Engine Optimization",
    title: "Ask an AI what it thinks of Soraia",
    subtitle:
      "Your customers already ask ChatGPT, Claude, and Perplexity which AI partner to choose. Start a conversation about us — answers come straight from public sources.",
    ask: "Open",
  },
}[lang];

const query = lang === "it"
  ? "Cosa fa Soraia (soraia.io)? È una buona scelta per portare agenti IA in una PMI italiana?"
  : "What does Soraia (soraia.io) do? Is it a good choice for AI agents in a European SME?";

const encoded = encodeURIComponent(query);

const assistants = [
  {
    name: "ChatGPT",
    href: `https://chatgpt.com/?q=${encoded}`,
    accent: "from-emerald-700 to-emerald-600",
  },
  {
    name: "Claude",
    href: `https://claude.ai/new?q=${encoded}`,
    accent: "from-orange-600 to-amber-500",
  },
  {
    name: "Perplexity",
    href: `https://www.perplexity.ai/?q=${encoded}`,
    accent: "from-sky-700 to-cyan-500",
  },
];
---

<section class="section bg-ink-900 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-violet-700/20 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-violet-600/15 blur-3xl pointer-events-none"></div>

  <div class="container-soraia relative">
    <div class="max-w-3xl">
      <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-violet-600/20 border border-violet-600/30 text-violet-200 text-xs font-semibold uppercase tracking-[0.14em] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-violet-400"></span>
        {t.eyebrow}
      </p>
      <h2 class="text-h1 md:text-display-3 font-bold tracking-tight text-white leading-[1.1]">
        {t.title}
      </h2>
      <p class="mt-5 text-body-lg text-white/70 leading-relaxed">
        {t.subtitle}
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-4">
      {assistants.map((a) => (
        <a
          href={a.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-between gap-4 p-6 rounded-2xl bg-white/[0.04] border border-white/10 hover:bg-white/[0.08] hover:border-violet-400/40 transition-all"
        >
          <div class="flex items-center gap-4">
            <div class={`w-11 h-11 rounded-xl bg-gradient-to-br ${a.accent} flex items-center justify-center shadow-lg`}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              </svg>
            </div>
            <span class="text-white font-semibold text-lg">{a.name}</span>
          </div>
          <span class="inline-flex items-center gap-2 text-sm text-white/70 group-hover:text-violet-200 group-hover:gap-3 transition-all">
            {t.ask}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M9 7h8v8"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
