---
// JetHR-style card: brand logo + quote on photo background, with Dipendenti + Settore pills.
interface Props {
  href: string;
  client: string;
  clientLogo?: string;
  quote: string;             // short quote (1-2 sentenze)
  dimensioni?: string;        // es. "11-50"
  sector: string;
  cardImage?: string;         // background image. fallback: branded gradient
}

const { href, client, clientLogo, quote, dimensioni, sector, cardImage } = Astro.props;
---

<a
  href={href}
  class="jet-card group relative block w-full h-full overflow-hidden rounded-2xl no-underline ring-1 ring-violet-100 transition-all duration-300 hover:-translate-y-1 hover:shadow-violet-lg"
  aria-label={`Case study ${client}`}
>
  {cardImage ? (
    <img
      src={cardImage}
      alt=""
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
  ) : (
    <div class="absolute inset-0" style="background: linear-gradient(160deg, #4A1E5C 0%, #892D9C 55%, #CFA0D8 100%);"></div>
  )}

  <!-- bottom-up dark gradient for legibility -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/15"></div>

  <!-- LOGO (top-left) -->
  {clientLogo && (
    <div class="absolute top-5 left-5 z-10">
      <img
        src={clientLogo}
        alt={client}
        loading="lazy"
        decoding="async"
        class="h-7 md:h-8 w-auto object-contain brightness-0 invert opacity-95"
      />
    </div>
  )}

  <!-- CONTENT (bottom) -->
  <div class="absolute inset-x-0 bottom-0 z-10 p-6 md:p-7 text-white">
    <p class="text-[15px] md:text-[16px] font-semibold leading-snug text-balance mb-5">
      &ldquo;{quote}&rdquo;
    </p>

    <div class="grid grid-cols-2 gap-4 pt-4 border-t border-white/15">
      <div>
        <p class="text-[9.5px] uppercase tracking-[0.2em] font-medium opacity-70 mb-1.5">Dipendenti</p>
        <span class="inline-block text-[12px] font-semibold px-2.5 py-1 rounded-full bg-white/95 text-ink-900">{dimensioni || "—"}</span>
      </div>
      <div>
        <p class="text-[9.5px] uppercase tracking-[0.2em] font-medium opacity-70 mb-1.5">Settore</p>
        <p class="text-[12.5px] font-medium leading-snug">{sector}</p>
      </div>
    </div>
  </div>
</a>

<style>
  .jet-card {
    aspect-ratio: 4 / 5;
    background: #1a1a1a;
  }
</style>
