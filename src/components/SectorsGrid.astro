---
interface Sector {
  name: string;
  description: string;
  href?: string;
  available?: boolean;
  icon: "users" | "briefcase" | "chart" | "building" | "home" | "leaf" | "calendar" | "heart" | "shield";
}

interface Props {
  sectors: Sector[];
}

const { sectors } = Astro.props;

const icons = {
  users: `<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>`,
  briefcase: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>`,
  chart: `<path d="M3 3v18h18"/><path d="M7 12l4-4 4 4 5-5"/>`,
  building: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h.01M15 9h.01M9 15h.01M15 15h.01M12 9v6"/>`,
  home: `<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/>`,
  leaf: `<path d="M3 21c0-7 4-13 9-15 4-2 9 1 9 6 0 7-6 13-13 13-2 0-4-1-5-4z"/><path d="M3 21c5-5 10-10 15-15"/>`,
  calendar: `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>`,
  heart: `<path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>`,
  shield: `<path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/>`,
};
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
  {sectors.map((s) => {
    const isLink = s.href && s.available;
    const Tag = isLink ? "a" : "div";
    return (
      <Tag
        href={isLink ? s.href : undefined}
        class={`card p-6 flex flex-col gap-3 group reveal ${
          isLink ? "card-hover cursor-pointer" : ""
        }`}
      >
        <div class={`w-10 h-10 rounded-lg flex items-center justify-center transition-colors ${
          s.available
            ? "bg-violet-50 text-violet-700 group-hover:bg-violet-600 group-hover:text-white"
            : "bg-ink-100 text-ink-500"
        }`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-ink-900 leading-tight">{s.name}</h3>
          <p class="mt-1 text-sm text-ink-600 leading-snug">{s.description}</p>
        </div>
        {s.available && (
          <span class="inline-flex items-center gap-1 text-xs font-semibold text-violet-700 group-hover:gap-2 transition-all">
            Approfondisci
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        )}
        {!s.available && (
          <span class="text-xs text-ink-400 font-medium">Pagina in arrivo</span>
        )}
      </Tag>
    );
  })}
</div>
