---
interface Props {
  name: string;
  src?: string;
  size?: "sm" | "md" | "lg" | "xl";
  variant?: "violet" | "ink" | "lilac";
}

const { name, src, size = "md", variant = "violet" } = Astro.props;

const initials = name
  .split(" ")
  .map((w) => w[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();

const sizes = {
  sm: "w-10 h-10 text-sm",
  md: "w-14 h-14 text-base",
  lg: "w-20 h-20 text-lg",
  xl: "w-28 h-28 text-2xl",
};

const variants = {
  violet: "bg-gradient-to-br from-violet-700 to-violet-500 text-white",
  ink: "bg-gradient-to-br from-ink-800 to-ink-700 text-white",
  lilac: "bg-gradient-to-br from-violet-500 to-violet-300 text-white",
};
---

<span
  class={`inline-flex items-center justify-center rounded-full font-display font-semibold tracking-tight shrink-0 overflow-hidden ${sizes[size]} ${src ? "" : variants[variant]}`}
  title={name}
>
  {src ? (
    <img src={src} alt={name} loading="lazy" decoding="async" class="w-full h-full object-cover" />
  ) : (
    <span class="leading-none">{initials}</span>
  )}
</span>
