---
interface Props {
  client: string;
  industry: string;
  metric: string;
  metricLabel: string;
  description: string;
  logo?: string;
  href?: string;
  accent?: "violet" | "amber";
}

const { client, industry, metric, metricLabel, description, logo, href } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag
  {...(href ? { href } : {})}
  class={`card-editorial group flex flex-col gap-7 h-full reveal no-underline${href ? " case-card-link" : ""}`}
>
  <header class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-ink-500">{industry}</p>
      <h3 class="text-[1.75rem] md:text-[2rem] font-semibold mt-2 text-ink-900 leading-[0.95] tracking-tight">{client}</h3>
    </div>
    <span class="shrink-0 inline-flex w-11 h-11 rounded-full bg-ink-50 group-hover:bg-violet-600 transition-colors duration-300 items-center justify-center">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        class="text-ink-700 group-hover:text-white transition-colors duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
        <path d="M7 17L17 7M9 7h8v8"/>
      </svg>
    </span>
  </header>

  {logo && (
    <div class="case-card-logo">
      <img src={logo} alt={`${client} logo`} loading="lazy" decoding="async" />
    </div>
  )}

  <div class="hairline"></div>

  <div class="flex-1 flex flex-col justify-end">
    <p class="text-[3.25rem] md:text-[4rem] font-semibold leading-[0.9] tracking-[-0.04em] text-gradient-violet">
      {metric}
    </p>
    <p class="mt-3 text-xs uppercase tracking-[0.16em] text-ink-500 font-semibold">{metricLabel}</p>
  </div>

  <p class="text-[14.5px] text-ink-700 leading-relaxed text-pretty">{description}</p>
</Tag>

<style>
  .case-card-link {
    transition: transform 0.3s var(--ease-out-quart), box-shadow 0.3s var(--ease-out-quart);
  }
  .case-card-link:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px -14px rgba(74, 30, 92, 0.20);
  }
  .case-card-logo {
    display: flex;
    align-items: center;
    height: 40px;
  }
  .case-card-logo img {
    max-height: 36px;
    width: auto;
    max-width: 60%;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.55) contrast(1.05);
    opacity: 0.7;
    transition: filter 0.3s ease, opacity 0.3s ease;
    mix-blend-mode: multiply;
  }
  .case-card-link:hover .case-card-logo img {
    filter: grayscale(0%) brightness(1);
    opacity: 1;
  }
</style>
