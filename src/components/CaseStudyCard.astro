---
interface Props {
  client: string;
  industry: string;
  metric: string;
  metricLabel: string;
  description: string;
  accent?: "violet" | "amber";
}

const { client, industry, metric, metricLabel, description, accent = "violet" } = Astro.props;

const accentClasses = {
  violet: "from-violet-700 to-violet-600",
  amber: "from-amber-500 to-amber-400",
};
---

<article class="card card-hover flex flex-col gap-6 h-full">
  <header class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.14em] text-ink-500">{industry}</p>
      <h3 class="text-h3 font-bold mt-1.5 text-ink-900 leading-tight">{client}</h3>
    </div>
    <div class={`shrink-0 inline-flex w-12 h-12 rounded-xl bg-gradient-to-br ${accentClasses[accent]} items-center justify-center shadow-violet`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17L17 7M9 7h8v8"/>
      </svg>
    </div>
  </header>

  <div class="flex-1">
    <div class="flex items-baseline gap-3">
      <span class="text-display-3 font-bold leading-none text-gradient-violet">{metric}</span>
    </div>
    <p class="text-sm text-ink-600 mt-1">{metricLabel}</p>
  </div>

  <p class="text-body text-ink-700 leading-relaxed">{description}</p>
</article>
