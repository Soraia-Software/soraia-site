---
interface Metric {
  value: string;
  label: string;
  detail?: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-ink-200 rounded-2xl overflow-hidden">
  {metrics.map((m) => (
    <div class="bg-white p-7 md:p-10">
      <p class="text-display-3 md:text-display-2 font-bold tracking-tight leading-none text-gradient-violet">
        {m.value}
      </p>
      <p class="mt-3 text-sm font-medium text-ink-900 leading-tight">{m.label}</p>
      {m.detail && (
        <p class="mt-1 text-xs text-ink-500">{m.detail}</p>
      )}
    </div>
  ))}
</div>
