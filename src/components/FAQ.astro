---
interface Item {
  q: string;
  a: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-ink-200 border-y border-ink-200">
  {items.map((item) => (
    <details class="group py-6 [&[open]>summary>svg]:rotate-45">
      <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
        <h3 class="text-lg md:text-xl font-semibold text-ink-900 leading-snug group-hover:text-violet-700 transition-colors">
          {item.q}
        </h3>
        <svg
          class="shrink-0 mt-1 w-6 h-6 text-violet-600 transition-transform duration-300"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 5v14M5 12h14" />
        </svg>
      </summary>
      <div class="mt-4 text-body text-ink-700 leading-relaxed max-w-3xl">
        <Fragment set:html={item.a} />
      </div>
    </details>
  ))}
</div>
