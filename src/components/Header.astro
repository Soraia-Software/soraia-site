---
interface Props {
  lang?: "it" | "en";
}

const { lang = "it" } = Astro.props;

const labels = {
  it: {
    nav_agents: "AI Agents",
    nav_recruitment: "Recruitment",
    nav_cases: "Casi studio",
    cta: "Assessment",
  },
  en: {
    nav_agents: "AI Agents",
    nav_recruitment: "Recruitment",
    nav_cases: "Case studies",
    cta: "Assessment",
  },
}[lang];

const homeHref = lang === "en" ? "/en/" : "/";
const agentsHref = lang === "en" ? "/en/ai-agents" : "/ai-agents";
const recHref = lang === "en" ? "/en/recruitment" : "/recruitment";
const otherLang = lang === "it" ? "en" : "it";
const otherHref = otherLang === "en"
  ? Astro.url.pathname === "/" ? "/en/" : `/en${Astro.url.pathname}`
  : Astro.url.pathname.replace(/^\/en/, "") || "/";
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-ink-50/80 border-b border-ink-200/60">
  <div class="container-soraia">
    <nav class="flex items-center justify-between h-16 md:h-[72px]" aria-label="Main">
      <a href={homeHref} class="flex items-center gap-2.5 group" aria-label="Soraia home">
        <img
          src="/logos/soraia-mark.svg"
          alt=""
          width="32"
          height="32"
          class="w-8 h-8 transition-transform duration-300 group-hover:scale-105"
        />
        <span class="font-display text-[1.125rem] font-semibold tracking-tight">Soraia</span>
      </a>

      <ul class="hidden md:flex items-center gap-9 text-[14px] text-ink-700">
        <li><a href={agentsHref} class="link-underline-anim hover:text-ink-900 transition-colors">{labels.nav_agents}</a></li>
        <li><a href={recHref} class="link-underline-anim hover:text-ink-900 transition-colors">{labels.nav_recruitment}</a></li>
        <li><a href={`${homeHref}#cases`} class="link-underline-anim hover:text-ink-900 transition-colors">{labels.nav_cases}</a></li>
      </ul>

      <div class="flex items-center gap-3">
        <a
          href={otherHref}
          class="hidden sm:inline-flex text-[11px] font-semibold text-ink-500 hover:text-ink-900 transition-colors uppercase tracking-[0.14em]"
          aria-label={`Switch to ${otherLang.toUpperCase()}`}
        >
          {otherLang.toUpperCase()}
        </a>
        <a href="#contact" class="btn btn-primary !py-2.5 !px-4 text-[13px]">
          {labels.cta}
          <span class="btn-arrow">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </nav>
  </div>
</header>
