---
interface Props {
  lang?: "it" | "en";
}

const { lang = "it" } = Astro.props;

const labels = {
  it: {
    nav_servizi: "Servizi",
    nav_prodotti: "Prodotti",
    nav_guide: "Guide",
    nav_cases: "Case studies",
    nav_blog: "Blog",
    nav_about: "Chi siamo",
    nav_scorecard: "Check-up IA",
    cta: "20 min con Daniel",
    badge_min: "3 min",
    coming_soon: "In arrivo",
  },
  en: {
    nav_servizi: "Services",
    nav_prodotti: "Products",
    nav_guide: "Guides",
    nav_cases: "Case studies",
    nav_blog: "Blog",
    nav_about: "About",
    nav_scorecard: "AI Check-up",
    cta: "20 min with Daniel",
    badge_min: "3 min",
    coming_soon: "Coming soon",
  },
}[lang];

const homeHref = lang === "en" ? "/en/" : "/";
const agentsHref = lang === "en" ? "/en/ai-agents" : "/ai-agents";
const adoptionHref = lang === "en" ? "/en/ai-adoption" : "/ai-adoption";
const prodottiHref = lang === "en" ? "/en/prodotti" : "/prodotti";
const guideHref = lang === "en" ? "/en/guide" : "/guide";
const casesHref = lang === "en" ? "/en/case-studies" : "/case-studies";
const blogHref = lang === "en" ? "/en/blog" : "/blog";
const aboutHref = lang === "en" ? "/en/chi-siamo" : "/chi-siamo";
const scorecardHref = lang === "en" ? "/en/check-up" : "/check-up";
const otherLang = lang === "it" ? "en" : "it";
const otherHref = otherLang === "en"
  ? Astro.url.pathname === "/" ? "/en/" : `/en${Astro.url.pathname}`
  : Astro.url.pathname.replace(/^\/en/, "") || "/";

const servizi = [
  {
    href: adoptionHref,
    title: "AI Adoption",
    subtitle: lang === "en"
      ? "End-to-end sprint to embed AI into your operations"
      : "Sprint operativo per integrare l'AI nei vostri processi",
    iconPath: '<path d="M12 21a9 9 0 1 1 0 -18a9 9 0 0 1 0 18z" /><path d="M14.5 9.5l-5 1l1 5l5 -1l-1 -5z" /><path d="M13 13l-1.5 -1.5" />',
  },
  {
    href: agentsHref,
    title: "AI Agents",
    subtitle: lang === "en"
      ? "Sprint to ship one production-ready agent in your workflow"
      : "Sprint per costruire un AI agent custom dentro i vostri processi",
    iconPath: '<path d="M9 7l-2 -2l-2 2l2 2z" /><path d="M19 5l-2 -2l-2 2l2 2z" /><path d="M5 21h14" /><path d="M9 21v-8a3 3 0 0 1 6 0v8" /><path d="M12 13v8" />',
  },
];

const prodotti = [
  {
    href: "https://linkly.soraia.io",
    title: "Linkly",
    subtitle: lang === "en"
      ? "AI agents for B2B fairs · lead capture, enrichment, CRM activation"
      : "AI agents per fiere B2B · cattura, arricchimento, attivazione CRM",
    badge: null,
    external: true,
    iconPath: '<path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0z" /><path d="M12 3c7.2 0 9 1.8 9 9s-1.8 9 -9 9s-9 -1.8 -9 -9s1.8 -9 9 -9z" />',
  },
  {
    href: prodottiHref + "#sourcer",
    title: "Sourcer",
    subtitle: lang === "en"
      ? "Chrome extension for recruiters · capture candidates from LinkedIn into your ATS"
      : "Chrome extension per recruiter · candidati da LinkedIn dentro l'ATS in un click",
    badge: labels.coming_soon,
    external: false,
    iconPath: '<path d="M10 4h-4a2 2 0 0 0 -2 2v4c1.105 0 2 0.895 2 2c0 1.105 -0.895 2 -2 2v4a2 2 0 0 0 2 2h4c0 -1.105 0.895 -2 2 -2c1.105 0 2 0.895 2 2h4a2 2 0 0 0 2 -2v-4c-1.105 0 -2 -0.895 -2 -2c0 -1.105 0.895 -2 2 -2v-4a2 2 0 0 0 -2 -2h-4c0 1.105 -0.895 2 -2 2c-1.105 0 -2 -0.895 -2 -2z" />',
  },
];
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-ink-50/80 border-b border-ink-200/60">
  <div class="container-soraia">
    <nav class="flex items-center justify-between h-16 md:h-[72px]" aria-label="Main">
      <a href={homeHref} class="flex items-center gap-2.5 group" aria-label="Soraia home">
        <img
          src="/logos/soraia-mark.svg"
          alt=""
          width="32"
          height="32"
          class="w-8 h-8 transition-transform duration-300 group-hover:scale-105"
        />
        <span class="text-[1.125rem] font-semibold tracking-tight">Soraia</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1 lg:gap-2 text-[14px] text-ink-700" data-nav>

        <!-- Servizi dropdown -->
        <li class="nav-dropdown relative" data-dropdown>
          <button
            class="nav-trigger inline-flex items-center gap-1.5 px-3 py-2 rounded-md hover:text-ink-900 hover:bg-ink-100/60 transition-colors"
            type="button"
            aria-expanded="false"
            aria-haspopup="true"
          >
            <span>{labels.nav_servizi}</span>
            <svg class="nav-chevron w-3.5 h-3.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div class="nav-panel">
            {servizi.map((s) => (
              <a href={s.href} class="nav-panel-item group">
                <span class="nav-panel-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={s.iconPath} />
                </span>
                <span class="nav-panel-text">
                  <span class="nav-panel-title">{s.title}</span>
                  <span class="nav-panel-subtitle">{s.subtitle}</span>
                </span>
              </a>
            ))}
          </div>
        </li>

        <!-- Prodotti link (no dropdown) -->
        <li><a href={prodottiHref} class="link-underline-anim px-3 py-2 hover:text-ink-900 transition-colors">{labels.nav_prodotti}</a></li>

        <li><a href={casesHref} class="link-underline-anim px-3 py-2 hover:text-ink-900 transition-colors">{labels.nav_cases}</a></li>
        <li><a href={guideHref} class="link-underline-anim px-3 py-2 hover:text-ink-900 transition-colors">{labels.nav_guide}</a></li>
        <li><a href={blogHref} class="link-underline-anim px-3 py-2 hover:text-ink-900 transition-colors">{labels.nav_blog}</a></li>
        <li><a href={aboutHref} class="link-underline-anim px-3 py-2 hover:text-ink-900 transition-colors">{labels.nav_about}</a></li>
        <li>
          <a href={scorecardHref} class="link-underline-anim px-3 py-2 hover:text-ink-900 transition-colors inline-flex items-center gap-1.5">
            {labels.nav_scorecard}
            <span class="text-[10px] font-semibold tracking-[0.1em] uppercase px-1.5 py-0.5 rounded-full" style="background: var(--color-violet-50, #F5EEF7); color: var(--color-brand);">{labels.badge_min}</span>
          </a>
        </li>
      </ul>

      <div class="flex items-center gap-3">
        <a
          href={otherHref}
          class="hidden sm:inline-flex text-[11px] font-semibold text-ink-500 hover:text-ink-900 transition-colors uppercase tracking-[0.14em]"
          aria-label={`Switch to ${otherLang.toUpperCase()}`}
        >
          {otherLang.toUpperCase()}
        </a>
        <button
          type="button"
          class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-md hover:bg-ink-100"
          aria-label="Apri menu"
          data-mobile-trigger
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <a href="/parliamone" class="btn btn-primary !py-2.5 !px-4 text-[13px]">
          {labels.cta}
          <span class="btn-arrow">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </nav>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer md:hidden" data-mobile-drawer aria-hidden="true">
    <div class="mobile-drawer__overlay" data-mobile-close></div>
    <aside class="mobile-drawer__panel" role="dialog" aria-label="Menu">
      <div class="flex items-center justify-between p-5 border-b border-ink-200/60">
        <span class="text-[16px] font-semibold tracking-tight">Soraia</span>
        <button type="button" class="w-9 h-9 inline-flex items-center justify-center rounded-md hover:bg-ink-100" data-mobile-close aria-label="Chiudi menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <nav class="p-5 space-y-1">
        <details class="mobile-section">
          <summary class="mobile-section__summary">
            <span>{labels.nav_servizi}</span>
            <svg class="mobile-section__chev w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="mobile-section__panel">
            {servizi.map((s) => (
              <a href={s.href} class="mobile-section__link">
                <strong>{s.title}</strong>
                <span>{s.subtitle}</span>
              </a>
            ))}
          </div>
        </details>

        <a href={prodottiHref} class="mobile-section__top">{labels.nav_prodotti}</a>
        <a href={casesHref} class="mobile-section__top">{labels.nav_cases}</a>
        <a href={guideHref} class="mobile-section__top">{labels.nav_guide}</a>
        <a href={blogHref} class="mobile-section__top">{labels.nav_blog}</a>
        <a href={aboutHref} class="mobile-section__top">{labels.nav_about}</a>
        <a href={scorecardHref} class="mobile-section__top">{labels.nav_scorecard} <span class="text-[10px] font-semibold tracking-[0.1em] uppercase px-1.5 py-0.5 rounded-full ml-2" style="background: var(--color-violet-50, #F5EEF7); color: var(--color-brand);">{labels.badge_min}</span></a>
      </nav>

      <div class="p-5 border-t border-ink-200/60">
        <a href="/parliamone" class="btn btn-primary w-full justify-center text-[14px]">{labels.cta}</a>
      </div>
    </aside>
  </div>
</header>

<style>
  /* =============================================================
     DROPDOWN NAV — desktop hover + click, mobile drawer accordion
     ============================================================= */

  .nav-dropdown[data-open="true"] .nav-trigger,
  .nav-dropdown[data-open="true"] .nav-trigger > span {
    color: var(--color-brand);
  }
  .nav-dropdown[data-open="true"] .nav-chevron {
    transform: rotate(180deg);
    color: var(--color-brand);
  }

  .nav-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 340px;
    max-width: 400px;
    background: white;
    border: 1px solid var(--color-line);
    border-radius: 14px;
    box-shadow: 0 16px 48px -16px rgba(74, 30, 92, 0.18);
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 200ms ease, transform 200ms ease, visibility 200ms;
    z-index: 60;
  }
  .nav-dropdown[data-open="true"] .nav-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-panel-item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    transition: background-color 160ms ease;
    text-decoration: none;
  }
  .nav-panel-item:hover {
    background: var(--color-violet-50, #F5EEF7);
  }

  .nav-panel-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
    background: var(--color-violet-50, #F5EEF7);
    color: var(--color-brand);
  }
  .nav-panel-icon svg {
    width: 20px;
    height: 20px;
  }

  .nav-panel-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .nav-panel-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    line-height: 1.25;
  }
  .nav-panel-item:hover .nav-panel-title {
    color: var(--color-brand);
  }
  .nav-panel-subtitle {
    font-size: 12.5px;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }
  .nav-panel-badge {
    font-size: 9.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--color-violet-50, #F5EEF7);
    color: var(--color-brand);
    font-family: inherit;
  }

  /* =============================================================
     MOBILE DRAWER
     ============================================================= */

  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    opacity: 0;
    transition: opacity 240ms ease;
  }
  .mobile-drawer[aria-hidden="false"] {
    pointer-events: auto;
    opacity: 1;
  }
  .mobile-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(2px);
  }
  .mobile-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(92vw, 380px);
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 280ms ease;
  }
  .mobile-drawer[aria-hidden="false"] .mobile-drawer__panel {
    transform: translateX(0);
  }

  .mobile-section {
    border-radius: 10px;
  }
  .mobile-section__summary {
    list-style: none;
    cursor: pointer;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink);
    border-radius: 10px;
  }
  .mobile-section__summary::-webkit-details-marker { display: none; }
  .mobile-section[open] .mobile-section__summary {
    background: var(--color-violet-50, #F5EEF7);
    color: var(--color-brand);
  }
  .mobile-section[open] .mobile-section__chev {
    transform: rotate(180deg);
    color: var(--color-brand);
  }
  .mobile-section__chev {
    transition: transform 200ms ease;
  }
  .mobile-section__panel {
    padding: 0.5rem 0.5rem 0.75rem;
  }
  .mobile-section__link {
    display: block;
    padding: 0.7rem 1rem;
    border-radius: 8px;
    text-decoration: none;
  }
  .mobile-section__link:hover {
    background: var(--color-surface);
  }
  .mobile-section__link strong {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.15rem;
  }
  .mobile-section__link span {
    font-size: 12.5px;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }
  .mobile-section__badge {
    font-style: normal;
    font-size: 9.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--color-violet-50, #F5EEF7);
    color: var(--color-brand);
    margin-left: 0.4rem;
  }
  .mobile-section__top {
    display: block;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
  }
  .mobile-section__top:hover {
    background: var(--color-surface);
  }
</style>

<script is:inline>
  (function () {
    const dropdowns = document.querySelectorAll("[data-dropdown]");
    let openTimer;

    function closeAll(except) {
      dropdowns.forEach((d) => {
        if (d !== except) {
          d.removeAttribute("data-open");
          d.querySelector(".nav-trigger")?.setAttribute("aria-expanded", "false");
        }
      });
    }

    function open(d) {
      clearTimeout(openTimer);
      closeAll(d);
      d.setAttribute("data-open", "true");
      d.querySelector(".nav-trigger")?.setAttribute("aria-expanded", "true");
    }

    function close(d) {
      d.removeAttribute("data-open");
      d.querySelector(".nav-trigger")?.setAttribute("aria-expanded", "false");
    }

    const isDesktop = () => window.matchMedia("(min-width: 768px)").matches;

    dropdowns.forEach((d) => {
      const trigger = d.querySelector(".nav-trigger");

      // Click toggle (always works)
      trigger?.addEventListener("click", (e) => {
        e.preventDefault();
        if (d.getAttribute("data-open") === "true") close(d);
        else open(d);
      });

      // Hover open (desktop only)
      d.addEventListener("mouseenter", () => {
        if (isDesktop()) open(d);
      });
      d.addEventListener("mouseleave", () => {
        if (isDesktop()) {
          clearTimeout(openTimer);
          openTimer = setTimeout(() => close(d), 180);
        }
      });
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
      if (!e.target.closest("[data-dropdown]")) closeAll();
    });

    // Close on ESC
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAll();
    });

    // Mobile drawer
    const drawer = document.querySelector("[data-mobile-drawer]");
    const mobileTrigger = document.querySelector("[data-mobile-trigger]");
    const mobileCloses = document.querySelectorAll("[data-mobile-close]");

    function openDrawer() {
      drawer.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }
    function closeDrawer() {
      drawer.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    mobileTrigger?.addEventListener("click", openDrawer);
    mobileCloses.forEach((b) => b.addEventListener("click", closeDrawer));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && drawer?.getAttribute("aria-hidden") === "false") closeDrawer();
    });
  })();
</script>
