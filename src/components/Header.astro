---
interface Props {
  lang?: "it" | "en";
}

const { lang = "it" } = Astro.props;

const labels = {
  it: {
    nav_recruitment: "Recruitment",
    nav_cases: "Casi studio",
    nav_about: "Soraia",
    cta: "Prenota assessment",
  },
  en: {
    nav_recruitment: "Recruitment",
    nav_cases: "Case studies",
    nav_about: "Soraia",
    cta: "Book assessment",
  },
}[lang];

const homeHref = lang === "en" ? "/en/" : "/";
const recHref = lang === "en" ? "/en/recruitment" : "/recruitment";
const otherLang = lang === "it" ? "en" : "it";
const otherHref = otherLang === "en"
  ? Astro.url.pathname === "/" ? "/en/" : `/en${Astro.url.pathname}`
  : Astro.url.pathname.replace(/^\/en/, "") || "/";
---

<header class="sticky top-0 z-50 backdrop-blur-lg bg-white/75 border-b border-ink-100">
  <div class="container-soraia">
    <nav class="flex items-center justify-between h-16 md:h-20" aria-label="Main">
      <a href={homeHref} class="flex items-center gap-2 group" aria-label="Soraia home">
        <span class="inline-block w-8 h-8 rounded-lg bg-gradient-to-br from-violet-700 to-violet-600 shadow-violet group-hover:scale-105 transition-transform"></span>
        <span class="text-xl font-bold tracking-tight">Soraia</span>
      </a>

      <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-ink-700">
        <li><a href={recHref} class="hover:text-violet-700 transition-colors">{labels.nav_recruitment}</a></li>
        <li><a href={`${homeHref}#cases`} class="hover:text-violet-700 transition-colors">{labels.nav_cases}</a></li>
        <li><a href={`${homeHref}#about`} class="hover:text-violet-700 transition-colors">{labels.nav_about}</a></li>
      </ul>

      <div class="flex items-center gap-3">
        <a
          href={otherHref}
          class="hidden sm:inline-flex text-sm font-medium text-ink-600 hover:text-violet-700 transition-colors uppercase tracking-wider"
          aria-label={`Switch to ${otherLang.toUpperCase()}`}
        >
          {otherLang.toUpperCase()}
        </a>
        <a href="#contact" class="btn btn-primary text-sm">
          {labels.cta}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>
