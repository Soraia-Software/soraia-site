---
interface Props {
  size?: number;
}

const { size = 600 } = Astro.props;
---

<div class="soraia-globe-wrapper" data-globe-size={size}>
  <div class="soraia-globe-inner">
    <canvas class="soraia-globe-canvas" data-globe-canvas></canvas>
    <div class="soraia-globe-fade" aria-hidden="true"></div>
  </div>
</div>

<script>
  import createGlobe from "cobe";

  function initGlobe(wrapper) {
    const canvas = wrapper.querySelector("[data-globe-canvas]");
    if (!canvas) return;

    let phi = 0;
    const theta = 0.25;
    let pointerInteracting = null;
    let pointerMovement = 0;
    let width = 0;

    function measure() {
      width = wrapper.getBoundingClientRect().width || 560;
      canvas.style.width = width + "px";
      canvas.style.height = width + "px";
    }
    measure();

    const dpr = Math.min(window.devicePixelRatio || 2, 2);

    const globe = createGlobe(canvas, {
      devicePixelRatio: dpr,
      width: width * dpr,
      height: width * dpr,
      phi: 0,
      theta: theta,
      dark: 0,
      diffuse: 1.2,
      mapSamples: 16000,
      mapBrightness: 5.5,
      baseColor: [0.94, 0.93, 0.91],
      markerColor: [74 / 255, 30 / 255, 92 / 255],
      glowColor: [0.93, 0.9, 0.94],
      markers: [
        { location: [41.9, 12.5], size: 0.10 },
        { location: [39.8, -98.5], size: 0.08 },
        { location: [24.5, 54.4], size: 0.06 },
        { location: [-25.3, 133.8], size: 0.05 },
      ],
    });

    function tick() {
      if (pointerInteracting === null) {
        phi += 0.0035;
      }
      globe.update({
        phi: phi + pointerMovement,
        theta: theta,
        width: width * dpr,
        height: width * dpr,
      });
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    requestAnimationFrame(function fadeIn() {
      canvas.style.opacity = "1";
    });

    canvas.style.cursor = "grab";

    canvas.addEventListener("pointerdown", function (e) {
      pointerInteracting = e.clientX - pointerMovement;
      canvas.style.cursor = "grabbing";
    });
    window.addEventListener("pointerup", function () {
      pointerInteracting = null;
      canvas.style.cursor = "grab";
    });
    window.addEventListener("pointercancel", function () {
      pointerInteracting = null;
      canvas.style.cursor = "grab";
    });
    window.addEventListener("pointermove", function (e) {
      if (pointerInteracting !== null) {
        pointerMovement = (e.clientX - pointerInteracting) / 200;
      }
    });
    canvas.addEventListener("touchmove", function (e) {
      if (pointerInteracting !== null && e.touches[0]) {
        pointerMovement = (e.touches[0].clientX - pointerInteracting) / 100;
      }
    }, { passive: true });

    const ro = new ResizeObserver(measure);
    ro.observe(wrapper);
  }

  function bootstrap() {
    document.querySelectorAll(".soraia-globe-wrapper").forEach(initGlobe);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootstrap);
  } else {
    bootstrap();
  }
</script>

<style is:global>
  .soraia-globe-wrapper {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
    aspect-ratio: 1 / 1;
  }
  .soraia-globe-inner {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .soraia-globe-canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    contain: layout paint size;
    opacity: 0;
    transition: opacity 600ms ease;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }
  .soraia-globe-fade {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at center, transparent 60%, rgba(250, 250, 248, 0.35) 82%, var(--color-bg) 100%);
  }
</style>
